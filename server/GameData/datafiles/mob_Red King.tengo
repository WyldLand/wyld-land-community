---aura_Phase Transition Immunity---
Type :: Buff
Duration :: 5.0
Icon :: statusicons_36
Max Stacks :: 1
Time Per Tick :: 1.0
Definitions :: [[Custom:PhaseTransitionImmunity]]

---script_PhaseTransitionImmunity_IncomingDamage---
// Negate all damage during phase transition
additionalDamage = -1 * damage

---script_redking_Monster---
resetVars := func() {
	scriptVars["timeSinceShoot"] = 0.0
	scriptVars["timeSinceStab"] = 0.0
	scriptVars["timeSinceTeleport"] = 0.0
	scriptVars["timeSinceAction"] = 0.0
	scriptVars["timeSinceCharge"] = 0.0
	scriptVars["timeSincePulse"] = 0.0  // New timer for Bloody Pulse
	scriptVars["phase"] = 1
	scriptVars["didPhaseTransition"] = false
	scriptVars["inTransition"] = false
	scriptVars["transitionTimer"] = 0.0
	scriptVars["saidDeathPhrase"] = false
	scriptVars["saidIntroPhrase"] = false
}

if !isDead {
	if is_undefined(scriptVars["timeSinceShoot"]) {
		resetVars()
	}
	
	// Add intro phrase when first seeing a player
	if targetEntityId > 0 && !scriptVars["saidIntroPhrase"] {
		say(myEntityId, "Finally, a real battle!")
		scriptVars["saidIntroPhrase"] = true
	}

	// Check for phase transition
	currentHealth := float(getPoints(myEntityId, "hp", "current"))
	maxHealth := float(getPoints(myEntityId, "hp", "max"))
	
	// Phase transition at 50% health
	if currentHealth < maxHealth * 0.5 && scriptVars["phase"] == 1 {
		if !scriptVars["inTransition"] && !scriptVars["didPhaseTransition"] {
			// Start phase transition and add invulnerability
			say(myEntityId, "Looks like I'll have to step it up!")
			addAuraToEntity(myEntityId, "Phase Transition Immunity", 0, myEntityId)
			scriptVars["inTransition"] = true
			scriptVars["transitionTimer"] = 0.0
			useAbilityAtPosition(myEntityId, "Phase Transition", entityPosition(myEntityId))
			
			// Visual effect to indicate invulnerability
			showVfxAtPosition(myEntityId, "Shield", entityPosition(myEntityId))
		}
	}
	
	// Handle phase transition
	if scriptVars["inTransition"] {
		scriptVars["transitionTimer"] += delta
		
		// After 2 seconds, complete the transition
		if scriptVars["transitionTimer"] >= 2.0 {
			scriptVars["inTransition"] = false
			scriptVars["didPhaseTransition"] = true
			scriptVars["phase"] = 2
			
			// Visual effect for phase transition completion
			triggerAnimation(myEntityId, "Buff")
			
			// Reset all timers after phase transition
			scriptVars["timeSinceShoot"] = 0.0
			scriptVars["timeSinceStab"] = 0.0
			scriptVars["timeSinceTeleport"] = 0.0
			scriptVars["timeSinceAction"] = 0.0
			scriptVars["timeSinceCharge"] = 0.0
			scriptVars["timeSincePulse"] = 0.0
		}
		
		// Skip the rest of the function execution when in transition
	} else {
	
		if targetEntityId > 0 {
			scriptVars["timeSinceShoot"] += delta
			scriptVars["timeSinceStab"] += delta
			scriptVars["timeSincePulse"] += delta  // Update Pulse timer

			if castingAction == 0 {
				scriptVars["timeSinceTeleport"] += delta
				scriptVars["timeSinceCharge"] += delta
				scriptVars["timeSinceAction"] += delta
				
				// Force a Bloody Slash every 20 seconds if it hasn't happened
				if scriptVars["timeSinceShoot"] > 1.50 {
					scriptVars["timeSinceShoot"] = 0.0
					scriptVars["timeSinceAction"] = 0.0
					
					if scriptVars["phase"] >= 2 {
						// Use enhanced version in phase 2
						useAbilityAtTarget(myEntityId, "Bloody Slash Phase Two", targetEntityId, 0.0)
					} else {
						// Use normal version in phase 1
						useAbilityAtTarget(myEntityId, "Bloody Slash", targetEntityId, 0.0)
					}
				}
				
				if scriptVars["timeSinceAction"] > 1.0 {
					// Prioritize actions with less overlap
					if scriptVars["timeSinceCharge"] > 28.0 {
						scriptVars["timeSinceCharge"] = 0.0
						scriptVars["timeSinceAction"] = 0.0
						useAbilityAtPosition(myEntityId, "Bloody Charge", entityPosition(myEntityId))
					} else if scriptVars["timeSinceTeleport"] > 11.0 {
						scriptVars["timeSinceTeleport"] = 0.0
						scriptVars["timeSinceAction"] = 0.0
						
						// Handle teleport based on phase
						if scriptVars["phase"] >= 2 {
							// Phase 2: Direct teleport to target and slam
							targetEntId := randomTargetEntityId(myEntityId, 100.0)
							setPosition(myEntityId, entityPosition(targetEntId))
							useAbilityAtPosition(myEntityId, "Bloody Slam Phase Two", entityPosition(myEntityId))
						} else {
							// Phase 1: Use original teleport
							targetEntId := randomTargetEntityId(myEntityId, 100.0)
							setPosition(myEntityId, entityPosition(targetEntId))
							useAbilityAtPosition(myEntityId, "Bloody Slam", entityPosition(myEntityId))
						}
					} else if scriptVars["timeSincePulse"] > 5.0 {  // Use Bloody Pulse every 5 seconds
						scriptVars["timeSincePulse"] = 0.0
						scriptVars["timeSinceAction"] = 0.0
						
						if scriptVars["phase"] >= 2 {
							// In phase 2, place multiple pulses for increased difficulty
							useAbilityAtPosition(myEntityId, "Bloody Pulse", randomPositionInCurrentRoom(myEntityId, 3.0))
							useAbilityAtPosition(myEntityId, "Bloody Pulse", randomPositionInCurrentRoom(myEntityId, 3.0))
						} else {
							// In phase 1, just one pulse
							useAbilityAtPosition(myEntityId, "Bloody Pulse", randomPositionInCurrentRoom(myEntityId, 3.0))
						}
					} else if scriptVars["timeSinceStab"] > 5.0 {
						scriptVars["timeSinceStab"] = 0.0
						scriptVars["timeSinceAction"] = 0.0
						useAbilityAtPosition(myEntityId, "Bloody Stab", entityPosition(myEntityId))
					} else if scriptVars["timeSinceShoot"] > 1.5 {
						scriptVars["timeSinceShoot"] = 0.0
						scriptVars["timeSinceAction"] = 0.0
						
						if scriptVars["phase"] >= 2 {
							// Use enhanced version in phase 2
							// Use actual target instead of random
							useAbilityAtTarget(myEntityId, "Bloody Slash Phase Two", targetEntityId, 0.0)
						} else {
							// Use normal version in phase 1
							// Use actual target instead of random
							useAbilityAtTarget(myEntityId, "Bloody Slash", targetEntityId, 0.0)
						}
					}
				}
			}
		}
	}
}

if isDead && !scriptVars["saidDeathPhrase"] {
	say(myEntityId, "A battle...well fought...")
	scriptVars["saidDeathPhrase"] = true
}
