---ability_Bloody Charge---
VFX Charging :: trigger:Teleport*
Cast Time :: 15.0
Script :: BloodyCharge

---script_BloodyCharge_Cast---
setSpeed(myEntityId, 0.0) //so we don't move while we're casing this

if frameNum == 1 {
	//Spawn our helpers
	aggroMyTargets(myEntityId, summonEntity("redball", positionInCurrentRoom(myEntityId, [16.0,6.0,0.0]), monsterLevel(myEntityId)))
	aggroMyTargets(myEntityId, summonEntity("redball", positionInCurrentRoom(myEntityId, [16.0,25.0,0.0]), monsterLevel(myEntityId)))
	aggroMyTargets(myEntityId, summonEntity("redball", positionInCurrentRoom(myEntityId, [25.0,15.0,0.0]), monsterLevel(myEntityId)))
	//aggroMyTargets(myEntityId, summonEntity("redball", positionInCurrentRoom(myEntityId, [5.0,15.0,0.0]), monsterLevel(myEntityId)))
}

if frameNum == 15 {
	setCollisionLayer(myEntityId, CollisionLayerDynamic)
}

if frameNum == 284 {
	triggerAnimation(myEntityId, "Reappear")
	setCollisionLayer(myEntityId, CollisionLayerMonster)
}

if frameNum == 299 {
	//Come back

	currentNearby := getNearbyEntities(myEntityId)
	ballsAlive := 0
	for i := 0; i < len(currentNearby); i++ {
		if currentNearby[i].prefab == "redball" && !isEntityDead(currentNearby[i].id) {
			//triggerAnimation(currentNearby[i].id, "Heal")
			useAbilityAtPosition(currentNearby[i].id, "Red Ball Heal", [0.0,0.0,0.0])
			killEntity(currentNearby[i].id)
			ballsAlive++
		}
	}


	dealPotencyToEntity(myEntityId, myEntityId, -1000 * ballsAlive, 0)
}

---ability_Bloody Slam---
