					scriptVars["allyIDsReady"]=2
					dispelAuraOnEntity(myEntityId, "Idrae Phase Two Speed Buff")
					dispelAuraOnEntity(myEntityId, "Invulnerability Indicator")
					addAuraToEntity(myEntityId, "Idrae Phase Two Speed Debuff", 0, myEntityId)
					changeAttackBehaviour(myEntityId, "Short Ranged")
					pathTo(myEntityId, targetEntityId)
					useAbilityAtPosition(myEntityId, "Idrae Phase Two Room Limiter", positionInCurrentRoom(myEntityId, [21.0,3.0,0.0]))
					useAbilityAtPosition(myEntityId, "Idrae Phase Two Room Limiter", positionInCurrentRoom(myEntityId, [21.0,39.0,0.0]))
