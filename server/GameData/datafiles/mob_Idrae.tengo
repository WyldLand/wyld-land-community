					scriptVars["towerOne"]=scriptVars["allyIDs"][1]["id"]
					scriptVars["towerTwo"]=scriptVars["allyIDs"][2]["id"]
					scriptVars["towerThree"]=scriptVars["allyIDs"][3]["id"]
					scriptVars["towerFour"]=scriptVars["allyIDs"][4]["id"]
