					useAbilityAtPosition(myEntityId, "Idrae Phase Two Room Limiter Three Warning", positionInCurrentRoom(myEntityId, [21.0,36.5,0.0]))
					useAbilityAtPosition(myEntityId, "Idrae Phase Two Room Limiter Four Warning", positionInCurrentRoom(myEntityId, [5.5,21.0,0.0]))
					useAbilityAtPosition(myEntityId, "Idrae Phase Two Room Limiter Four Warning", positionInCurrentRoom(myEntityId, [36.5,21.0,0.0]))
				scriptVars["WallTimer"]=5.0
				}
				if scriptVars["WallTimer"]>15.0	{
					useAbilityAtPosition(myEntityId, "Idrae Phase Two Room Limiter", positionInCurrentRoom(myEntityId, [21.0,3.0,0.0]))
					useAbilityAtPosition(myEntityId, "Idrae Phase Two Room Limiter", positionInCurrentRoom(myEntityId, [21.0,39.0,0.0]))
					useAbilityAtPosition(myEntityId, "Idrae Phase Two Room Limiter Two", positionInCurrentRoom(myEntityId, [3.0,21.0,0.0]))
