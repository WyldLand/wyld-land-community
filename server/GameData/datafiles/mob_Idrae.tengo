					useAbilityAtPosition(myEntityId, "Idrae Phase Two Room Limiter Three", positionInCurrentRoom(myEntityId, [21.0,5.5,0.0]))
					useAbilityAtPosition(myEntityId, "Idrae Phase Two Room Limiter Three", positionInCurrentRoom(myEntityId, [21.0,36.5,0.0]))
					useAbilityAtPosition(myEntityId, "Idrae Phase Two Room Limiter Four", positionInCurrentRoom(myEntityId, [5.5,21.0,0.0]))
					useAbilityAtPosition(myEntityId, "Idrae Phase Two Room Limiter Four", positionInCurrentRoom(myEntityId, [36.5,21.0,0.0]))
					useAbilityAtPosition(myEntityId, "Idrae Get Out Of Spawn", positionInCurrentRoom(myEntityId, [42.0,35.0,0.0]))
				scriptVars["WallTimer"]=5.0
				}

				scriptVars["BombTimer"]+=delta
				if scriptVars["BombTimer"]>1.5	{
					useAbilityAtPosition(myEntityId, "Idrae Phase X Bomb", positionInCurrentRoom(myEntityId, [21.0,33.0,0.0]))
					useAbilityAtPosition(myEntityId, "Idrae Phase X Bomb", positionInCurrentRoom(myEntityId, [21.0,29.0,0.0]))
					useAbilityAtPosition(myEntityId, "Idrae Phase X Bomb", positionInCurrentRoom(myEntityId, [21.0,25.0,0.0]))
					useAbilityAtPosition(myEntityId, "Idrae Phase X Bomb", positionInCurrentRoom(myEntityId, [21.0,21.0,0.0]))
