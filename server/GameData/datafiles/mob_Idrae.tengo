					useAbilityAtPosition(myEntityId, "Idrae Phase One Side Shotguns", positionInCurrentRoom(myEntityId, [21.0,3.0,0.0]), addBoundingCenter(targetEntityId, entityPosition(targetEntityId)))
					useAbilityAtPosition(myEntityId, "Idrae Phase One Side Shotguns", positionInCurrentRoom(myEntityId, [21.0,39.0,0.0]), addBoundingCenter(targetEntityId, entityPosition(targetEntityId)))
				scriptVars["BombTimer"]=0.0
				scriptVars["BombCounter"]=0
				}



}


//Phase 3 setup
if hp < 0.62 * pthp && scriptVars["PhaseTransitionCount"] == 3  {
				log("phase 3")
				clearBulletsForEntity(myEntityId)
				scriptVars["PhaseTransitionDelay"] = 0.0
				scriptVars["PhaseTransitionCount"]+=1
