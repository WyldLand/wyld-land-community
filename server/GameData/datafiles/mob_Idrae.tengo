				scriptVars["BombCounter"] += 1
				}
				if scriptVars["BombTimer"]>3.0	&& scriptVars["BombCounter"] == 1	{
					useAbilityAtPosition(myEntityId, "Idrae Phase X Bomb", positionInCurrentRoom(myEntityId, [32.0,21.0,0.0]))
					useAbilityAtPosition(myEntityId, "Idrae Phase X Bomb", positionInCurrentRoom(myEntityId, [10.0,21.0,0.0]))
					useAbilityAtPosition(myEntityId, "Idrae Phase X Bomb", positionInCurrentRoom(myEntityId, [21.0,32.0,0.0]))
