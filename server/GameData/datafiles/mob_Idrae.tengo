					scriptVars["directionCounter"]=1
					changeAttackBehaviour(myEntityId, "Stationary")

				}
//Boss paths to the players previous position instead of current one
				if scriptVars["directionCounter"] == 1 {
					scriptVars["ChasePauseTimer"]+=delta
					if scriptVars["ChasePauseTimer"]>2.0	{
						scriptVars["direction"]=entityPosition(targetEntityId)
						pathTo(myEntityId, scriptVars["direction"])
						scriptVars["directionCounter"]=0
						scriptVars["ChasePauseTimer"]=0.0
						changeAttackBehaviour(myEntityId, "Ignore Targets")
					}

				}


				scriptVars["SubAttackTimer"]+=delta
				if scriptVars["SubAttackTimer"]>1.5 {
