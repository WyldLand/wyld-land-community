					pathTo(myEntityId, scriptVars["direction"])
					scriptVars["directionCounter"]=3
				}

				if distToPoint(myEntityId, scriptVars["direction"]) < 5.0	&&	scriptVars["directionCounter"] == 3	&& scriptVars["towersDead"] == 0 	{	
					scriptVars["direction"]=positionInCurrentRoom(myEntityId, [27.0,15.0,0.0])
					pathTo(myEntityId, scriptVars["direction"])
					scriptVars["directionCounter"]=0
				}


				if scriptVars["towerCount"] == 0 {
