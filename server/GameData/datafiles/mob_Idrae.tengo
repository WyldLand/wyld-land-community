					setCollisionLayer(scriptVars["towerTwo"], CollisionLayerMonster)
					setCollisionLayer(scriptVars["towerThree"], CollisionLayerMonster)
					setCollisionLayer(scriptVars["towerFour"], CollisionLayerMonster)
					dispelAuraOnEntity(scriptVars["towerOne"], "Invulnerability Indicator")
					dispelAuraOnEntity(scriptVars["towerTwo"], "Invulnerability Indicator")
					dispelAuraOnEntity(scriptVars["towerThree"], "Invulnerability Indicator")
					dispelAuraOnEntity(scriptVars["towerFour"], "Invulnerability Indicator")
					scriptVars["allyIDsReady"]=1
				}


				if isEntityDead(scriptVars["towerOne"]) == true && isEntityDead(scriptVars["towerTwo"]) == true && isEntityDead(scriptVars["towerThree"]) == true && isEntityDead(scriptVars["towerFour"]) == true && scriptVars["allyIDsReady"] == 1 {
					clearBulletsForEntity(myEntityId)
					clearBulletsForEntity(scriptVars["towerOne"])
					clearBulletsForEntity(scriptVars["towerTwo"])
					clearBulletsForEntity(scriptVars["towerThree"])
					clearBulletsForEntity(scriptVars["towerFour"])

					scriptVars["SubAttackTimer"]=0.0
					scriptVars["towersDead"]=1
