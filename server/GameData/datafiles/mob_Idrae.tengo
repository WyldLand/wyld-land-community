					useAbilityAtPosition(myEntityId, "Idrae Phase X Bomb", positionInCurrentRoom(myEntityId, [32.0,25.0,0.0]))
					useAbilityAtPosition(myEntityId, "Idrae Phase X Bomb", positionInCurrentRoom(myEntityId, [10.0,25.0,0.0]))
					useAbilityAtPosition(myEntityId, "Idrae Phase X Bomb", positionInCurrentRoom(myEntityId, [25.0,32.0,0.0]))
					useAbilityAtPosition(myEntityId, "Idrae Phase X Bomb", positionInCurrentRoom(myEntityId, [25.0,10.0,0.0]))
					useAbilityAtPosition(myEntityId, "Idrae Phase X Bomb", positionInCurrentRoom(myEntityId, [32.0,13.0,0.0]))
