					pathTo(myEntityId, scriptVars["direction"])
					scriptVars["directionCounter"]=2
				}

				if distToPoint(myEntityId, scriptVars["direction"]) < 5.0	&&	scriptVars["directionCounter"] == 2	&& scriptVars["towersDead"] == 0 	{
