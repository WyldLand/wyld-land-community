				scriptVars["minionCount"]=1
				}

				scriptVars["allyIDsTimer"]+=delta
				if scriptVars["allyIDsTimer"]>2.0 && scriptVars["allyIDsReady"] == 0 {
					scriptVars["allyIDs"]=getAlliesSortedByHealth(myEntityId)
					scriptVars["towerOne"]=scriptVars["allyIDs"][1]["id"]
					scriptVars["towerTwo"]=scriptVars["allyIDs"][2]["id"]
					scriptVars["towerThree"]=scriptVars["allyIDs"][3]["id"]
					scriptVars["towerFour"]=scriptVars["allyIDs"][4]["id"]
					scriptVars["allyIDsReady"]=1
				}






				

				if distToPoint(myEntityId, scriptVars["direction"]) < 5.0	&&	scriptVars["directionCounter"] == 0	{
					scriptVars["direction"]=positionInCurrentRoom(myEntityId, [30.0,30.0,0.0])
					pathTo(myEntityId, scriptVars["direction"])
					scriptVars["directionCounter"]=1
				}

				if distToPoint(myEntityId, scriptVars["direction"]) < 5.0	&&	scriptVars["directionCounter"] == 1	{ 
					scriptVars["direction"]=positionInCurrentRoom(myEntityId, [30.0,12.0,0.0])
					pathTo(myEntityId, scriptVars["direction"])
					scriptVars["directionCounter"]=2
				}

				if distToPoint(myEntityId, scriptVars["direction"]) < 5.0	&&	scriptVars["directionCounter"] == 2	{
					scriptVars["direction"]=positionInCurrentRoom(myEntityId, [12.0,12.0,0.0])
					pathTo(myEntityId, scriptVars["direction"])
					scriptVars["directionCounter"]=3
				}

				if distToPoint(myEntityId, scriptVars["direction"]) < 5.0	&&	scriptVars["directionCounter"] == 3	{	
					scriptVars["direction"]=positionInCurrentRoom(myEntityId, [12.0,30.0,0.0])
					pathTo(myEntityId, scriptVars["direction"])
					scriptVars["directionCounter"]=0
				}	

					

				

				scriptVars["MidAttackTimer"]+=delta
				if scriptVars["MidAttackTimer"]>1.0 && scriptVars["MidAttackCounter"] == 0	{
					useAbilityAtPosition(myEntityId, "Idrae Phase Three Middle Shotgun", positionInCurrentRoom(myEntityId, [21.0,21.0,0.0]), addBoundingCenter(myEntityId,  positionInCurrentRoom(myEntityId, [40.0,40.0,0.0])))
				scriptVars["MidAttackCounter"] += 1
				}
				if scriptVars["MidAttackTimer"]>2.0 && scriptVars["MidAttackCounter"] == 1	{
					useAbilityAtPosition(myEntityId, "Idrae Phase Three Middle Shotgun", positionInCurrentRoom(myEntityId, [21.0,21.0,0.0]), addBoundingCenter(myEntityId,  positionInCurrentRoom(myEntityId, [40.0,2.0,0.0])))
				scriptVars["MidAttackCounter"] += 1
				}
				if scriptVars["MidAttackTimer"]>3.0 && scriptVars["MidAttackCounter"] == 2	{
					useAbilityAtPosition(myEntityId, "Idrae Phase Three Middle Shotgun", positionInCurrentRoom(myEntityId, [21.0,21.0,0.0]), addBoundingCenter(myEntityId,  positionInCurrentRoom(myEntityId, [2.0,2.0,0.0])))
				scriptVars["MidAttackCounter"] += 1
				}
				if scriptVars["MidAttackTimer"]>4.0 && scriptVars["MidAttackCounter"] == 3	{
					useAbilityAtPosition(myEntityId, "Idrae Phase Three Middle Shotgun", positionInCurrentRoom(myEntityId, [21.0,21.0,0.0]), addBoundingCenter(myEntityId,  positionInCurrentRoom(myEntityId, [2.0,40.0,0.0])))
				scriptVars["MidAttackTimer"]=0.0
				scriptVars["MidAttackCounter"]=0
				}



				scriptVars["BossAttackTimer"]+=delta
