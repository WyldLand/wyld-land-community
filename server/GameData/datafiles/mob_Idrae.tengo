					dispelAuraOnEntity(scriptVars["towerFour"], "Invulnerability Indicator")
					changeAttackBehaviour(myEntityId, "Ignore Targets")
				scriptVars["WallTimer"]=5.0
				}
				if scriptVars["WallTimer"]>15.0	{
