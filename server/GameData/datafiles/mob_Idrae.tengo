}

//phase 5 setup

if hp < 0.32 * pthp && scriptVars["PhaseTransitionCount"] == 7  {
				log("phase 5")
				clearBulletsForEntity(myEntityId)
				scriptVars["PhaseTransitionDelay"] = 0.0
				scriptVars["PhaseTransitionCount"]+=1
				dispelAuraOnEntity(myEntityId, "Idrae Phase Four Speed")

					scriptVars["BombTimer"]=0.0
