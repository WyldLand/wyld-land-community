					scriptVars["spiralPosition2"]=15
					scriptVars["spiralDirection"]=0

				}

//Phase 6
if scriptVars["PhaseTransitionCount"] == 11 {
				scriptVars["PhaseTransitionDelay"] = 0.0

				scriptVars["RandomLineTimer"]+=delta
				if scriptVars["RandomLineTimer"]>1.5	&& scriptVars["RandomLineCounter"] == 0 {
						scriptVars["rnd"] = import("rand")
						z := scriptVars["rnd"]
						prevside := z.intn(7) + 18
						randompos := float(prevside)
					useAbilityAtPosition(myEntityId, "Idrae Phase Six Random Line", positionInCurrentRoom(myEntityId, [randompos,2.0,0.0]))
				scriptVars["RandomLineCounter"]=1
				}
				if scriptVars["RandomLineTimer"]>3.0	&& scriptVars["RandomLineCounter"] == 1 {
						scriptVars["rnd"] = import("rand")
						z := scriptVars["rnd"]
						prevside := z.intn(7) + 18
						randompos := float(prevside)
					useAbilityAtPosition(myEntityId, "Idrae Phase Six Random Line", positionInCurrentRoom(myEntityId, [randompos,40.0,0.0]))
				scriptVars["RandomLineCounter"]=0
				scriptVars["RandomLineTimer"]=0.0
				}

				scriptVars["RandomBulletTimer"]+=delta
				if scriptVars["RandomBulletTimer"]>4.0	{
					useAbilityAtPosition(myEntityId, "Idrae Phase Six Random Bullets One", positionInCurrentRoom(myEntityId, [40.0,21.0,0.0]))
					useAbilityAtPosition(myEntityId, "Idrae Phase Six Random Bullets Two", positionInCurrentRoom(myEntityId, [2.0,21.0,0.0]))
				scriptVars["RandomBulletTimer"]=0.0
				}

				scriptVars["BossAttackTimer"]+=delta
				if scriptVars["BossAttackTimer"]>1.0	{
