					addAuraToEntity(myEntityId, "Idrae Phase Four Speed", 0, myEntityId)
				}
//Phase 3
if scriptVars["PhaseTransitionCount"] == 5 {
				scriptVars["PhaseTransitionDelay"] - 0.0

				if scriptVars["minionCount"] == 0 {
					summonEntity("cultist", positionInCurrentRoom(myEntityId, [35.0,7.0,0.0]), monsterLevel(myEntityId))
					summonEntity("cultist", positionInCurrentRoom(myEntityId, [35.0,35.0,0.0]), monsterLevel(myEntityId))
