					useAbilityAtPosition(myEntityId, "Idrae Phase X Bomb", positionInCurrentRoom(myEntityId, [13.0,32.0,0.0]))
					useAbilityAtPosition(myEntityId, "Idrae Phase X Bomb", positionInCurrentRoom(myEntityId, [13.0,10.0,0.0]))
					useAbilityAtPosition(myEntityId, "Idrae Phase X Bomb", positionInCurrentRoom(myEntityId, [32.0,29.0,0.0]))
