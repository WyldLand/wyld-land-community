					useAbilityAtPosition(myEntityId, "Idrae Phase X Bomb", positionInCurrentRoom(myEntityId, [25.0,21.0,0.0]))
					useAbilityAtPosition(myEntityId, "Idrae Phase X Bomb", positionInCurrentRoom(myEntityId, [17.0,21.0,0.0]))
					useAbilityAtPosition(myEntityId, "Idrae Phase X Bomb", positionInCurrentRoom(myEntityId, [13.0,21.0,0.0]))
					useAbilityAtPosition(myEntityId, "Idrae Phase X Bomb", positionInCurrentRoom(myEntityId, [9.0,21.0,0.0]))
				scriptVars["BombTimer"]=0.0
				}



}

//phase 4 setup

if hp < 0.54 * pthp && scriptVars["PhaseTransitionCount"] == 5  {
				log("phase 4")
				clearBulletsForEntity(myEntityId)
				scriptVars["PhaseTransitionDelay"] = 0.0
				scriptVars["PhaseTransitionCount"]+=1

