---aura_Cultist Hp---
Type :: Buff
Duration :: -1
Max stacks :: 1 
Time Per Tick :: 1.0
Definitions :: [[AuraAffectStat/Cultist Hp]]

---auraaffectstat_Cultist Hp---
Stat :: Vitality
Boost :: 30.0

---aura_Invulnerability Indicator---
Type :: Buff
Duration :: -1
Max Stacks :: 1 
Time Per Tick :: 1.0
Icon :: statusicons_3




---script_cultist_Monster---

if !isDead	&&	targetEntityId!=0	{
	if is_undefined(scriptVars["attackTimer"]){
		setCollisionLayer(myEntityId, CollisionLayerDynamic)
		addAuraToEntity(myEntityId, "Invulnerability Indicator", 0, myEntityId)
		addAuraToEntity(myEntityId, "Cultist Hp", 0, myEntityId)
		addHitPoints(myEntityId, 500000)
		scriptVars["attackTimer"]=0.0
		scriptVars["radialTimer"]=0.0
		scriptVars["directionCounter"]=0
		scriptVars["PhaseCount"]=3
		scriptVars["IDtimer"]=0.0
	}

		scriptVars["IDtimer"]+=delta
		if scriptVars["IDtimer"]>2.0	&& scriptVars["IDtimer"]<3.0 {
		scriptVars["allyIDs"]=getAlliesSortedByHealth(myEntityId)
		scriptVars["Boss"]=scriptVars["allyIDs"][0]["id"]
		scriptVars["IDtimer"]=10.0
		}
		if scriptVars["IDtimer"]>3.0 {
			hp := getPoints(scriptVars["Boss"], "hp", "current")
			pthp := getPoints(scriptVars["Boss"], "hp", "max")





		if distToPoint(myEntityId, positionInCurrentRoom(myEntityId, [35.0,7.0,0.0])) < 1.0 && is_undefined(scriptVars["position"]) {
			scriptVars["position"]=1
			scriptVars["direction"]=positionInCurrentRoom(myEntityId, [35.0,7.0,0.0])
		}
		if distToPoint(myEntityId, positionInCurrentRoom(myEntityId, [35.0,35.0,0.0])) < 1.0 && is_undefined(scriptVars["position"]) {
			scriptVars["position"]=2
			scriptVars["direction"]=positionInCurrentRoom(myEntityId, [35.0,35.0,0.0])
		}
		if distToPoint(myEntityId, positionInCurrentRoom(myEntityId, [7.0,35.0,0.0])) < 1.0 && is_undefined(scriptVars["position"]) {
			scriptVars["position"]=3
			scriptVars["direction"]=positionInCurrentRoom(myEntityId, [7.0,35.0,0.0])
		}
		if distToPoint(myEntityId, positionInCurrentRoom(myEntityId, [7.0,7.0,0.0])) < 1.0 && is_undefined(scriptVars["position"]) {
			scriptVars["position"]=4
			scriptVars["direction"]=positionInCurrentRoom(myEntityId, [7.0,7.0,0.0])
		}


//Phase 3
		if hp < 0.62 * pthp	&& scriptVars["PhaseCount"] == 3 {
			if scriptVars["position"] == 1 {


				if distToPoint(myEntityId, scriptVars["direction"]) < 5.0	&&	scriptVars["directionCounter"] == 0	{
					scriptVars["direction"]=positionInCurrentRoom(myEntityId, [35.0,35.0,0.0])
					pathTo(myEntityId, scriptVars["direction"])
					scriptVars["directionCounter"]=1
					useAbilityAtPosition(myEntityId, "Cultist Anticorner", entityPosition(myEntityId), addBoundingCenter(myEntityId,  positionInCurrentRoom(myEntityId, [35.0,7.0,0.0])))
				}

				if distToPoint(myEntityId, scriptVars["direction"]) < 5.0	&&	scriptVars["directionCounter"] == 1	{ 
					scriptVars["direction"]=positionInCurrentRoom(myEntityId, [7.0,35.0,0.0])
					pathTo(myEntityId, scriptVars["direction"])
					scriptVars["directionCounter"]=2
					useAbilityAtPosition(myEntityId, "Cultist Anticorner", entityPosition(myEntityId), addBoundingCenter(myEntityId,  positionInCurrentRoom(myEntityId, [35.0,35.0,0.0])))
				}

				if distToPoint(myEntityId, scriptVars["direction"]) < 5.0	&&	scriptVars["directionCounter"] == 2	{
					scriptVars["direction"]=positionInCurrentRoom(myEntityId, [7.0,7.0,0.0])
					pathTo(myEntityId, scriptVars["direction"])
					scriptVars["directionCounter"]=3
					useAbilityAtPosition(myEntityId, "Cultist Anticorner", entityPosition(myEntityId), addBoundingCenter(myEntityId,  positionInCurrentRoom(myEntityId, [7.0,35.0,0.0])))
				}

				if distToPoint(myEntityId, scriptVars["direction"]) < 5.0	&&	scriptVars["directionCounter"] == 3	{	

					scriptVars["direction"]=positionInCurrentRoom(myEntityId, [35.0,7.0,0.0])
					pathTo(myEntityId, scriptVars["direction"])
					scriptVars["directionCounter"]=0
