					summonEntity("blastertwo", positionInCurrentRoom(myEntityId, [36.0,36.0,0.0]), monsterLevel(myEntityId))
					summonEntity("blastertwo", positionInCurrentRoom(myEntityId, [6.0,6.0,0.0]), monsterLevel(myEntityId))
					summonEntity("blastertwo", positionInCurrentRoom(myEntityId, [6.0,36.0,0.0]), monsterLevel(myEntityId))
				scriptVars["towerCount"]=1
				}

				scriptVars["allyIDsTimer"]+=delta
				if scriptVars["allyIDsTimer"]>2.5 && scriptVars["allyIDsReady"] == 0 {
