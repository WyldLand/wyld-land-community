					scriptVars["allyIDsTimer"]=0.0
					scriptVars["allyIDsReady"]=0
					scriptVars["towersDead"]=0
				}

//Phase 2

if scriptVars["PhaseTransitionCount"] == 3 {
				scriptVars["PhaseTransitionDelay"] = 0.0

				slowPlayer()


				if distToPoint(myEntityId, scriptVars["direction"]) < 5.0	&&	scriptVars["directionCounter"] == 0	&& scriptVars["towersDead"] == 0 	{
					scriptVars["direction"]=positionInCurrentRoom(myEntityId, [27.0,27.0,0.0])
					pathTo(myEntityId, scriptVars["direction"])
					scriptVars["directionCounter"]=1
				}

				if distToPoint(myEntityId, scriptVars["direction"]) < 5.0	&&	scriptVars["directionCounter"] == 1	&& scriptVars["towersDead"] == 0 	{ 
