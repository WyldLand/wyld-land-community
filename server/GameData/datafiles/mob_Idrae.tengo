					scriptVars["placeholderEntityPos2"] = scriptVars["placeholderEntityPos"][1] 
					useAbilityAtPosition(myEntityId, "Idrae Phase Six Shotgun", [scriptVars["placeholderEntityPos1"] - 3 ,scriptVars["placeholderEntityPos2"] - 3 ,0.0])
					useAbilityAtPosition(myEntityId, "Idrae Phase Six Shotgun", [scriptVars["placeholderEntityPos1"] + 3 ,scriptVars["placeholderEntityPos2"] - 3 ,0.0])
					useAbilityAtPosition(myEntityId, "Idrae Phase Six Shotgun", [scriptVars["placeholderEntityPos1"] - 3 ,scriptVars["placeholderEntityPos2"] + 3 ,0.0])
					useAbilityAtPosition(myEntityId, "Idrae Phase Six Shotgun", [scriptVars["placeholderEntityPos1"] + 3 ,scriptVars["placeholderEntityPos2"] + 3 ,0.0])
				scriptVars["SubAttackTimer"]=0.0
				}


				scriptVars["WallTimer"]+=delta
				if scriptVars["WallTimer"]<1.0	{
					useAbilityAtPosition(myEntityId, "Idrae Phase Six Room Limiter Warning", positionInCurrentRoom(myEntityId, [21.0,4.5,0.0]))
					useAbilityAtPosition(myEntityId, "Idrae Phase Six Room Limiter Warning", positionInCurrentRoom(myEntityId, [21.0,37.5,0.0]))
					useAbilityAtPosition(myEntityId, "Idrae Phase Six Room Limiter Two Warning", positionInCurrentRoom(myEntityId, [9.5,21.0,0.0]))
					useAbilityAtPosition(myEntityId, "Idrae Phase Six Room Limiter Two Warning", positionInCurrentRoom(myEntityId, [32.5,21.0,0.0]))
					changeAttackBehaviour(myEntityId, "Ignore Targets")
					setCollisionLayer(myEntityId, CollisionLayerMonster)
					dispelAuraOnEntity(myEntityId, "Invulnerability Indicator")
					pathTo(myEntityId, positionInCurrentRoom(myEntityId, [21.0,7.0,0.0]))
				scriptVars["WallTimer"]=5.0
				}
				if scriptVars["WallTimer"]>15.0	{
					useAbilityAtPosition(myEntityId, "Idrae Phase Six Room Limiter", positionInCurrentRoom(myEntityId, [21.0,4.5,0.0]))
					useAbilityAtPosition(myEntityId, "Idrae Phase Six Room Limiter", positionInCurrentRoom(myEntityId, [21.0,37.5,0.0]))
					useAbilityAtPosition(myEntityId, "Idrae Phase Six Room Limiter Two", positionInCurrentRoom(myEntityId, [9.5,21.0,0.0]))
					useAbilityAtPosition(myEntityId, "Idrae Phase Six Room Limiter Two", positionInCurrentRoom(myEntityId, [32.5,21.0,0.0]))
					useAbilityAtPosition(myEntityId, "Idrae Get Out Of Spawn", positionInCurrentRoom(myEntityId, [42.0,35.0,0.0]))
				scriptVars["WallTimer"]=5.0
				}

//explosion changes directions once it has hit a certain point
					if scriptVars["explosionPosition"] == 25 && scriptVars["explosionDirection"] == 1 {
						pathTo(myEntityId, positionInCurrentRoom(myEntityId, [21.0,7.0,0.0]))
						scriptVars["explosionPosition"]=37
						scriptVars["explosionDirection"]=0
						scriptVars["BombTimer"]=0.0
					}
					if scriptVars["explosionPosition"] == 17 && scriptVars["explosionDirection"] == 0 {
						pathTo(myEntityId, positionInCurrentRoom(myEntityId, [21.0,35.0,0.0]))
						scriptVars["explosionPosition"]=5
						scriptVars["explosionDirection"]=1
						scriptVars["BombTimer"]=0.0
					}

				scriptVars["BombTimer"]+=delta
				if scriptVars["BombTimer"]>5.5 {
					if scriptVars["explosionDirection"] == 0 {
						scriptVars["explosionPosition"] -= 4
						explosionpos := float(scriptVars["explosionPosition"])
						useAbilityAtPosition(myEntityId, "Idrae Phase Six Long Bomb", positionInCurrentRoom(myEntityId, [21.0,explosionpos,0.0]))
						scriptVars["BombTimer"]=3.5
					}
					if scriptVars["explosionDirection"] == 1 {
						scriptVars["explosionPosition"] += 4
						explosionpos := float(scriptVars["explosionPosition"])
						useAbilityAtPosition(myEntityId, "Idrae Phase Six Long Bomb", positionInCurrentRoom(myEntityId, [21.0,explosionpos,0.0]))
						scriptVars["BombTimer"]=3.5
					}


				}


		}

if scriptVars["PhaseTransitionCount"] == 13 {
				Sicken ()

				if distToPoint(myEntityId, scriptVars["direction"]) < 2.0	&&	scriptVars["directionCounter"] == 0	{
					scriptVars["direction"]=positionInCurrentRoom(myEntityId, [27.0,15.0,0.0])
					pathTo(myEntityId, scriptVars["direction"])
					scriptVars["directionCounter"]=1
				}

				if distToPoint(myEntityId, scriptVars["direction"]) < 2.0	&&	scriptVars["directionCounter"] == 1	{ 
					scriptVars["direction"]=positionInCurrentRoom(myEntityId, [27.0,27.0,0.0])
					pathTo(myEntityId, scriptVars["direction"])
					scriptVars["directionCounter"]=2
				}

				if distToPoint(myEntityId, scriptVars["direction"]) < 2.0	&&	scriptVars["directionCounter"] == 2	{
					scriptVars["direction"]=positionInCurrentRoom(myEntityId, [15.0,27.0,0.0])
					pathTo(myEntityId, scriptVars["direction"])
					scriptVars["directionCounter"]=3
				}

				if distToPoint(myEntityId, scriptVars["direction"]) < 2.0	&&	scriptVars["directionCounter"] == 3	{	
					scriptVars["direction"]=positionInCurrentRoom(myEntityId, [15.0,15.0,0.0])
					pathTo(myEntityId, scriptVars["direction"])
					scriptVars["directionCounter"]=0
				}
	
				scriptVars["IdraeFinalPhaseProgressionTimer"]+=delta
				if scriptVars["IdraeFinalPhaseProgressionTimer"] < 60.0 && scriptVars["IdraeFinalPhaseProgression"] == 0 {


					scriptVars["SubAttackTimerTwo"]+=delta
					if scriptVars["SubAttackTimerTwo"]>23.0	&& scriptVars["SubAttackCounterTwo"] == 0 {
						useAbilityAtPosition(myEntityId, "Idrae Phase Final Boss Stationary Shotgun", entityPosition(myEntityId), addBoundingCenter(myEntityId,  positionInCurrentRoom(myEntityId, [21.0,21.0,0.0])))
					scriptVars["SubAttackCounterTwo"]=1
					}
					if scriptVars["SubAttackTimerTwo"]>30.0	&& scriptVars["SubAttackCounterTwo"] == 1 {
						useAbilityAtPosition(myEntityId, "Idrae Phase Final Boss Stationary Shotgun", entityPosition(myEntityId), addBoundingCenter(myEntityId,  positionInCurrentRoom(myEntityId, [21.0,21.0,0.0])))
	
					scriptVars["SubAttackCounterTwo"]=0
					scriptVars["SubAttackTimerTwo"]=0.0
					}
	
					scriptVars["BossAttackTimer"]+=delta
					if scriptVars["BossAttackTimer"]>1.0	{
						useAbilityAtPosition(myEntityId, "Idrae Phase Final Boss Shotgun", entityPosition(myEntityId), addBoundingCenter(targetEntityId, entityPosition(targetEntityId)))
					scriptVars["BossAttackTimer"]=0.0
					}
	
					scriptVars["SubAttackTimer"]+=delta
					if scriptVars["SubAttackTimer"]>7.5	{
						scriptVars["rnd"] = import("rand")
						z := scriptVars["rnd"]
						prevside := z.intn(4)
						scriptVars["linePos"] = prevside
	
						if scriptVars["linePos"] == 0 {
							useAbilityAtPosition(myEntityId, "Idrae Phase Final Line", positionInCurrentRoom(myEntityId, [24.0,15.0,0.0]), addBoundingCenter(myEntityId, positionInCurrentRoom(myEntityId, [24.0,21.0,0.0])))
							useAbilityAtPosition(myEntityId, "Idrae Phase Final Line", positionInCurrentRoom(myEntityId, [22.0,15.0,0.0]), addBoundingCenter(myEntityId, positionInCurrentRoom(myEntityId, [22.0,21.0,0.0])))
							useAbilityAtPosition(myEntityId, "Idrae Phase Final Line", positionInCurrentRoom(myEntityId, [20.0,15.0,0.0]), addBoundingCenter(myEntityId, positionInCurrentRoom(myEntityId, [20.0,21.0,0.0])))
							useAbilityAtPosition(myEntityId, "Idrae Phase Final Line", positionInCurrentRoom(myEntityId, [18.0,15.0,0.0]), addBoundingCenter(myEntityId, positionInCurrentRoom(myEntityId, [18.0,21.0,0.0])))
						}
						if scriptVars["linePos"] == 1 {
							useAbilityAtPosition(myEntityId, "Idrae Phase Final Line", positionInCurrentRoom(myEntityId, [24.0,27.0,0.0]), addBoundingCenter(myEntityId, positionInCurrentRoom(myEntityId, [24.0,21.0,0.0])))
							useAbilityAtPosition(myEntityId, "Idrae Phase Final Line", positionInCurrentRoom(myEntityId, [22.0,27.0,0.0]), addBoundingCenter(myEntityId, positionInCurrentRoom(myEntityId, [22.0,21.0,0.0])))
							useAbilityAtPosition(myEntityId, "Idrae Phase Final Line", positionInCurrentRoom(myEntityId, [20.0,27.0,0.0]), addBoundingCenter(myEntityId, positionInCurrentRoom(myEntityId, [20.0,21.0,0.0])))
							useAbilityAtPosition(myEntityId, "Idrae Phase Final Line", positionInCurrentRoom(myEntityId, [18.0,27.0,0.0]), addBoundingCenter(myEntityId, positionInCurrentRoom(myEntityId, [18.0,21.0,0.0])))
						}
						if scriptVars["linePos"] == 2 {
							useAbilityAtPosition(myEntityId, "Idrae Phase Final Bullet wall", positionInCurrentRoom(myEntityId, [15.0,21.0,0.0]))
						}
						if scriptVars["linePos"] == 3 {
							useAbilityAtPosition(myEntityId, "Idrae Phase Final Bullet wall", positionInCurrentRoom(myEntityId, [27.0,21.0,0.0]))
						}
					scriptVars["SubAttackTimer"]=0.0
					}

						if scriptVars["spiralPosition"] == 17 && scriptVars["spiralDirection"] == 1 {
							scriptVars["spiralPosition"]=27
							scriptVars["spiralPosition2"]=15
							scriptVars["spiralDirection"]=0
						}
						if scriptVars["spiralPosition"] == 17 && scriptVars["spiralDirection"] == 0 {
							scriptVars["spiralPosition"]=27
							scriptVars["spiralPosition2"]=15
							scriptVars["spiralDirection"]=1
						}
					scriptVars["SpiralTimer"]+=delta
					if scriptVars["SpiralTimer"]>1.5 {
						if scriptVars["spiralDirection"] == 0 {
							scriptVars["spiralPosition"] -= 2
							posy := float(scriptVars["spiralPosition"])
							useAbilityAtPosition(myEntityId, "Idrae Phase Final Spiral", positionInCurrentRoom(myEntityId, [27.0,posy,0.0]), addBoundingCenter(myEntityId, positionInCurrentRoom(myEntityId, [21.0,21.0,0.0])))
							scriptVars["spiralPosition2"] += 2
							posytwo := float(scriptVars["spiralPosition2"])
							useAbilityAtPosition(myEntityId, "Idrae Phase Final Spiral", positionInCurrentRoom(myEntityId, [15.0,posytwo,0.0]), addBoundingCenter(myEntityId, positionInCurrentRoom(myEntityId, [21.0,21.0,0.0])))
							scriptVars["SpiralTimer"]=0.0
						}
						if scriptVars["spiralDirection"] == 1 {
							scriptVars["spiralPosition"] -= 2
							posx := float(scriptVars["spiralPosition"])
							useAbilityAtPosition(myEntityId, "Idrae Phase Final Spiral", positionInCurrentRoom(myEntityId, [posx,15.0,0.0]), addBoundingCenter(myEntityId, positionInCurrentRoom(myEntityId, [21.0,21.0,0.0])))
							scriptVars["spiralPosition2"] += 2
							posxtwo := float(scriptVars["spiralPosition2"])
							useAbilityAtPosition(myEntityId, "Idrae Phase Final Spiral", positionInCurrentRoom(myEntityId, [posxtwo,27.0,0.0]), addBoundingCenter(myEntityId, positionInCurrentRoom(myEntityId, [21.0,21.0,0.0])))
							scriptVars["SpiralTimer"]=0.0
						}
	
	
					}
	


				}
//Phase Transition

				if scriptVars["IdraeFinalPhaseProgressionTimer"] > 60.0 && scriptVars["IdraeFinalPhaseProgression"] == 0 {
					clearBulletsForEntity(myEntityId)
					useAbilityAtPosition(myEntityId, "Idrae Phase Final Room Limiter", positionInCurrentRoom(myEntityId, [21.0,9.5,0.0]))
					useAbilityAtPosition(myEntityId, "Idrae Phase Final Room Limiter", positionInCurrentRoom(myEntityId, [21.0,32.5,0.0]))
					useAbilityAtPosition(myEntityId, "Idrae Phase Final Room Limiter Two", positionInCurrentRoom(myEntityId, [9.5,21.0,0.0]))
					useAbilityAtPosition(myEntityId, "Idrae Phase Final Room Limiter Two", positionInCurrentRoom(myEntityId, [32.5,21.0,0.0]))
					scriptVars["SubAttackTimer"]=0.0
					scriptVars["IdraeFinalPhaseProgression"]=1
					scriptVars["IdraeFinalPhaseProgressionTimer"]=0.0
					scriptVars["SpiralTimer"]=0.0
					scriptVars["BossAttackTimer"]=0.0
					scriptVars["spiralPosition"]=29
					scriptVars["spiralPosition2"]=13
				}

//Part Two of the phase




				if scriptVars["IdraeFinalPhaseProgressionTimer"] < 60.0 && scriptVars["IdraeFinalPhaseProgression"] == 1 {

					scriptVars["BossAttackTimer"]+=delta
					if scriptVars["BossAttackTimer"]>3.0	{
						useAbilityAtPosition(myEntityId, "Idrae Phase Final Boomerang", entityPosition(myEntityId), addBoundingCenter(targetEntityId, entityPosition(targetEntityId)))
					scriptVars["BossAttackTimer"]=0.0
					}

					scriptVars["SubAttackTimer"]+=delta
					if scriptVars["SubAttackTimer"]>2.0	{
					useAbilityAtPosition(myEntityId, "Idrae Phase Final Bullet Wall Two", positionInCurrentRoom(myEntityId, [17.0,27.0,0.0]))
					useAbilityAtPosition(myEntityId, "Idrae Phase Final Bullet Wall Three", positionInCurrentRoom(myEntityId, [27.0,25.0,0.0]))
					scriptVars["SubAttackTimer"]=0.0
					}

						if scriptVars["spiralPosition"] == 17 && scriptVars["spiralDirection"] == 1 {
							scriptVars["spiralPosition"]=29
							scriptVars["spiralPosition2"]=13
							scriptVars["spiralDirection"]=0
						}
						if scriptVars["spiralPosition"] == 17 && scriptVars["spiralDirection"] == 0 {
							scriptVars["spiralPosition"]=29
							scriptVars["spiralPosition2"]=13
							scriptVars["spiralDirection"]=1
						}
					scriptVars["SpiralTimer"]+=delta
					if scriptVars["SpiralTimer"]>1.5 {
						if scriptVars["spiralDirection"] == 0 {
							scriptVars["spiralPosition"] -= 4
							posy := float(scriptVars["spiralPosition"])
							useAbilityAtPosition(myEntityId, "Idrae Phase Final Spiral Two", positionInCurrentRoom(myEntityId, [27.0,posy,0.0]), addBoundingCenter(myEntityId, positionInCurrentRoom(myEntityId, [21.0,21.0,0.0])))
							scriptVars["spiralPosition2"] += 4
							posytwo := float(scriptVars["spiralPosition2"])
							useAbilityAtPosition(myEntityId, "Idrae Phase Final Spiral Two", positionInCurrentRoom(myEntityId, [15.0,posytwo,0.0]), addBoundingCenter(myEntityId, positionInCurrentRoom(myEntityId, [21.0,21.0,0.0])))
							scriptVars["SpiralTimer"]=0.0
						}
						if scriptVars["spiralDirection"] == 1 {
							scriptVars["spiralPosition"] -= 4
							posx := float(scriptVars["spiralPosition"])
							useAbilityAtPosition(myEntityId, "Idrae Phase Final Spiral Two", positionInCurrentRoom(myEntityId, [posx,15.0,0.0]), addBoundingCenter(myEntityId, positionInCurrentRoom(myEntityId, [21.0,21.0,0.0])))
							scriptVars["spiralPosition2"] += 4
							posxtwo := float(scriptVars["spiralPosition2"])
							useAbilityAtPosition(myEntityId, "Idrae Phase Final Spiral Two", positionInCurrentRoom(myEntityId, [posxtwo,27.0,0.0]), addBoundingCenter(myEntityId, positionInCurrentRoom(myEntityId, [21.0,21.0,0.0])))
							scriptVars["SpiralTimer"]=0.0
						}
					}


				}


				scriptVars["WallTimer"]+=delta
				if scriptVars["WallTimer"]<1.0	{
					useAbilityAtPosition(myEntityId, "Idrae Phase Final Room Limiter Warning", positionInCurrentRoom(myEntityId, [21.0,9.5,0.0]))
					useAbilityAtPosition(myEntityId, "Idrae Phase Final Room Limiter Warning", positionInCurrentRoom(myEntityId, [21.0,32.5,0.0]))
					useAbilityAtPosition(myEntityId, "Idrae Phase Final Room Limiter Two Warning", positionInCurrentRoom(myEntityId, [9.5,21.0,0.0]))
					useAbilityAtPosition(myEntityId, "Idrae Phase Final Room Limiter Two Warning", positionInCurrentRoom(myEntityId, [32.5,21.0,0.0]))
					changeAttackBehaviour(myEntityId, "Ignore Targets")
				scriptVars["WallTimer"]=5.0
				}
				if scriptVars["WallTimer"]>15.0	{
					useAbilityAtPosition(myEntityId, "Idrae Phase Final Room Limiter", positionInCurrentRoom(myEntityId, [21.0,9.5,0.0]))
					useAbilityAtPosition(myEntityId, "Idrae Phase Final Room Limiter", positionInCurrentRoom(myEntityId, [21.0,32.5,0.0]))
					useAbilityAtPosition(myEntityId, "Idrae Phase Final Room Limiter Two", positionInCurrentRoom(myEntityId, [9.5,21.0,0.0]))
					useAbilityAtPosition(myEntityId, "Idrae Phase Final Room Limiter Two", positionInCurrentRoom(myEntityId, [32.5,21.0,0.0]))
					useAbilityAtPosition(myEntityId, "Idrae Get Out Of Spawn", positionInCurrentRoom(myEntityId, [42.0,35.0,0.0]))
				scriptVars["WallTimer"]=5.0
				}


				if scriptVars["IdraeFinalPhaseProgressionTimer"] > 60.0 && scriptVars["IdraeFinalPhaseProgression"] == 1 {

					scriptVars["direction"]=positionInCurrentRoom(myEntityId, [21.0,21.0,0.0])
					pathTo(myEntityId, scriptVars["direction"])
					addAuraToEntity(myEntityId, "Idrae Death Speed", 0, myEntityId)

				
					if distToPoint(myEntityId, scriptVars["direction"]) < 1.0 && scriptVars["IdraeFinalPhaseProgressionTimer"] > 70.0 {
						killEntity(myEntityId)
						unSicken ()
					}


				}

		}
}



---mob_BlasterTwo---
Prefab :: blastertwo
Range Behavior :: Stationary
Bounding Box :: 0.0 0.3 1.0 1.0
Type :: Elite

---ability_Invincibility Tower Attack---
Bullet Definition :: [[invulntowerattack]]


---bulletdef_invulntowerattack---
sprite Custom10
color 6
radial bullets:12 speed:1.5 directionType:relative
	lifetime 150
wait 20
radial bullets:12 speed:1.5 directionType:relative angle:15
	lifetime 150

---aura_Invuln Tower Hp---
Type :: Buff
Duration :: -1
Max stacks :: 1 
Time Per Tick :: 1.0
Definitions :: [[AuraAffectStat/Invuln Tower Hp]]

---auraaffectstat_Invuln Tower Hp---
Stat :: Vitality
Boost :: 25.0


---aura_Invulnerability Indicator---
Type :: Buff
Duration :: -1
Max Stacks :: 1 
Time Per Tick :: 1.0
Icon :: statusicons_3



---script_blastertwo_Monster---

if !isDead&&targetEntityId!=0 {
	if is_undefined(scriptVars["attackTimer"]){
		addAuraToEntity(myEntityId, "Invuln Tower Hp", 0, myEntityId)
		addAuraToEntity(myEntityId, "Invulnerability Indicator", 0, myEntityId)
		setCollisionLayer(myEntityId, CollisionLayerDynamic)
		addHitPoints(myEntityId, 500000)
		scriptVars["attackTimer"]=0.0
	}
				scriptVars["attackTimer"]+=delta
				if scriptVars["attackTimer"]>2.5	{
				useAbilityAtPosition(myEntityId, "Invincibility Tower Attack", entityPosition(myEntityId), addBoundingCenter(targetEntityId, entityPosition(targetEntityId)))
				scriptVars["attackTimer"]=0.0
				}
}






