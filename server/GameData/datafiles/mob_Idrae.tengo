					useAbilityAtPosition(myEntityId, "Idrae Phase Two Top Shotgun", positionInCurrentRoom(myEntityId, [21.0,3.0,0.0]), addBoundingCenter(targetEntityId, entityPosition(targetEntityId)))
					useAbilityAtPosition(myEntityId, "Idrae Phase Two Bottom Shotgun", positionInCurrentRoom(myEntityId, [21.0,39.0,0.0]), addBoundingCenter(targetEntityId, entityPosition(targetEntityId)))
				scriptVars["SubAttackTimer"]=0.0
				}

				if scriptVars["SubAttackTimer"]>2.0	&& scriptVars["towersDead"] == 1 {
					useAbilityAtPosition(myEntityId, "Idrae Phase Two Post Tower Shotgun", positionInCurrentRoom(myEntityId, [35.0,35.0,0.0]), addBoundingCenter(myEntityId,  positionInCurrentRoom(myEntityId, [21.0,21.0,0.0])))
					useAbilityAtPosition(myEntityId, "Idrae Phase Two Post Tower Shotgun", positionInCurrentRoom(myEntityId, [7.0,7.0,0.0]), addBoundingCenter(myEntityId,  positionInCurrentRoom(myEntityId, [21.0,21.0,0.0])))
					useAbilityAtPosition(myEntityId, "Idrae Phase Two Post Tower Shotgun", positionInCurrentRoom(myEntityId, [7.0,35.0,0.0]), addBoundingCenter(myEntityId,  positionInCurrentRoom(myEntityId, [21.0,21.0,0.0])))
					useAbilityAtPosition(myEntityId, "Idrae Phase Two Post Tower Shotgun", positionInCurrentRoom(myEntityId, [35.0,7.0,0.0]), addBoundingCenter(myEntityId,  positionInCurrentRoom(myEntityId, [21.0,21.0,0.0])))
				scriptVars["SubAttackTimer"]=0.0
				}

				scriptVars["WallTimer"]+=delta
				if scriptVars["WallTimer"]<1.0	{
