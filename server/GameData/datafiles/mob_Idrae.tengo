---layout_layout2---

---script_idrae_Monster---

slowPlayer := func() {
	currentNearby := getNearbyEntities(myEntityId)
	for i := 0; i < len(currentNearby); i++ {
		if isEnemyOfEntity(myEntityId, currentNearby[i].id) {
			addAuraToEntity(myEntityId, "Idrae Phase X Speed Cap", 0, currentNearby[i].id)
		}
	}
}


unSlowPlayer := func() {
	currentNearby := getNearbyEntities(myEntityId)
	for i := 0; i < len(currentNearby); i++ {
		if isEnemyOfEntity(myEntityId, currentNearby[i].id) {
			dispelAuraOnEntity(currentNearby[i].id, "Idrae Phase X Speed Cap")
		}
	}
}

Sicken := func() {
	currentNearby := getNearbyEntities(myEntityId)
	for i := 0; i < len(currentNearby); i++ {
		if isEnemyOfEntity(myEntityId, currentNearby[i].id) {
			addAuraToEntity(myEntityId, "Idrae Phase Final Rec Cap", 0, currentNearby[i].id)
			addAuraToEntity(myEntityId, "Sicken", 0, currentNearby[i].id)
		}
	}
}

unSicken := func() {
	currentNearby := getNearbyEntities(myEntityId)
	for i := 0; i < len(currentNearby); i++ {
		if isEnemyOfEntity(myEntityId, currentNearby[i].id) {
			dispelAuraOnEntity(currentNearby[i].id, "Idrae Phase Final Rec Cap")
			dispelAuraOnEntity(currentNearby[i].id, "Sicken")
		}
	}
}

if !isDead && targetEntityId != 0 {


//hp
hp := getPoints(myEntityId, "hp", "current")
pthp := getPoints(myEntityId, "hp", "max")
//wait
if scriptVars["PhaseTransitionCount"] == 2 || scriptVars["PhaseTransitionCount"] == 4 || scriptVars["PhaseTransitionCount"] == 6 || scriptVars["PhaseTransitionCount"] == 8 || scriptVars["PhaseTransitionCount"] == 10 || scriptVars["PhaseTransitionCount"] == 12 {
	scriptVars["PhaseTransitionDelay"] += delta
	changeAttackBehaviour(myEntityId, "Stationary")
	addAuraToEntity(myEntityId, "Invulnerability Indicator", 0, myEntityId)
	setCollisionLayer(myEntityId, CollisionLayerDynamic)
	if scriptVars["PhaseTransitionDelay"] > 5.0	{
		scriptVars["PhaseTransitionCount"] += 1
	}
}

				if is_undefined(scriptVars["WallTimer"]){
					setPosition(myEntityId, positionInCurrentRoom(myEntityId, [21.0,21.0,0.0]))
					addAuraToEntity(myEntityId, "Idrae Max Hp", 0, myEntityId)
					addHitPoints(myEntityId, 500000000)
					scriptVars["BombTimer"]=0.0
					scriptVars["BombCounter"]=0
					scriptVars["SubAttackTimer"]=0.0
					scriptVars["BossAttackTimer"]=0.0
					scriptVars["WallTimer"]=0.0

//Phase Transition stuff
					scriptVars["PhaseTransitionCount"] = 1
					scriptVars["PhaseTransitionDelay"]=0.0
				}

	




//phase 2 setup

if hp < 0.82 * pthp && scriptVars["PhaseTransitionCount"] == 1  {
				log("phase 2")
				clearBulletsForEntity(myEntityId)
				scriptVars["PhaseTransitionDelay"] = 0.0
				scriptVars["PhaseTransitionCount"]+=1
					setCollisionLayer(myEntityId, CollisionLayerDynamic)
					scriptVars["BombTimer"]=0.0
					scriptVars["MidAttackTimer"]=0.0
					scriptVars["MidAttackTwoTimer"]=4.0
					scriptVars["BossAttackTimer"]=4.0
					scriptVars["SubAttackTimer"]=0.0
					scriptVars["WallTimer"]=0.0
//Id stuff
					scriptVars["towerCount"]=0
					scriptVars["allyIDsTimer"]=0.0
					scriptVars["allyIDsReady"]=0
					scriptVars["towersDead"]=0
//Pathing stuff
					scriptVars["directionCounter"]=0
					scriptVars["direction"]=positionInCurrentRoom(myEntityId, [27.0,15.0,0.0])
					pathTo(myEntityId, scriptVars["direction"])
					setPosition(myEntityId, positionInCurrentRoom(myEntityId, [21.0,21.0,0.0]))
//Auras
				addAuraToEntity(myEntityId, "Idrae Phase Two Speed Buff", 0, myEntityId)
				addAuraToEntity(myEntityId, "Invulnerability Indicator", 0, myEntityId)
				}

//Phase 1

if scriptVars["PhaseTransitionCount"] == 1 {
				scriptVars["PhaseTransitionDelay"] = 0.0

				scriptVars["SubAttackTimer"]+=delta
				if scriptVars["SubAttackTimer"]>2.0	{
				useAbilityAtPosition(myEntityId, "Idrae Phase One Bullet Wall One", positionInCurrentRoom(myEntityId, [3.0,39.0,0.0]))
				useAbilityAtPosition(myEntityId, "Idrae Phase One Bullet Wall Two", positionInCurrentRoom(myEntityId, [39.0,39.0,0.0]))
				scriptVars["SubAttackTimer"]=0.0
				}

				scriptVars["BossAttackTimer"]+=delta
				if scriptVars["BossAttackTimer"]>5.0	{
				useAbilityAtPosition(myEntityId, "Idrae Phase One Boss Shotgun", positionInCurrentRoom(myEntityId, [21.0,21.0,0.0]))
				scriptVars["BossAttackTimer"]=0.0
				}

				scriptVars["WallTimer"]+=delta
				if scriptVars["WallTimer"]<1.0	{
				useAbilityAtPosition(myEntityId, "Idrae Phase One Room Limiter Warning", positionInCurrentRoom(myEntityId, [21.0,3.0,0.0]))
				useAbilityAtPosition(myEntityId, "Idrae Phase One Room Limiter Warning", positionInCurrentRoom(myEntityId, [21.0,39.0,0.0]))
				useAbilityAtPosition(myEntityId, "Idrae Phase One Room Limiter Two Warning", positionInCurrentRoom(myEntityId, [3.0,21.0,0.0]))
				useAbilityAtPosition(myEntityId, "Idrae Phase One Room Limiter Two Warning", positionInCurrentRoom(myEntityId, [39.0,21.0,0.0]))
				scriptVars["WallTimer"]=5.0
				}
				if scriptVars["WallTimer"]>15.0	{
				useAbilityAtPosition(myEntityId, "Idrae Phase One Room Limiter", positionInCurrentRoom(myEntityId, [21.0,3.0,0.0]))
				useAbilityAtPosition(myEntityId, "Idrae Phase One Room Limiter", positionInCurrentRoom(myEntityId, [21.0,39.0,0.0]))
				useAbilityAtPosition(myEntityId, "Idrae Phase One Room Limiter Two", positionInCurrentRoom(myEntityId, [3.0,21.0,0.0]))
				useAbilityAtPosition(myEntityId, "Idrae Phase One Room Limiter Two", positionInCurrentRoom(myEntityId, [39.0,21.0,0.0]))
				useAbilityAtPosition(myEntityId, "Idrae Get Out Of Spawn", positionInCurrentRoom(myEntityId, [42.0,35.0,0.0]))
				scriptVars["WallTimer"]=5.0
				}



//just a whole lot of bombs and the shotguns that fire from the walls. im sorry
				scriptVars["BombTimer"]+=delta
				if scriptVars["BombTimer"]>1.5	&& scriptVars["BombCounter"] == 0	{
					useAbilityAtPosition(myEntityId, "Idrae Phase X Bomb", positionInCurrentRoom(myEntityId, [36.0,21.0,0.0]))
					useAbilityAtPosition(myEntityId, "Idrae Phase X Bomb", positionInCurrentRoom(myEntityId, [6.0,21.0,0.0]))
					useAbilityAtPosition(myEntityId, "Idrae Phase X Bomb", positionInCurrentRoom(myEntityId, [21.0,36.0,0.0]))
					useAbilityAtPosition(myEntityId, "Idrae Phase X Bomb", positionInCurrentRoom(myEntityId, [21.0,6.0,0.0]))
					useAbilityAtPosition(myEntityId, "Idrae Phase X Bomb", positionInCurrentRoom(myEntityId, [36.0,17.0,0.0]))
