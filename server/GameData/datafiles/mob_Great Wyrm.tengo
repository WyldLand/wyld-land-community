[[186 Wyrmscale Fragment]] @ 67.0
[[103 Gravity Collapse]] @ 2.0
[[98 Void Embrace]] @ 2.0
[[113 Dark Rabbit]] @ 5.0
[[702 Speed Pulse]] @ 15.0
[[123 Wyrm Egg]] @ 500.0 @ qf_epicQuestPhaseTwoItems

---script_greatwyrm_Monster---
resetVars := func() {
	scriptVars["phase"] = 1
	// Phase 1 timers
	scriptVars["timeSinceBurrow"] = 0.0
	scriptVars["timeSinceEarthShatter"] = 0.0
	scriptVars["timeSinceQuakeWave"] = 0.0
	// Phase 2 timers
	scriptVars["timeSinceMagmaBreath"] = 0.0
	scriptVars["timeSinceWingGust"] = 0.0
	// Phase 3 timers
	scriptVars["timeSinceSpineStorm"] = 0.0
	scriptVars["timeSinceTailLash"] = 0.0
	scriptVars["timeSinceRupture"] = 0.0
	// Phase 4 timers
	scriptVars["timeSinceSkyFire"] = 0.0

	scriptVars["timeSinceCornerGuns"] = 0.0
	scriptVars["saidIntroPhrase"] = false
	scriptVars["saidDeathPhrase"] = false
	scriptVars["didPhase2Transition"] = false
	scriptVars["didPhase3Transition"] = false
	scriptVars["didPhase4Transition"] = false
	scriptVars["inTransition"] = false
	scriptVars["transitionTimer"] = 0.0
}

if isDead && !scriptVars["saidDeathPhrase"] {
	say(myEntityId, "At least my children...had enough time to escape...")
	scriptVars["saidDeathPhrase"] = true
}

if !isDead {
	if is_undefined(scriptVars["phase"]) {
		resetVars()
	}

	if targetEntityId > 0 {
		// Check if intro phrase has been said
		if !is_undefined(scriptVars["saidIntroPhrase"]) && !scriptVars["saidIntroPhrase"] {
			say(myEntityId, "A Runner? What a nice snack for my offspring.")
			scriptVars["saidIntroPhrase"] = true
		}
		
		currentHealth := float(getPoints(myEntityId, "hp", "current"))
		maxHealth := float(getPoints(myEntityId, "hp", "max"))
		
		// Phase transitions
		if currentHealth < maxHealth * 0.75 && scriptVars["phase"] == 1 {
			if !scriptVars["inTransition"] && !scriptVars["didPhase2Transition"] {
				// Start phase transition and add invulnerability
				say(myEntityId, "This snack likes to be played with it seems!")
				addAuraToEntity(myEntityId, "Phase Transition Immunity", 0, myEntityId)
				scriptVars["inTransition"] = true
				scriptVars["transitionTimer"] = 0.0
				clearBulletsForEntity(myEntityId)
				useAbilityAtPosition(myEntityId, "Phase Transition", entityPosition(myEntityId))
				
				// Visual effect to indicate invulnerability
				showVfxAtPosition(myEntityId, "Shield", entityPosition(myEntityId))
			}
		}
		
		// Phase 2 to Phase 3 transition at 50% health
		if currentHealth < maxHealth * 0.5 && scriptVars["phase"] == 2 {
			if !scriptVars["inTransition"] && !scriptVars["didPhase3Transition"] {
				// Start phase transition and add invulnerability
				say(myEntityId, "The mighty often make the best meal...")
				addAuraToEntity(myEntityId, "Phase Transition Immunity", 0, myEntityId)
				scriptVars["inTransition"] = true
				scriptVars["transitionTimer"] = 0.0
				clearBulletsForEntity(myEntityId)
				useAbilityAtPosition(myEntityId, "Phase Transition", entityPosition(myEntityId))
				
				// Visual effect to indicate invulnerability
				showVfxAtPosition(myEntityId, "Shield", entityPosition(myEntityId))
			}
		}
		
		// Phase 3 to Phase 4 transition at 25% health
		if currentHealth < maxHealth * 0.25 && scriptVars["phase"] == 3 {
			if !scriptVars["inTransition"] && !scriptVars["didPhase4Transition"] {
				// Start phase transition and add invulnerability
				say(myEntityId, "Enough playing with my food, it's time to end this.")
				addAuraToEntity(myEntityId, "Phase Transition Immunity", 0, myEntityId)
				scriptVars["inTransition"] = true
				scriptVars["transitionTimer"] = 0.0
				clearBulletsForEntity(myEntityId)
				useAbilityAtPosition(myEntityId, "Phase Transition", entityPosition(myEntityId))
				
				// Visual effect to indicate invulnerability
				showVfxAtPosition(myEntityId, "Shield", entityPosition(myEntityId))
			}
		}
		
		// Handle phase transition
		if scriptVars["inTransition"] {
			scriptVars["transitionTimer"] += delta
			
			// After 3 seconds, complete the transition
			if scriptVars["transitionTimer"] >= 3.0 {
				scriptVars["inTransition"] = false
				
				if !scriptVars["didPhase2Transition"] {
					scriptVars["didPhase2Transition"] = true
					scriptVars["phase"] = 2
				} else if !scriptVars["didPhase3Transition"] {
					scriptVars["didPhase3Transition"] = true
					scriptVars["phase"] = 3
				} else if !scriptVars["didPhase4Transition"] {
					scriptVars["didPhase4Transition"] = true
					scriptVars["phase"] = 4
				}
				
				// Reset all timers after phase transition
				scriptVars["timeSinceBurrow"] = 0.0
				scriptVars["timeSinceEarthShatter"] = 0.0
				scriptVars["timeSinceQuakeWave"] = 0.0
				scriptVars["timeSinceMagmaBreath"] = 0.0
				scriptVars["timeSinceWingGust"] = 0.0
				scriptVars["timeSinceSpineStorm"] = 0.0
				scriptVars["timeSinceTailLash"] = 0.0
				scriptVars["timeSinceRupture"] = 0.0
				scriptVars["timeSinceSkyFire"] = 0.0

				triggerAnimation(myEntityId, "Appear"); //make sure we are visible
			}
			
			// Don't perform any other actions while in transition
			// Skip the rest of the function execution
		} else {
			// Update all timers
			scriptVars["timeSinceBurrow"] += delta
			scriptVars["timeSinceEarthShatter"] += delta
			scriptVars["timeSinceQuakeWave"] += delta
			scriptVars["timeSinceMagmaBreath"] += delta
			scriptVars["timeSinceWingGust"] += delta
			scriptVars["timeSinceSpineStorm"] += delta
			scriptVars["timeSinceTailLash"] += delta
			scriptVars["timeSinceRupture"] += delta
			scriptVars["timeSinceSkyFire"] += delta
			scriptVars["timeSinceCornerGuns"] += delta
			
			if castingAction == 0 {
				if scriptVars["phase"] == 1 {
					// Ground Phase - Aggressive earth attacks
					if scriptVars["timeSinceBurrow"] > 13.0 {
						useAbilityAtPosition(myEntityId, "Converging Rings", entityPosition(myEntityId))
						useAbilityAtPosition(myEntityId, "Burrow Strike", entityPosition(myEntityId))
						scriptVars["timeSinceBurrow"] = 0.0
					} else if scriptVars["timeSinceEarthShatter"] > 2.5 {
						for i := 0; i < 3; i++ {
							useAbilityAtPosition(myEntityId, "Earth Shatter", randomPositionInCurrentRoom(myEntityId, 3.0))
						}
						scriptVars["timeSinceEarthShatter"] = 0.0
					} else if scriptVars["timeSinceQuakeWave"] > 3.5 {
						useAbilityAtPosition(myEntityId, "Quake Wave", entityPosition(myEntityId))
						scriptVars["timeSinceQuakeWave"] = 0.0
					}
				} else if scriptVars["phase"] == 2 {
					// Breath Phase - Rapid breath and wing combos
					if scriptVars["timeSinceBurrow"] > 11.0 {
						useAbilityAtPosition(myEntityId, "Converging Rings", entityPosition(myEntityId))
						useAbilityAtPosition(myEntityId, "Burrow Strike", entityPosition(myEntityId))
						scriptVars["timeSinceBurrow"] = 0.0
					} else if scriptVars["timeSinceEarthShatter"] > 2.5 {
						for i := 0; i < 3; i++ {
							useAbilityAtPosition(myEntityId, "Earth Shatter", randomPositionInCurrentRoom(myEntityId, 3.0))
						}
						scriptVars["timeSinceEarthShatter"] = 0.0
					}
					if scriptVars["timeSinceWingGust"] > 1.5 {
						useAbilityAtTarget(myEntityId, "Wing Gust", targetEntityId, 1.0)
						scriptVars["timeSinceWingGust"] = 0.0
					}
				} else if scriptVars["phase"] == 3 {
					// Storm Phase - Constant bullet pressure
					if scriptVars["timeSinceBurrow"] > 11.0 {
						useAbilityAtPosition(myEntityId, "Converging Rings", entityPosition(myEntityId))
						useAbilityAtPosition(myEntityId, "Burrow Strike", entityPosition(myEntityId))
						scriptVars["timeSinceBurrow"] = 0.0
					} else if scriptVars["timeSinceSpineStorm"] > 5.0 {
						useAbilityAtPosition(myEntityId, "Spine Storm", entityPosition(myEntityId))
						scriptVars["timeSinceSpineStorm"] = 0.0
					} else if scriptVars["timeSinceTailLash"] > 2.5 {
						useAbilityAtTarget(myEntityId, "Tail Lash", targetEntityId, 1.0)
						scriptVars["timeSinceTailLash"] = 0.0
					} else if scriptVars["timeSinceRupture"] > 3.0 {
						useAbilityAtPosition(myEntityId, "Ground Rupture", randomPositionInCurrentRoom(myEntityId, 3.0))
						useAbilityAtPosition(myEntityId, "Ground Rupture", randomPositionInCurrentRoom(myEntityId, 3.0))
						scriptVars["timeSinceRupture"] = 0.0
					}
				} else {
					// Final Phase - Relentless attack combinations
					if scriptVars["timeSinceBurrow"] > 11.0 {
						useAbilityAtPosition(myEntityId, "Converging Rings", entityPosition(myEntityId))
						useAbilityAtPosition(myEntityId, "Burrow Strike", entityPosition(myEntityId))
						scriptVars["timeSinceBurrow"] = 0.0
					} else if scriptVars["timeSinceSpineStorm"] > 5.0 {
						useAbilityAtPosition(myEntityId, "Spine Storm", entityPosition(myEntityId))
						scriptVars["timeSinceSpineStorm"] = 0.0
					} else if scriptVars["timeSinceWingGust"] > 3.0 {
						useAbilityAtTarget(myEntityId, "Wing Gust", targetEntityId, 1.0)
						scriptVars["timeSinceWingGust"] = 0.0
					} else if scriptVars["timeSinceRupture"] > 1.75 {
						useAbilityAtPosition(myEntityId, "Ground Rupture", randomPositionInCurrentRoom(myEntityId, 3.0))
						scriptVars["timeSinceRupture"] = 0.0
					} else if scriptVars["timeSinceEarthShatter"] > 2.5 {
						for i := 0; i < 2; i++ {
							useAbilityAtPosition(myEntityId, "Earth Shatter", randomPositionInCurrentRoom(myEntityId, 3.0))
						}
						scriptVars["timeSinceEarthShatter"] = 0.0
					}
				}
			}
		}
	}
}
