---aura_Phase Transition Immunity---
Type :: Buff
Duration :: 5.0
Icon :: statusicons_36
Max Stacks :: 1
Time Per Tick :: 1.0
Definitions :: [[Custom:PhaseTransitionImmunity]]

---script_PhaseTransitionImmunity_IncomingDamage---
// Negate all damage during phase transition
additionalDamage = -1 * damage

---script_BurrowStrike_Cast---
setSpeed(myEntityId, 0.0)

if frameNum == 25 {
	setCollisionLayer(myEntityId, CollisionLayerDynamic)
}

if frameNum == 90 {
	targetPos := entityPosition(randomTargetEntityId(myEntityId, 100.0))
	setPosition(myEntityId, targetPos)
	setCollisionLayer(myEntityId, CollisionLayerMonster)
}

---ability_Corner Shotgun---
Cast Time :: 0.0
Script :: CornerShotgun

---script_CornerShotgun_Cast---
log("Corner Shotgun Cast frame ", frameNum)
if frameNum == 0 {
	roomCorners := [
		positionInCurrentRoom(myEntityId, [4.0, 4.0, 0.0]),
		positionInCurrentRoom(myEntityId, [28.0, 4.0, 0.0]),
		positionInCurrentRoom(myEntityId, [4.0, 28.0, 0.0]),
		positionInCurrentRoom(myEntityId, [28.0, 28.0, 0.0])
	]
	
	targetPos := positionInCurrentRoom(myEntityId, [14.0, 14.0, 0.0])
	
	for i := 0; i < len(roomCorners); i++ {
		useAbilityAtPosition(myEntityId, "Corner Shotgun Fire", roomCorners[i], targetPos)
	}
}

