---script_TankyPulse_FireWeapon---
if abilityId == auraAbilityId {

    auras := getAurasOnEntity(myEntityId)
    highestLevelTauntFound := 0
    for j := 0; j < len(auras); j++ {
       if (auras[j]["name"] == "Taunt I") && highestLevelTauntFound < 1 {
            highestLevelTauntFound = 1
       } else if (auras[j]["name"] == "Taunt II") && highestLevelTauntFound < 2 {
            highestLevelTauntFound = 2
       } else if (auras[j]["name"] == "Taunt III") && highestLevelTauntFound < 3 {
            highestLevelTauntFound = 3
       }
    }

     if highestLevelTauntFound == 3 {
        addAuraToEntity(myEntityId, "Aggro III", -99, myEntityId)
        addAuraToEntity(myEntityId, "Damage Reduction III", -99, myEntityId)
        log("Taunt III Activated")
    } else if highestLevelTauntFound == 2 {
        addAuraToEntity(myEntityId, "Aggro II", -99, myEntityId)
        addAuraToEntity(myEntityId, "Damage Reduction II", -99, myEntityId)
        log("Taunt II  Activated")
    } else if highestLevelTauntFound == 1 {
        addAuraToEntity(myEntityId, "Aggro I", -99, myEntityId)
        addAuraToEntity(myEntityId, "Damage Reduction I", -99, myEntityId)
        log("Taunt I Activated")
    } else if highestLevelTauntFound == 0 {
        addAuraToEntity(myEntityId, "Damage Reduction I", -99, myEntityId)
        log("Taunt Not Activated")
    }
}