---aura_Damage Reduction I---
Type :: Buff
Duration :: 2.0
Icon :: statusicons_8
Max Stacks :: 1
Time Per Tick :: 1.0
Definitions :: [[Custom:DamageReductionI]]

---script_DamageReductionI_IncomingDamage---
// Reduce incoming damage by 10 points
if damage > 0 {
	damageReduction := 10
	if damage <= damageReduction {
		// If damage is 10 or less, negate all damage
		additionalDamage = -1 * damage
	} else {
		// Otherwise, reduce damage by 10
		additionalDamage = -damageReduction
	}
}

