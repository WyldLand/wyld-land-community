// Phase 1

---ability_Web Spray---
Bullet Definition :: [[webspray]]
Auras :: [[Slow]]
Cooldown :: 3.0

---bulletdef_webspray---
sprite Custom11
color 0
potency 100
// Create a spiral effect by using repeat with increasing angles
repeat bullets:24 speed:8 angle:0 angleChange:15 delay:1 directionType:relative
	wait 120
	vanish
// Add a second spiral with different timing
wait 5
repeat bullets:24 speed:6 angle:180 angleChange:15 delay:1 directionType:relative
	wait 120
	vanish

---ability_Flame Burst---
Bullet Definition :: [[flameburst]]
Cooldown :: 4.5
Auras :: [[Slow]]
VFX Cast :: trigger:Attack

---bulletdef_flameburst---
sprite WhitePool 15
potency 175
fire 0 relative 0
	aoeexplosion
	radius 15
	timedFill 50
	damageEvery 50
	wait 50
	vfx BombExplosion 4
	wait 1
	fire flameburstwave
	vanish

---bulletdef_flameburstwave---
sprite Custom7
color 0
potency 75
// First star pattern - 8 points with 45-degree spacing
nway speed:8 bullets:8 spread:360 angle:0 directionType:absolute
	wait 60
	vanish
// Second star pattern - 8 points offset from first pattern
wait 5
nway speed:7 bullets:8 spread:360 angle:22.5 directionType:absolute
	wait 60
	vanish
// Third dense star pattern with more bullets
wait 5
nway speed:6 bullets:16 spread:360 angle:11.25 directionType:absolute
	wait 60
	vanish

