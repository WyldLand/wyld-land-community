			if scriptVars["timeSinceVoidTimer"] >= 2.0 {
				rand := import("rand")
				// Create 2-3 void timers throughout the room
				numVoidTimers := 5
				
				for i := 0; i < numVoidTimers; i++ {
					// Generate random coordinates within the combat area
					xPos := 10.0 + rand.float() * 76.0  // Between 10 and 86
					yPos := 10.0 + rand.float() * 68.0  // Between 10 and 78
					
					useAbilityAtPosition(myEntityId, "Void Timer", 
						positionInCurrentRoom(myEntityId, [xPos, yPos, 0.0]))
				}
				scriptVars["timeSinceVoidTimer"] = 0.0
			}

