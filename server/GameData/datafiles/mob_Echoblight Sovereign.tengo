				useAbilityAtPosition(myEntityId, "Fire Vortex", 
					positionInCurrentRoom(myEntityId, [81.0, 73.0, 0.0]))
				scriptVars["timeSinceFireVortex"] = 0.0
			}
			
			// Random spawning attack
			
			// Ember Mines - Spawns randomly throughout the room
			if scriptVars["timeSinceEmberMines"] >= 3.5 {
				rand := import("rand")
				// Create 4-6 random ember mines throughout the room
				numMines := rand.intn(3) + 4  // 4 to 6 mines
				
				for i := 0; i < numMines; i++ {
					// Generate random coordinates within the combat area
					xPos := 3.0 + rand.float() * 90.0  // Between 3 and 93
					yPos := 4.0 + rand.float() * 80.0  // Between 4 and 84
					
					useAbilityAtPosition(myEntityId, "Ember Mines", 
						positionInCurrentRoom(myEntityId, [xPos, yPos, 0.0]))
				}
				scriptVars["timeSinceEmberMines"] = 0.0
			}
		}

		// Phase 2 
		if scriptVars["phase"] == 2 {

			 scriptVars["timeSinceWebSprayPhase2"] += delta
			 scriptVars["timeSinceFlameBurstPhase2"] += delta
			 scriptVars["timeSinceFireVortexPhase2"] += delta
			 scriptVars["timeSinceEmberMinesPhase2"] += delta

			if scriptVars["timeSinceWebSprayPhase2"] >= 2.5 {  // Slightly faster cooldown than Phase 1
				useAbilityAtTarget(myEntityId, "Web Spray Phase 2", targetEntityId, 1.0)
				scriptVars["timeSinceWebSprayPhase2"] = 0.0
			}
	
			if scriptVars["timeSinceFlameBurstPhase2"] >= 4.0 {  // Slightly faster cooldown than Phase 1
				useAbilityAtPosition(myEntityId, "Flame Burst Phase 2", entityPosition(myEntityId))
				scriptVars["timeSinceFlameBurstPhase2"] = 0.0
			}

