			// Fire Vortex - Creates spinning fire patterns from fixed points
			if scriptVars["timeSinceFireVortex"] >= 6.0 {
				// Place fire vortices at corners and other strategic points
				useAbilityAtPosition(myEntityId, "Fire Vortex", 
					positionInCurrentRoom(myEntityId, [15.0, 15.0, 0.0]))
				useAbilityAtPosition(myEntityId, "Fire Vortex", 
					positionInCurrentRoom(myEntityId, [81.0, 15.0, 0.0]))
				useAbilityAtPosition(myEntityId, "Fire Vortex", 
