---ability_Spawn Minions---
Script :: SpawnMinions

---script_SpawnMinions_Cast---
if frameNum == 0 {
	// Choose which enemy type to spawn this time
	rand := import("rand")
	entityTypes := ["anklebiter", "mushroomdagger"]
	selectedType := entityTypes[rand.intn(len(entityTypes))]
	
	// Spawn at the four designated positions
	spawnPositions := [
		 positionInCurrentRoom(myEntityId,[81.0, 76.0, 0.0]),
		 positionInCurrentRoom(myEntityId,[81.0, 14.0, 0.0]),
		 positionInCurrentRoom(myEntityId,[16.0, 76.0, 0.0]),
		 positionInCurrentRoom(myEntityId,[16.0, 14.0, 0.0])
	]
	
	for i := 0; i < len(spawnPositions); i++ {
	   newEntityId := summonEntity(selectedType, spawnPositions[i], monsterLevel(myEntityId))
	   killEntityIfEntityDies(newEntityId, myEntityId)
	   aggroMyTargets(myEntityId, newEntityId)
	}
}

---ability_Fire Arena---
Bullet Definition :: [[firearena]]
Max Range :: 10000000000000.0
Cooldown :: 2.0
Script :: FireArena

---bulletdef_firearena---
sprite Invisible
potency 0
fire 0 relative 0
	aoeexplosion
	radius 800
	damageEvery 1
	wait 1
	vanish

---script_FireArena_Cast---
// Custom logic to apply The Floor Is Lava only to players without Lava Protection
nearby := getNearbyEntities(myEntityId)

for i := 0; i < len(nearby); i++ {
	targetId := nearby[i]["id"]
	
	// Check if this entity is within the Fire Arena radius (800 units)
	dist := distToEntity(myEntityId, targetId)
	if dist <= 800 {
		// Check if the target is an enemy of this entity (i.e., a player)
		// Since this is cast by a monster/boss, players will be enemies
		if isEnemyOfEntity(myEntityId, targetId) {
			// Additional check: make sure it's actually a player by checking prefab name
			prefabName := getPrefabNameOfEntity(targetId)
			if prefabName == "player" {
				// Check if the target has Lava Protection aura
				hasFireProtection := false
				targetAuras := getAurasOnEntity(targetId)
				
				for j := 0; j < len(targetAuras); j++ {
					if targetAuras[j]["name"] == "Lava Protection" {
						hasFireProtection = true
						break
					}
				}
				
				// Only apply The Floor Is Lava if the target doesn't have Lava Protection
				if !hasFireProtection {
					addAuraToEntity(myEntityId, "The Floor Is Lava", abilityId, targetId)
				}
			}
		}
	}
}

---aura_The Floor Is Lava---
Type :: Debuff
Duration :: 2.0
Icon :: statusicons_9
Max Stacks :: 1
Time Per Tick :: 1.0
Definitions :: [[AuraDealDamage/The Floor Is Lava]]

---auradealdamage_The Floor Is Lava---
Damage Type :: Burn
Potency :: 25

---ability_Lava Protection Pool---
Bullet Definition :: [[fireprotectionpool]]
Max Range :: 100.0
Auras :: [[Lava Protection]]

---bulletdef_fireprotectionpool---
sprite GreenPool 4
potency 0
fire 0 relative 0
	aoedot
	nododge
	radius 4
	damageEvery 5
	wait 50
	vanish

---aura_Lava Protection---
Type :: Buff
Duration :: 50.0
Icon :: statusicons_8
Max Stacks :: 1
Time Per Tick :: 1.0
Definitions :: [[Custom:FireProtection]]

---script_FireProtection_IncomingDamage---
dispelAuraOnEntity(targetEntityId, "The Floor Is Lava")

// Check if damage is from Fire Arena ability
if getAbilityName(abilityId) == "Fire Arena" {
	// Negate all fire arena damage
	additionalDamage = -1 * damage
}



---aura_Sovereign Invulnerability---
Type :: Buff
Duration :: -1
Max Stacks :: 1
Time Per Tick :: 1.0
Icon :: statusicons_36
Definitions :: [[Custom:SovereignInvulnerability]]

---script_SovereignInvulnerability_IncomingDamage---
// Complete immunity to all damage while guardian is alive
additionalDamage = -1 * damage

