---script_echoblightsovereign_Monster---
resetVars := func() {
	scriptVars["timeSinceSpawn"] = 0.0
	scriptVars["timeSinceFire"] = 0.0
	scriptVars["firstFrame"] = true
	scriptVars["poolsCreated"] = false
	scriptVars["engaged"] = false
	scriptVars["timePoolCheck"] = 0.0
	scriptVars["guardiansSpawned"] = false
	scriptVars["guardianId1"] = 0
	scriptVars["guardianId2"] = 0
	scriptVars["guardian1RespawnTimer"] = 0.0
	scriptVars["guardian2RespawnTimer"] = 0.0
	scriptVars["guardian1Dead"] = false
	scriptVars["guardian2Dead"] = false
	scriptVars["guardianRespawnTime"] = 45.0  // 10 seconds respawn time
	
	

	// Phase 1 attack timers
	scriptVars["timeSinceWebSpray"] = 0.0
	scriptVars["timeSinceFlameBurst"] = 0.0
	scriptVars["timeSinceWebCorridor"] = 0.0
	scriptVars["timeSinceFireVortex"] = 0.0
	scriptVars["timeSinceEmberMines"] = 0.0
	scriptVars["timeSinceBottomLine"] = 0.0
	scriptVars["phase"] = 1

	// Phase 2 attack timers
	scriptVars["timeSinceWebSprayPhase2"] = 0.0
	scriptVars["timeSinceFlameBurstPhase2"] = 0.0
	scriptVars["timeSinceFireVortexPhase2"] = 0.0
	scriptVars["timeSinceEmberMinesPhase2"] = 0.0

	// Phase 3 timers
	scriptVars["timeSinceVoidTimer"] = 0.0

	// Teleport variables

	scriptVars["timeSinceTeleport"] = 0.0
	scriptVars["teleportIndex"] = 0
	
	// Define predefined teleport locations
	// These should be coordinates within your current room
	scriptVars["teleportLocations"] = [
		[27.0, 27.0, 0.0],
		[72.0, 27.0, 0.0],
		[27.0, 63.0, 0.0],
		[72.0, 63.0, 0.0]
	]
}

if !isDead {
	if is_undefined(scriptVars["timeSinceSpawn"]) {
		resetVars()
	}

	// Set initial boss position when first spawned
	if scriptVars["firstFrame"] {
		setPosition(myEntityId, positionInCurrentRoom(myEntityId, [48.0, 44.0, 0.0]))
		scriptVars["firstFrame"] = false
	}

	if targetEntityId > 0 {
	currentHealth := float(getPoints(myEntityId, "hp", "current"))
	maxHealth := float(getPoints(myEntityId, "hp", "max"))

	// Phase transitions
	if currentHealth < maxHealth * 0.66 && scriptVars["phase"] == 1 {
			clearBulletsForEntity(myEntityId)
			scriptVars["phase"] = 2
		} else if currentHealth < maxHealth * 0.33 && scriptVars["phase"] == 2 {
			clearBulletsForEntity(myEntityId)
			scriptVars["phase"] = 3 
		}
	}
	
	// Check guardians status and handle respawning
	if scriptVars["guardiansSpawned"] {
		// Check and handle first guardian
		if isEntityDead(scriptVars["guardianId1"]) {
			if !scriptVars["guardian1Dead"] {
				// First time detecting this guardian's death
				scriptVars["guardian1Dead"] = true
				scriptVars["guardian1RespawnTimer"] = 0.0
			} else {
				// Increment respawn timer
				scriptVars["guardian1RespawnTimer"] += delta
				
				if scriptVars["guardian1RespawnTimer"] >= scriptVars["guardianRespawnTime"] {
					// Time to respawn guardian 1
					guardianPos1 := positionInCurrentRoom(myEntityId, [48.0, 12.0, 0.0])
					scriptVars["guardianId1"] = summonEntity("echoblightguardian", guardianPos1, monsterLevel(myEntityId))
					scriptVars["guardian1Dead"] = false
					scriptVars["guardian1RespawnTimer"] = 0.0
				}
			}
		} else {
			scriptVars["guardian1Dead"] = false
		}
		
		// Check and handle second guardian
		if isEntityDead(scriptVars["guardianId2"]) {
			if !scriptVars["guardian2Dead"] {
				// First time detecting this guardian's death
				scriptVars["guardian2Dead"] = true
				scriptVars["guardian2RespawnTimer"] = 0.0
			} else {
				// Increment respawn timer
				scriptVars["guardian2RespawnTimer"] += delta
				
				if scriptVars["guardian2RespawnTimer"] >= scriptVars["guardianRespawnTime"] {
					// Time to respawn guardian 2
					guardianPos2 := positionInCurrentRoom(myEntityId, [48.0, 76.0, 0.0])
					scriptVars["guardianId2"] = summonEntity("echoblightguardian", guardianPos2, monsterLevel(myEntityId))
					scriptVars["guardian2Dead"] = false
					scriptVars["guardian2RespawnTimer"] = 0.0
				}
			}
		} else {
			scriptVars["guardian2Dead"] = false
		}
		
		// Only remove invulnerability if BOTH guardians are dead
		bothGuardiansDead := isEntityDead(scriptVars["guardianId1"]) && isEntityDead(scriptVars["guardianId2"])
		
		if bothGuardiansDead {
			// Both guardians are dead, remove invulnerability temporarily
			if hasAura := getAurasOnEntity(myEntityId); len(hasAura) > 0 {
				for i := 0; i < len(hasAura); i++ {
					if hasAura[i]["name"] == "Sovereign Invulnerability" {
						dispelAuraOnEntity(myEntityId, "Sovereign Invulnerability")
					}
				}
			}
		} else {
			// At least one guardian is alive, ensure invulnerability is active
			hasInvulnerability := false
			if hasAura := getAurasOnEntity(myEntityId); len(hasAura) > 0 {
				for i := 0; i < len(hasAura); i++ {
					if hasAura[i]["name"] == "Sovereign Invulnerability" {
						hasInvulnerability = true
						break
					}
				}
			}
			
			if !hasInvulnerability {
				addAuraToEntity(myEntityId, "Sovereign Invulnerability", 0, myEntityId)
			}

			// Check if it's time to teleport (every 30 seconds)
			if scriptVars["timeSinceTeleport"] >= 30.0 {
				// Reset the timer
				scriptVars["timeSinceTeleport"] = 0.0
				
				// Move to the next location in the predefined list
				scriptVars["teleportIndex"] = (scriptVars["teleportIndex"] + 1) % len(scriptVars["teleportLocations"])
				
				// Get the new position
				newPosition := positionInCurrentRoom(myEntityId, scriptVars["teleportLocations"][scriptVars["teleportIndex"]])
				
				// Teleport the entity to the new position
				setPosition(myEntityId, newPosition)
				
			}
		}
	}
	
	if targetEntityId > 0 {
		// Spawn the guardians when the player is first detected
		if !scriptVars["guardiansSpawned"] {
			// Spawn first guardian at the top of the arena
			guardianPos1 := positionInCurrentRoom(myEntityId, [48.0, 12.0, 0.0])
			scriptVars["guardianId1"] = summonEntity("echoblightguardian", guardianPos1, monsterLevel(myEntityId))
			
			// Spawn second guardian at the bottom of the arena
			guardianPos2 := positionInCurrentRoom(myEntityId, [48.0, 76.0, 0.0])
			scriptVars["guardianId2"] = summonEntity("echoblightguardian", guardianPos2, monsterLevel(myEntityId))
			
			scriptVars["guardiansSpawned"] = true
			
			// Add invulnerability to the boss until guardians are killed
			addAuraToEntity(myEntityId, "Sovereign Invulnerability", 0, myEntityId)
		}
		
		// Create Lava Protection pools only after the boss has engaged with a player
		if !scriptVars["poolsCreated"] {
			// Create the first pool at position [33,44,0]
			useAbilityAtPosition(myEntityId, "Lava Protection Pool", 
				positionInCurrentRoom(myEntityId, [33.0, 44.0, 0.0]))
			
			// Create the second pool at position [65,44,0]
			useAbilityAtPosition(myEntityId, "Lava Protection Pool", 
				positionInCurrentRoom(myEntityId, [65.0, 44.0, 0.0]))
			
			scriptVars["poolsCreated"] = true
			
			// Mark that the boss is now engaged
			scriptVars["engaged"] = true
		}

		// Update all timers
		scriptVars["timeSinceSpawn"] += delta
		scriptVars["timeSinceFire"] += delta
		scriptVars["timePoolCheck"] += delta
		scriptVars["timeSinceTeleport"] += delta
		
		// Update Phase 1 ability timers
		scriptVars["timeSinceWebSpray"] += delta
		scriptVars["timeSinceFlameBurst"] += delta
		scriptVars["timeSinceWebCorridor"] += delta
		scriptVars["timeSinceFireVortex"] += delta  
		scriptVars["timeSinceEmberMines"] += delta
		scriptVars["timeSinceBottomLine"] += delta

		// Periodically check and recreate pools if needed
		if scriptVars["timePoolCheck"] >= 2.0 {
			// Recreate pools to ensure they're always present
			useAbilityAtPosition(myEntityId, "Lava Protection Pool", 
				positionInCurrentRoom(myEntityId, [33.0, 44.0, 0.0]))
			useAbilityAtPosition(myEntityId, "Lava Protection Pool", 
				positionInCurrentRoom(myEntityId, [65.0, 44.0, 0.0]))
			
			scriptVars["timePoolCheck"] = 0.0
		}

		// Handle spawn minions timer
		if scriptVars["timeSinceSpawn"] >= 7.5 {
		   useAbilityAtPosition(myEntityId, "Spawn Minions", entityPosition(myEntityId))
			scriptVars["timeSinceSpawn"] = 0.0
		}
		
		// Periodically apply the fire arena effect, but only after we've created the protection pools
		if scriptVars["timeSinceFire"] >= 2.0 {
			useAbilityAtPosition(myEntityId, "Fire Arena", positionInCurrentRoom(myEntityId, [48.0, 44.0, 0.0]))
			scriptVars["timeSinceFire"] = 0.0
		}


		
		// PHASE 1 ABILITIES
		if scriptVars["phase"] == 1 {
			// Boss Direct Attacks
			
			// Web Spray - Direct attack from boss
			if scriptVars["timeSinceWebSpray"] >= 3.0 {
				useAbilityAtTarget(myEntityId, "Web Spray", targetEntityId, 1.0)
				scriptVars["timeSinceWebSpray"] = 0.0
			}
			
			// Flame Burst - Direct AoE attack from boss
			if scriptVars["timeSinceFlameBurst"] >= 4.5 {
				useAbilityAtPosition(myEntityId, "Flame Burst", entityPosition(myEntityId))
				scriptVars["timeSinceFlameBurst"] = 0.0
			}
			
			// Stationary point patterns
			
			// Web Corridor - Creates web lines from fixed points
			if scriptVars["timeSinceWebCorridor"] >= 2.5 {
				useAbilityAtPosition(myEntityId, "Web Corridor1", positionInCurrentRoom(myEntityId, [3.0, 4.0, 0.0]))
				useAbilityAtPosition(myEntityId, "Web Corridor2", positionInCurrentRoom(myEntityId, [3.0, 5.0, 0.0]))
				useAbilityAtPosition(myEntityId, "Web Corridor3", positionInCurrentRoom(myEntityId, [3.0, 6.0, 0.0]))
				useAbilityAtPosition(myEntityId, "Web Corridor4", positionInCurrentRoom(myEntityId, [3.0, 7.0, 0.0]))
				useAbilityAtPosition(myEntityId, "Web Corridor5", positionInCurrentRoom(myEntityId, [3.0, 8.0, 0.0]))
				useAbilityAtPosition(myEntityId, "Web Corridor6", positionInCurrentRoom(myEntityId, [3.0, 9.0, 0.0]))
				useAbilityAtPosition(myEntityId, "Web Corridor7", positionInCurrentRoom(myEntityId, [3.0, 10.0, 0.0]))
				useAbilityAtPosition(myEntityId, "Web Corridor8", positionInCurrentRoom(myEntityId, [3.0, 11.0, 0.0]))
				useAbilityAtPosition(myEntityId, "Web Corridor9", positionInCurrentRoom(myEntityId, [3.0, 12.0, 0.0]))
				useAbilityAtPosition(myEntityId, "Web Corridor10", positionInCurrentRoom(myEntityId, [3.0, 13.0, 0.0]))
				useAbilityAtPosition(myEntityId, "Web Corridor11", positionInCurrentRoom(myEntityId, [3.0, 14.0, 0.0]))
