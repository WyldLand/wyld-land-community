				useAbilityAtPosition(myEntityId, "Web Corridor Left84", positionInCurrentRoom(myEntityId, [94.0, 87.0, 0.0]))
				useAbilityAtPosition(myEntityId, "Web Corridor Left85", positionInCurrentRoom(myEntityId, [94.0, 88.0, 0.0]))
				scriptVars["timeSinceWebCorridor"] = 0.0
			}  
		}
	}
}

---mobdefinition_Echoblight Guardian---
ID :: echoblightguardian
Prefab :: raidbosshealtower
Range Behavior :: [[Stationary]]
Abilities :: [[Guardian Barrier]]
Bounding Box :: -0.03125 2.34375 2.3125 4.6875
Speed :: 0
Type :: Elite
Options :: alwaysattack

---ability_Guardian Barrier---
Bullet Definition :: [[guardianbarrier]]
Cooldown :: 5.0

---bulletdef_guardianbarrier---
sprite PurplePool 3
potency 0
fire 0 relative 0
	aoeexplosion
	radius 3
	timedFill 20
	damageEvery 20
	wait 20
	vfx ShockPool
	wait 1
	vanish
wait 20
sprite Basic
color 4
potency 80
radial bullets:16 speed:6
	wait 60
	vanish

---script_echoblightguardian_Monster---
if is_undefined(scriptVars["initialized"]) {
	scriptVars["initialized"] = true
	scriptVars["timeSinceBarrier"] = 0.0
}

if !isDead {
	scriptVars["timeSinceBarrier"] += delta
	
	// Cast barrier ability periodically
	if scriptVars["timeSinceBarrier"] >= 5.0 {
		useAbilityAtPosition(myEntityId, "Guardian Barrier", entityPosition(myEntityId))
		scriptVars["timeSinceBarrier"] = 0.0
	}
}

---mobdefinition_Raid Portal---
