---bulletdef_rampageexplosion---
sprite CirclePool 3
potency 150
fire 0 relative 0
	aoeexplosion
	radius 3.0
	timedFill 3
	damageEvery 3
	wait 3
	vfx BombExplosion 
	wait 1
	vanish

---script_RampageExplosive_DamageDealt---
if abilityId == auraAbilityId {
	if is_undefined(scriptVars["hitCounter"]) {
		scriptVars["hitCounter"] = 0
	}
	
	scriptVars["hitCounter"] += 1
	
	if scriptVars["hitCounter"] >= 10 {
		// Create explosion at the target's position
		targetPos := entityPosition(damageSenderId)
		useAbilityAtPosition(myEntityId, "Rampage Explosion", targetPos)
		scriptVars["hitCounter"] = 0
		showVfxAtPosition(myEntityId, "PowerSpike", targetPos)
	}
}

---script_RampageExplosive_ReloadWeapon---
// Reset counter on reload to prevent carrying over partial progress
if abilityId == auraAbilityId {
	scriptVars["hitCounter"] = 0
}