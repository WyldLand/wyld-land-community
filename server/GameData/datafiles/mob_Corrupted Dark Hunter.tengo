---script_corruptedhunter_Monster---

if is_undefined(scriptVars["phase"]) {
	scriptVars["phase"] = 1
}

if is_undefined(scriptVars["wait"]) {
	scriptVars["wait"] = 0.0
}

if !isDead && targetEntityId != 0 {

	//hp
	hp := getPoints(myEntityId, "hp", "current")
	//log(hp)
	//log(getStat(myEntityId, "Speed"))
	pthp := getPoints(myEntityId, "hp", "max")
	//wait
	if scriptVars["phase"] == 2 || scriptVars["phase"] == 4 || scriptVars["phase"] == 6 || scriptVars["phase"] == 8 || scriptVars["phase"] == 10 || scriptVars["phase"] == 12 || scriptVars["phase"] == 14 {
		if scriptVars["wait"] == 0.0 {
			clearBulletsForEntity(myEntityId)
		}
		scriptVars["wait"] += delta
		setPosition(myEntityId, positionInCurrentRoom(myEntityId, [16.0, 18.0, 0.0]))
		changeAttackBehaviour(myEntityId, "Stationary")
		setCollisionLayer(myEntityId, CollisionLayerDynamic)
		if scriptVars["wait"] > 5.0 {
			setCollisionLayer(myEntityId, CollisionLayerMonster)
			scriptVars["phase"] += 1
		}
	}


	//phase 1

	if hp < 0.93 * pthp && scriptVars["phase"] == 1 {
		dispelAuraOnEntity(myEntityId, "CorruptedHunter Phase One Speed")
		log("phase 2")
		scriptVars["wait"] = 0.0
		scriptVars["phase"] += 1
	}
	if scriptVars["phase"] == 1 {
		if !isDead {
			scriptVars["wait"] = 0.0
			if is_undefined(scriptVars["hp1limit"]) {
				scriptVars["hp1limit"] = 1
				addAuraToEntity(myEntityId, "CorruptedHunter Boss Max Hp", 0, myEntityId)
				addHitPoints(myEntityId, 100000000)
				log("phase 1 corrupted")
			}
			if scriptVars["hp1limit"] <= 1 && targetEntityId != 0 {
				summonEntity("corruptedhunterassassin", positionInCurrentRoom(myEntityId, [18.0, 18.0, 0.0]), monsterLevel(myEntityId))
				summonEntity("corruptedhunterassassin", positionInCurrentRoom(myEntityId, [20.0, 20.0, 0.0]), monsterLevel(myEntityId))
				summonEntity("corruptedhunterassassin", positionInCurrentRoom(myEntityId, [15.0, 15.0, 0.0]), monsterLevel(myEntityId))
				addAuraToEntity(myEntityId, "CorruptedHunter Phase One Speed", 0, myEntityId)
				scriptVars["hp1limit"] = scriptVars["hp1limit"] + 1
			}
			if is_undefined(scriptVars["hp1bullets"]) {
				scriptVars["hp1bullets"] = 4.0
			}
			scriptVars["hp1bullets"] += delta
			if scriptVars["hp1bullets"] > 5.0 {
				useAbilityAtPosition(myEntityId, "CorruptedHunter Phase One Mines", positionInCurrentRoom(myEntityId, [26.0, 26.0, 0.0]))
				useAbilityAtPosition(myEntityId, "CorruptedHunter Phase One Mines", positionInCurrentRoom(myEntityId, [6.0, 6.0, 0.0]))
				useAbilityAtPosition(myEntityId, "CorruptedHunter Phase One Mines", positionInCurrentRoom(myEntityId, [26.0, 6.0, 0.0]))
				useAbilityAtPosition(myEntityId, "CorruptedHunter Phase One Mines", positionInCurrentRoom(myEntityId, [6.0, 26.0, 0.0]))
				useAbilityAtPosition(myEntityId, "CorruptedHunter Phase One Mines", positionInCurrentRoom(myEntityId, [16.0, 16.0, 0.0]))
				useAbilityAtPosition(myEntityId, "CorruptedHunter Phase One Mines", positionInCurrentRoom(myEntityId, [16.0, 6.0, 0.0]))
				useAbilityAtPosition(myEntityId, "CorruptedHunter Phase One Mines", positionInCurrentRoom(myEntityId, [6.0, 16.0, 0.0]))
				useAbilityAtPosition(myEntityId, "CorruptedHunter Phase One Mines", positionInCurrentRoom(myEntityId, [26.0, 16.0, 0.0]))
				useAbilityAtPosition(myEntityId, "CorruptedHunter Phase One Mines", positionInCurrentRoom(myEntityId, [16.0, 26.0, 0.0]))
				scriptVars["hp1bullets"] = 0
			}
