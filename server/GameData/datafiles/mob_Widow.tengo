---ability_Widow Spider Call---
VFX Charging :: trigger:Buff*
Cast Time :: 1.0
Script :: SpiderCall

---script_SpiderCall_Cast---
if frameNum == 10 {
    // Spawn 3 spiderlings
    for i := 0; i < 3; i++ {
        newEntId := summonEntity("spider", randomPositionInCurrentRoom(myEntityId, 2.0), monsterLevel(myEntityId))
        aggroMyTargets(myEntityId, newEntId)
        killEntityIfEntityDies(newEntId, myEntityId)
    }
}

