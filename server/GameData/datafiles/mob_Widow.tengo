---script_widow_Monster---
resetVars := func() {
    scriptVars["phase"] = 1
    scriptVars["timeSinceVenomPool"] = 3.0
    scriptVars["timeSinceWebShot"] = 0.0
    scriptVars["timeSinceSpiderCall"] = 10.0
    scriptVars["timeSinceRapidFire"] = 0.0
    scriptVars["timeSinceRush"] = 0.0
    scriptVars["timeSinceWebWall"] = 0.0
    scriptVars["timeSinceMultiShot"] = 0.0
    scriptVars["timeSinceSpinningWeb"] = 0.0
}

if !isDead {
    if is_undefined(scriptVars["phase"]) {
        resetVars()
    }

    if targetEntityId > 0 {
        currentHealth := float(getPoints(myEntityId, "hp", "current"))
        maxHealth := float(getPoints(myEntityId, "hp", "max"))

        // Phase transitions
        if currentHealth < maxHealth * 0.66 && scriptVars["phase"] == 1 {
            scriptVars["phase"] = 2
            clearBulletsForEntity(myEntityId)
        } else if currentHealth < maxHealth * 0.33 && scriptVars["phase"] == 2 {
            scriptVars["phase"] = 3
            clearBulletsForEntity(myEntityId)
        }

        // Update all timers
        scriptVars["timeSinceVenomPool"] += delta
        scriptVars["timeSinceWebShot"] += delta
        scriptVars["timeSinceSpiderCall"] += delta
        scriptVars["timeSinceRapidFire"] += delta
        scriptVars["timeSinceRush"] += delta
        scriptVars["timeSinceWebWall"] += delta
        scriptVars["timeSinceMultiShot"] += delta
        scriptVars["timeSinceSpinningWeb"] += delta

        if castingAction == 0 {
            if scriptVars["phase"] == 1 {
                // Phase 1: Basic attacks and web patterns
                if scriptVars["timeSinceVenomPool"] > 4.0 {
                    useAbilityAtPosition(myEntityId, "Widow Venom Pool", randomPositionInCurrentRoom(myEntityId, 3.0))
                    scriptVars["timeSinceVenomPool"] = 0.0
                }
                if scriptVars["timeSinceWebShot"] > 2.0 {
                    useAbilityAtTarget(myEntityId, "Widow Web Shot", targetEntityId, 1.0)
                    scriptVars["timeSinceWebShot"] = 0.0
                }
                if scriptVars["timeSinceSpiderCall"] > 15.0 {
                    useAbilityAtPosition(myEntityId, "Widow Spider Call", entityPosition(myEntityId))
                    scriptVars["timeSinceSpiderCall"] = 0.0
                }
                if scriptVars["timeSinceRapidFire"] > 3.0 {
                    useAbilityAtTarget(myEntityId, "Widow Rapid Fire", targetEntityId, 2.0)
					useAbilityAtPosition(myEntityId, "Widow Rapid Fire", entityPosition(myEntityId), randomPositionInCurrentRoom(myEntityId, 3.0))
					useAbilityAtPosition(myEntityId, "Widow Rapid Fire", entityPosition(myEntityId), randomPositionInCurrentRoom(myEntityId, 3.0))
					useAbilityAtPosition(myEntityId, "Widow Rapid Fire", entityPosition(myEntityId), randomPositionInCurrentRoom(myEntityId, 3.0))
                    scriptVars["timeSinceRapidFire"] = 0.0
                }
            } else if scriptVars["phase"] == 2 {
                // Phase 2: More aggressive attacks and patterns
                if scriptVars["timeSinceRush"] > 6.0 {
                    useAbilityAtTarget(myEntityId, "Widow Phase Two Rush", targetEntityId, 1.0)
                    scriptVars["timeSinceRush"] = 0.0
                }
                // if scriptVars["timeSinceWebWall"] > 4.0 {
                //     useAbilityAtPosition(myEntityId, "Phase Two Web", entityPosition(myEntityId))
                //     scriptVars["timeSinceWebWall"] = 0.0
                // }
                if scriptVars["timeSinceVenomPool"] > 3.0 {
                    useAbilityAtPosition(myEntityId, "Widow Phase Two Venom", randomPositionInCurrentRoom(myEntityId, 2.0))
                    scriptVars["timeSinceVenomPool"] = 0.0
                }
                if scriptVars["timeSinceMultiShot"] > 2.5 {
                    useAbilityAtTarget(myEntityId, "Widow Multi Shot", targetEntityId, 1.0)
                    scriptVars["timeSinceMultiShot"] = 0.0
                }
				if scriptVars["timeSinceRapidFire"] > 3.0 {
                    useAbilityAtTarget(myEntityId, "Widow Rapid Fire", targetEntityId, 2.0)
					useAbilityAtPosition(myEntityId, "Widow Rapid Fire", entityPosition(myEntityId), randomPositionInCurrentRoom(myEntityId, 3.0))
					useAbilityAtPosition(myEntityId, "Widow Rapid Fire", entityPosition(myEntityId), randomPositionInCurrentRoom(myEntityId, 3.0))
					useAbilityAtPosition(myEntityId, "Widow Rapid Fire", entityPosition(myEntityId), randomPositionInCurrentRoom(myEntityId, 3.0))
                    scriptVars["timeSinceRapidFire"] = 0.0
                }
            } else {
                // Phase 3: Most dangerous attacks and combinations
                if scriptVars["timeSinceSpinningWeb"] > 5.0 {
                    useAbilityAtPosition(myEntityId, "Widow Phase Three Storm", entityPosition(myEntityId))
                    scriptVars["timeSinceSpinningWeb"] = 0.0
                }
                if scriptVars["timeSinceVenomPool"] > 3.0 {
                    useAbilityAtPosition(myEntityId, "Widow Phase Three Pool", randomPositionInCurrentRoom(myEntityId, 4.0))
                    scriptVars["timeSinceVenomPool"] = 0.0
                }
                if scriptVars["timeSinceRush"] > 4.0 {
                    useAbilityAtPosition(myEntityId, "Widow Phase Three Burst", randomPositionInCurrentRoom(myEntityId, 6.0))
                    scriptVars["timeSinceRush"] = 0.0
                }
                if scriptVars["timeSinceWebWall"] > 8.0 {
                    useAbilityAtPosition(myEntityId, "Widow Phase Three Finale", entityPosition(myEntityId))
                    scriptVars["timeSinceWebWall"] = 0.0
                }
				if scriptVars["timeSinceRapidFire"] > 3.0 {
                    useAbilityAtTarget(myEntityId, "Widow Rapid Fire", targetEntityId, 2.0)
					useAbilityAtPosition(myEntityId, "Widow Rapid Fire", entityPosition(myEntityId), randomPositionInCurrentRoom(myEntityId, 3.0))
					useAbilityAtPosition(myEntityId, "Widow Rapid Fire", entityPosition(myEntityId), randomPositionInCurrentRoom(myEntityId, 3.0))
					useAbilityAtPosition(myEntityId, "Widow Rapid Fire", entityPosition(myEntityId), randomPositionInCurrentRoom(myEntityId, 3.0))
                    scriptVars["timeSinceRapidFire"] = 0.0
                }
            }
        }
    }
}
