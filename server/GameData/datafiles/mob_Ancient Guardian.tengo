Duration :: 1.5
Icon :: statusicons_8
Max Stacks :: 1
Time Per Tick :: 1.0
Definitions :: [[Custom:MiniHunterImmunity]]

---script_MiniHunterImmunity_IncomingDamage---
// When this entity takes damage, if it's fromthe Immunity Punish attack, negate the damage.
if damage > 0 && getNameOfAbility(abilityId) == "Immunity Punish" {
	additionalDamage = -1 * damage
}


