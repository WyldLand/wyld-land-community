---script_ancientguardian_Monster---

rand := import("rand")

randPositions := [[7.0,7.0,0.0], [23.0,7.0,0.0], [23.0,23.0,0.0], [7.0,23.0,0.0]]

resetVars := func() {
	scriptVars["phase"] = 1
	scriptVars["timeSinceTurret"] = 0.0
	scriptVars["timeSinceShotgun"] = 0.0
	scriptVars["timeSinceWall"] = 0.0
	scriptVars["timeSinceSpiral"] = 0.0
	scriptVars["timeSinceCross"] = 0.0
	scriptVars["timeSinceRain"] = 0.0
	scriptVars["timeSinceMine"] = 0.0
	scriptVars["timeSinceStorm"] = 0.0
	scriptVars["timeSinceFinale"] = 0.0
	scriptVars["timeSinceImmunityCycle"] = 0.0
	scriptVars["saidHello"] = false
}

if !isDead {
	if is_undefined(scriptVars["phase"]) {
		resetVars()
	}

	if targetEntityId > 0 {

		if !scriptVars["saidHello"] {
			scriptVars["saidHello"] = true
			say(myEntityId, "Containment breach. Containment breach. Lethal force authorized.")
		}

		currentHealth := float(getPoints(myEntityId, "hp", "current"))
		maxHealth := float(getPoints(myEntityId, "hp", "max"))

		// Phase transitions
		if currentHealth < maxHealth * 0.66 && scriptVars["phase"] == 1 {
			clearBulletsForEntity(myEntityId)
			scriptVars["phase"] = 2
			say(myEntityId, "Program response initiated. Containment sequence A004.")
		} else if currentHealth < maxHealth * 0.33 && scriptVars["phase"] == 2 {
			say(myEntityId, "Emergency reactive measures authorized. Directive override.")
			clearBulletsForEntity(myEntityId)
			scriptVars["phase"] = 3
		}

		// Update timers
		scriptVars["timeSinceTurret"] += delta
		scriptVars["timeSinceShotgun"] += delta
		scriptVars["timeSinceWall"] += delta  
		scriptVars["timeSinceSpiral"] += delta
		scriptVars["timeSinceCross"] += delta
		scriptVars["timeSinceRain"] += delta
		scriptVars["timeSinceMine"] += delta
		scriptVars["timeSinceStorm"] += delta
		scriptVars["timeSinceFinale"] += delta
		scriptVars["timeSinceImmunityCycle"] += delta

		// Phase 1: Six evenly spaced turrets + shotgun patterns
		if scriptVars["phase"] == 1 {
			if scriptVars["timeSinceTurret"] > 2.0 {
				// Place 6 turrets around the room
				useAbilityAtPosition(myEntityId, "Phase One Turrets", 
					positionInCurrentRoom(myEntityId, [6.0,6.0,0.0]))
				useAbilityAtPosition(myEntityId, "Phase One Turrets",
					positionInCurrentRoom(myEntityId, [26.0,6.0,0.0]))
				useAbilityAtPosition(myEntityId, "Phase One Turrets",
					positionInCurrentRoom(myEntityId, [6.0,16.0,0.0]))
				useAbilityAtPosition(myEntityId, "Phase One Turrets",
					positionInCurrentRoom(myEntityId, [26.0,16.0,0.0]))
				useAbilityAtPosition(myEntityId, "Phase One Turrets",
					positionInCurrentRoom(myEntityId, [6.0,26.0,0.0]))
				useAbilityAtPosition(myEntityId, "Phase One Turrets",
					positionInCurrentRoom(myEntityId, [26.0,26.0,0.0]))
				scriptVars["timeSinceTurret"] = 0.0
			}
			
			if scriptVars["timeSinceShotgun"] > 2.0 {
				useAbilityAtTarget(myEntityId, "Phase One Shotgun", targetEntityId, 1.0)
				scriptVars["timeSinceShotgun"] = 0.0
			}
		} else if scriptVars["phase"] == 2 {
		
		// Phase 2: Multiple simultaneous patterns
		
			if scriptVars["timeSinceWall"] > 3.0 {
				useAbilityAtPosition(myEntityId, "Phase Two Walls", 
					positionInCurrentRoom(myEntityId, [16.0,16.0,0.0]))
				scriptVars["timeSinceWall"] = 0.0
			}
			
			if scriptVars["timeSinceSpiral"] > 3.5 {
				useAbilityAtPosition(myEntityId, "Phase Two Spiral",
					positionInCurrentRoom(myEntityId, [16.0,16.0,0.0]))
				scriptVars["timeSinceSpiral"] = 0.0
			}
			
			if scriptVars["timeSinceCross"] > 4.0 {
				useAbilityAtPosition(myEntityId, "Phase Two Cross",
					positionInCurrentRoom(myEntityId, [16.0,16.0,0.0]))
				scriptVars["timeSinceCross"] = 0.0
			}

			// Added consistent bullet rain for more pressure
			if scriptVars["timeSinceMine"] > 2.0 {
				for i := 0; i < 3; i++ {
					useAbilityAtPosition(myEntityId, "Phase Three Mines",
						randomPositionInCurrentRoom(myEntityId, 2.0))
				}
				scriptVars["timeSinceMine"] = 0.0
			}

			if scriptVars["timeSinceImmunityCycle"] > 20.0 {
				//Every 20 seconds, we will generate a random "good zone" on the ground where the player needs to go/
				//Players inside of the green zone when the time expires are protected from the following room-wide Punish explosion.
				say(myEntityId, "Cleanse cycle engaged. All personnel should proceed to the safety area.")
				pos := positionInCurrentRoom(myEntityId, randPositions[rand.intn(4)])
				useAbilityAtPosition(myEntityId, "Immunity Pool", pos)
				useAbilityAtPosition(myEntityId, "Immunity Punish", entityPosition(myEntityId))
				scriptVars["timeSinceImmunityCycle"] = 0.0
			}

		} else if scriptVars["phase"] == 3 {

		
		// Phase 3: All the things
			// Corner turrets from phase 1
			if scriptVars["timeSinceTurret"] > 2.5 {
				useAbilityAtPosition(myEntityId, "Phase Three Turrets",
					positionInCurrentRoom(myEntityId, [4.0,4.0,0.0]))
				useAbilityAtPosition(myEntityId, "Phase Three Turrets",
					positionInCurrentRoom(myEntityId, [28.0,4.0,0.0]))
				useAbilityAtPosition(myEntityId, "Phase Three Turrets",
					positionInCurrentRoom(myEntityId, [4.0,28.0,0.0]))
				useAbilityAtPosition(myEntityId, "Phase Three Turrets",
					positionInCurrentRoom(myEntityId, [28.0,28.0,0.0]))
				scriptVars["timeSinceTurret"] = 0.0
			}

			if scriptVars["timeSinceMine"] > 2.0 {
				for i := 0; i < 3; i++ {
					useAbilityAtPosition(myEntityId, "Phase Three Mines",
						randomPositionInCurrentRoom(myEntityId, 2.0))
				}
				scriptVars["timeSinceMine"] = 0.0
			}
			
			if scriptVars["timeSinceStorm"] > 3.0 {
				useAbilityAtPosition(myEntityId, "Phase Three Storm",
					positionInCurrentRoom(myEntityId, [16.0,16.0,0.0]))
				scriptVars["timeSinceStorm"] = 0.0
			}
			
			if scriptVars["timeSinceFinale"] > 5.0 {
				useAbilityAtPosition(myEntityId, "Phase Three Finale",
					positionInCurrentRoom(myEntityId, [16.0,16.0,0.0]))
				scriptVars["timeSinceFinale"] = 0.0
			}

			if scriptVars["timeSinceImmunityCycle"] > 20.0 {
				//Every 20 seconds, we will generate a random "good zone" on the ground where the player needs to go/
				//Players inside of the green zone when the time expires are protected from the following room-wide Punish explosion.
				say(myEntityId, "Cleanse cycle engaged. All personnel should proceed to the safety area.")
				pos := positionInCurrentRoom(myEntityId, randPositions[rand.intn(4)])
				useAbilityAtPosition(myEntityId, "Immunity Pool", pos)
				useAbilityAtPosition(myEntityId, "Immunity Punish", entityPosition(myEntityId))
				scriptVars["timeSinceImmunityCycle"] = 0.0
			}
		}
	}
}
