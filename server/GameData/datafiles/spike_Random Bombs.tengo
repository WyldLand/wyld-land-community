---bulletdef_smallpool1---
sprite CirclePool 0.5
potency 150
fire 5 absolute 0
	aoeexplosion
	radius 0.5
	timedFill 15
	damageEvery 15
	wait 15
	vfx BombExplosion 3
	vanish

