---spike_Random Bombs---
Auras :: [[Random Bombs]]
Rarity :: Legendary
Archetypes :: [[ExplosiveLauncher]]

---aura_Random Bombs---
Type :: Buff
Duration :: -1
Icon :: 
Max Stacks :: 1
Time Per Tick :: 1.0
Definitions :: [[Custom:PoolSpawner]]

---script_PoolSpawner_DamageDealt---
rand := import("rand")

if auraAbilityId == abilityId {
    // 30% chance to spawn pools
    if rand.float() < 0.30 {
        // Get the position of the enemy that was hit
        enemyPosition := entityPosition(damageSenderId)
        
        // Spawn multiple small circle pools around the enemy position
        useAbilityAtPosition(myEntityId, "Spawn Pool 1", enemyPosition, enemyPosition)
        useAbilityAtPosition(myEntityId, "Spawn Pool 2", enemyPosition, enemyPosition)
        useAbilityAtPosition(myEntityId, "Spawn Pool 3", enemyPosition, enemyPosition)
        useAbilityAtPosition(myEntityId, "Spawn Pool 4", enemyPosition, enemyPosition)
        useAbilityAtPosition(myEntityId, "Spawn Pool 5", enemyPosition, enemyPosition)
    }
}

