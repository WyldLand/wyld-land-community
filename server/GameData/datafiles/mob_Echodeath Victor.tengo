---bulletdef_doomRoomDamage---
sprite Invisible
potency 0
fire 0 relative 0
	wait 1
	script DealRoomDamage
	vanish

---script_DealRoomDamage_BulletScript---
// Get all entities in the current room
currentRoom := entityRoom(myEntityId)
nearby := getNearbyEntities(myEntityId)

// Iterate through all nearby entities
for i := 0; i < len(nearby); i++ {
    // Check if the entity is a player and in the same room
    if nearby[i].isPlayer && entityRoom(nearby[i].id) == currentRoom {
        // Deal massive damage to the player
        dealPotencyToEntity(myEntityId, nearby[i].id, 50000, bulletAbilityId)
    }
}

