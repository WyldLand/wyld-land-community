        if scriptVars["timeSinceBombBuff"] >= 70.0 {
            log("RANDOM BOMB BUFF")
            useAbilityAtPosition(myEntityId, "Random Bomb Buff", entityPosition(myEntityId))
            scriptVars["timeSinceBombBuff"] = 0
        }

        // Function to check if a specific tower type exists and is alive in the game
        checkForTower := func(towerName) {
            nearby := getNearbyEntities(myEntityId)
            towerExists := false
            
            for i := 0; i < len(nearby); i++ {
                entity := nearby[i]
                
                // Check if this entity matches our tower name AND is still alive
                if entity.mobid == towerName && !isEntityDead(entity.id) {
                    towerExists = true
                    break
                }
            }
            
            return towerExists
        }

        // Check for Tower One and spawn if it doesn't exist or is dead
        if !checkForTower("raidexplosiontowerone") {
           // log("Spawning Tower One")
           useAbilityAtPosition(myEntityId, "Spawn Tower One", entityPosition(myEntityId))
        } 

        // Check for Tower Two and spawn if it doesn't exist or is dead
        if !checkForTower("raidexplosiontowertwo") {
           // log("Spawning Tower Two")
           useAbilityAtPosition(myEntityId, "Spawn Tower Two", entityPosition(myEntityId))
        } 

        
        // Bomb Spawn logic - spawn a bomb every 35 seconds
        if scriptVars["bombSpawnTimer"] >= 35.0 {
            useAbilityAtPosition(myEntityId, "Spawn Bomb", entityPosition(myEntityId))
            scriptVars["bombSpawnTimer"] = 0.0
        }

        if scriptVars["timeSinceBigAttack"] > 12.0 {
            useAbilityAtPosition(myEntityId, "Ethereal Convergence", entityPosition(myEntityId))
            scriptVars["timeSinceBigAttack"] = 0.0
        }
        
    }
}