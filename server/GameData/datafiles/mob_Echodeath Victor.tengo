       killEntityIfEntityDies(newEntityId, myEntityId)
    }
}

---ability_Spawn Tower One---
Script :: SpawnTowerOne

---script_SpawnTowerOne_Cast---
if frameNum == 0 {
    rand := import("rand")
    entityTypes := ["raidexplosiontowerone"]
    selectedType := entityTypes[rand.intn(len(entityTypes))]
    
    spawnPositions := [
         positionInCurrentRoom(myEntityId,[86.0, 44.0, 0.0]),
         positionInCurrentRoom(myEntityId,[64.0, 20.0, 0.0]),
         positionInCurrentRoom(myEntityId,[16.0, 58.0, 0.0]),
         positionInCurrentRoom(myEntityId,[32.0, 16.0, 0.0]),
         positionInCurrentRoom(myEntityId,[79.0, 42.0, 0.0])
    ]
    
    // Randomly select one position from the array
    randomIndex := rand.intn(len(spawnPositions))
    randomPosition := spawnPositions[randomIndex]
    
    // Summon only one entity at the randomly chosen position
    newEntityId := summonEntity(selectedType, randomPosition, monsterLevel(myEntityId))
    killEntityIfEntityDies(newEntityId, myEntityId)
}

---script_collectorbombone_Monster---
if is_undefined(scriptVars["bossId"]) {
    nearby := getNearbyEntities(myEntityId)
    for i := 0; i < len(nearby); i++ {
        if nearby[i].mobid == "raidexplosiontowerone" {
            scriptVars["bossId"] = nearby[i].id
            break
        }
    }
}

if is_undefined(scriptVars["didDie"]) {
    scriptVars["didDie"] = false
}

// Only proceed if we found a boss and haven't already died
if !is_undefined(scriptVars["bossId"]) && !scriptVars["didDie"] {
    
    // Check if the boss is dead - if so, explode and die
    if isEntityDead(scriptVars["bossId"]) {
        useAbilityAtPosition(myEntityId, "Spider Bomb Raid", entityPosition(myEntityId))
        scriptVars["didDie"] = true
        killEntity(myEntityId)
    } else {
        // Boss is still alive, so move toward it
        bossPos := entityPosition(scriptVars["bossId"])
        pathTo(myEntityId, bossPos)
        
        // Explode if we get close enough to the boss
        if distToPoint(myEntityId, bossPos) < 3.0 {
            useAbilityAtPosition(myEntityId, "Spider Bomb Raid", entityPosition(myEntityId))
            scriptVars["didDie"] = true
            killEntity(myEntityId)
        }
    }
}
---mobdefinition_Raid Explosion Tower One---
ID :: raidexplosiontowerone
Prefab :: echodeathtower
Range Behavior :: [[Stationary]]
Abilities :: [[Spawn Minions One]]
Bounding Box :: 0 2.73 2.5 3.0
Type :: Elite
Speed :: 0
Options :: alwaysattack

---script_raidexplosiontowerone_Monster---
resetVars := func() {
    scriptVars["firstFrame"] = true
    scriptVars["timeSinceSpawn"] = 0.0
    scriptVars["lastSummonTime"] = 0.0
    scriptVars["hasDied"] = false
    scriptVars["timeSinceTeleport"] = 0.0
    scriptVars["teleportIndex"] = 0
    scriptVars["timeSinceProgressUpdate"] = 0.0
    
    // Define predefined teleport locations
    // These should be coordinates within your current room
    scriptVars["teleportLocations"] = [
        [64.0, 20.0, 0.0],
        [16.0, 58.0, 0.0],
        [32.0, 16.0, 0.0],
        [79.0, 42.0, 0.0]
    ]
}

doExplosion := func() {
	currentNearby := getNearbyEntities(myEntityId)
	for i := 0; i < len(currentNearby); i++ {
		if isEnemyOfEntity(myEntityId, currentNearby[i].id) {
            maxHealth := float(getPoints(currentNearby[i].id, "hp", "max"))
            damageToDeal := int(maxHealth * 0.4)
            attackEntity(myEntityId,  currentNearby[i].id, damageToDeal, -99)
            log(damageToDeal)
		}
	}
}

if is_undefined(scriptVars["timeSinceSpawn"]) {
    resetVars()
}

if isDead && !scriptVars["hasDied"] {
    doExplosion()
    say(myEntityId, "Tower Destroyed")
    scriptVars["hasDied"] = true
}

if !isDead {
    scriptVars["timeSinceSpawn"] += delta
    scriptVars["lastSummonTime"] += delta
    scriptVars["timeSinceTeleport"] += delta
    scriptVars["timeSinceProgressUpdate"] += delta
    
    // Check if it's time to teleport (every 25 seconds)
    if scriptVars["timeSinceTeleport"] >= 35.0 {
        // Reset the timer
        scriptVars["timeSinceTeleport"] = 0.0
        
        // Move to the next location in the predefined list
        scriptVars["teleportIndex"] = (scriptVars["teleportIndex"] + 1) % len(scriptVars["teleportLocations"])
        
        // Get the new position
        newPosition := positionInCurrentRoom(myEntityId, scriptVars["teleportLocations"][scriptVars["teleportIndex"]])
        
        // Teleport the entity to the new position
        setPosition(myEntityId, newPosition)
        
    }

    if scriptVars["timeSinceSpawn"] > 5.0 {
        useAbilityAtPosition(myEntityId, "Spawn Minions One", entityPosition(myEntityId))
        scriptVars["timeSinceSpawn"] = 0.0
    }

    if scriptVars["timeSinceProgressUpdate"] > 0.5 {
        healthPct := float(getPoints(myEntityId, "hp", "current")) / float(getPoints(myEntityId, "hp", "max"))
        setProgressBar(myEntityId, "towerone", "Tower One Health", healthPct)
        scriptVars["timeSinceProgressUpdate"] = 0.0
    }
}


