---ability_Spawn Bomb---
Script :: SpawnBomb

---script_SpawnBomb_Cast---
if frameNum == 0 {
    rand := import("rand")
    bombSpawned := false
    
    // Define possible spawn positions
    spawnPositions := [
        positionInCurrentRoom(myEntityId, [71.0, 21.0, 0.0]),
        positionInCurrentRoom(myEntityId, [64.0, 75.0, 0.0]),
        positionInCurrentRoom(myEntityId, [60.0, 46.0, 0.0]),
        positionInCurrentRoom(myEntityId, [8.0, 22.0, 0.0])
    ]
    
    // Select a random position from the array
    selectedPosition := spawnPositions[rand.intn(len(spawnPositions))]
    
    // Spawn the Echodeath Raidbomb at the selected position
    if !bombSpawned {
            log("SPAWN BOMB")
            newEntityId := summonEntity("echodeathraidbomb", selectedPosition, monsterLevel(myEntityId))
            killEntityIfEntityDies(newEntityId, myEntityId)
             bombSpawned := true
    }

}

