---ability_Spider Bomb Raid---
Bullet Definition :: [[spiderbombraid]]
Lock Time :: 1.0
VFX Cast :: trigger:Dig

---bulletdef_spiderbombraid---
sprite CirclePool 7
potency 1000
fire 0 relative 0
	aoeexplosion
	damageFriendly
	radius 2
	timedFill 3
	damageEvery 3
	wait 1
	vfx BombExplosion 5
	wait 1
	vfx ShakeLarge 5
	vanish
sprite Invisible
potency 300
fire 0 relative 0
	aoeexplosion
	radius 2
	damageEvery 3
	wait 4
	vanish

---script_echodeathraidbomb_Monster---
if is_undefined(scriptVars["hasSpawnedDoomCircle"]) {
    scriptVars["hasSpawnedDoomCircle"] = false
    scriptVars["timeTillDoomCircle"] = 0
    scriptVars["timeSinceDoomCircle"] = 0
    scriptVars["timeSinceSpawned"] = 0
    scriptVars["timeSinceProgress"] = 0.0
}

doExplosion := func() {
	currentNearby := getNearbyEntities(myEntityId)
	for i := 0; i < len(currentNearby); i++ {
		if isEnemyOfEntity(myEntityId, currentNearby[i].id) {
            maxHealth := float(getPoints(currentNearby[i].id, "hp", "max"))
            damageToDeal := int(maxHealth * 0.4)
            attackEntity(myEntityId,  currentNearby[i].id, damageToDeal, -99)
            log(damageToDeal)
		}
	}
}

if isDead {    
    // Clear all bullets
    clearBulletsForEntity(myEntityId)
}

if !isDead {

    scriptVars["timeTillDoomCircle"] += delta
    scriptVars["timeSinceSpawned"] += delta
    scriptVars["timeSinceProgress"] += delta

    // Cast Doom Circle immediately upon spawning
    if !scriptVars["hasSpawnedDoomCircle"] && scriptVars["timeTillDoomCircle"] >= 1 {
        useAbilityAtPosition(myEntityId, "Echoblight Doom Circle", entityPosition(myEntityId))
        scriptVars["hasSpawnedDoomCircle"] = true
    }

    if  scriptVars["timeSinceSpawned"] >= 25.0 {
        doExplosion()
        say(myEntityId, "Bomb Exploded")
        scriptVars["didDie"] = true
        killEntity(myEntityId)
    }
    
    // Add an aura to check for invulnerability
    if len(getAurasOnEntity(myEntityId)) == 0 {
        addAuraToEntity(myEntityId, "Bomb Immunity", 0, myEntityId)
    }

    if scriptVars["timeSinceProgress"] > 0.5 {
        scriptVars["timeSinceProgress"] = 0.0
        setProgressBar(myEntityId, "bomb", "Bomb Timer", 1.0 - (scriptVars["timeSinceSpawned"] / 25.0))
    }
}

---aura_Bomb Immunity---
Type :: Buff
Duration :: -1
Max Stacks :: 1
Time Per Tick :: 1.0
Definitions :: [[Custom:BombImmunity]]

---script_BombImmunity_IncomingDamage---
// Check if the damage sender has the Bomb Attacker
hasBombBuff := false
senderAuras := getAurasOnEntity(damageSenderId)

for i := 0; i < len(senderAuras); i++ {
    if senderAuras[i]["name"] == "Bomb Attacker" {
        hasBombBuff = true
        break
    }
}

// If the player doesn't have the bomb buff, make the entity invulnerable
if !hasBombBuff {
    additionalDamage = -1 * damage
    
    // Optional: Display a visual effect to show immunity
    showVfxAtPosition(myEntityId, "Shield", entityPosition(myEntityId))
}

---script_echodeathvictor_Monster---
// Function to check if an entity has an aura with the given name
hasAuraByName := func(entityId, auraName) {
    auras := getAurasOnEntity(entityId)
    for i := 0; i < len(auras); i++ {
        if auras[i]["name"] == auraName {
            return true
        }
    }
    return false
}

resetVars := func() {
    scriptVars["firstFrame"] = true
    scriptVars["timeSinceSpawn"] = 2.0
    scriptVars["lastSummonTime"] = 0.0
    scriptVars["toweronespawn"] = true
    scriptVars["towertwospawn"] = true
    scriptVars["doomCircleTimer"] = 0.0
    scriptVars["hasCastDoomCircle"] = false
    scriptVars["bombSpawnTimer"] = 33.0
    scriptVars["astralConvergenceTimer"] = 0.0
    scriptVars["astralNodeTimer"] = 0.0
    scriptVars["fractureWaveTimer"] = 0.0
    scriptVars["minionSpawnTimer"] = 3.0
    scriptVars["timeSinceBombBuff"] = 68.0
    scriptVars["timeSinceBigAttack"] = 0.0

    scriptVars["inPhaseTransition"] = false
    scriptVars["phaseTransitionTimer"] = 0.0
    scriptVars["phaseTransitionDuration"] = 3.0  // 3 seconds of invulnerability during transitions

    // Phase tracking
    scriptVars["currentPhase"] = 1
    scriptVars["phaseChangeHP"] = 0.5  // 50% health triggers phase 2
    
    // Phase 2 specific variables - initialize but leave empty
    scriptVars["phase2FirstFrame"] = true
    scriptVars["phase2Timer"] = 0.0
    
    // Phase 3 specific variables
    scriptVars["phase3FirstFrame"] = true
    scriptVars["phase3Timer"] = 0.0
}

doExplosion := func() {
	currentNearby := getNearbyEntities(myEntityId)
	for i := 0; i < len(currentNearby); i++ {
		if isEnemyOfEntity(myEntityId, currentNearby[i].id) {
            maxHealth := float(getPoints(currentNearby[i].id, "hp", "max"))
            damageToDeal := int(maxHealth * 0.4)
            attackEntity(myEntityId,  currentNearby[i].id, damageToDeal, -99)
            log(damageToDeal)
		}
	}
}

// Function to check if any raid bombs are active in the game
hasActiveRaidBomb := func() {
    nearby := getNearbyEntities(myEntityId)
    for i := 0; i < len(nearby); i++ {
        if nearby[i].mobid == "echodeathraidbomb" && !isEntityDead(nearby[i].id) {
            return true
        }
    }
    return false
}

if !isDead {
    if is_undefined(scriptVars["timeSinceSpawn"]) {
        resetVars()
    }

    // Check if any raid bombs are active
    hasActiveBomb := hasActiveRaidBomb()
    
    // Apply or remove invulnerability based on whether bombs are active
    if hasActiveBomb {
        // Make ONLY the boss invulnerable when bombs are active
        if !hasAuraByName(myEntityId, "Sovereign Invulnerability") {
            // Only add immunity to the boss (this entity), not players
            addAuraToEntity(myEntityId, "Sovereign Invulnerability", 0, myEntityId)
        }
    } else {
        // Remove invulnerability when no bombs are active
        if hasAuraByName(myEntityId, "Sovereign Invulnerability") {
            dispelAuraOnEntity(myEntityId, "Sovereign Invulnerability")
        }
    }



    if scriptVars["firstFrame"] {
        setPosition(myEntityId, positionInCurrentRoom(myEntityId, [48.0, 44.0, 0.0]))
        scriptVars["firstFrame"] = false
    }

    if targetEntityId > 0 {

        scriptVars["timeSinceBombBuff"] += delta
        scriptVars["timeSinceSpawn"] += delta
        scriptVars["lastSummonTime"] += delta
        scriptVars["doomCircleTimer"] += delta
        scriptVars["bombSpawnTimer"] += delta
        scriptVars["minionSpawnTimer"] += delta
        scriptVars["astralConvergenceTimer"] += delta
        scriptVars["astralNodeTimer"] += delta
        scriptVars["fractureWaveTimer"] += delta
        scriptVars["timeSinceBigAttack"] += delta
        
        // Check for phase transitions
        currentHealth := float(getPoints(myEntityId, "hp", "current"))
        maxHealth := float(getPoints(myEntityId, "hp", "max"))
        healthPercent := currentHealth / maxHealth

        // Phase transition logic - transition at 2/3 and 1/3 health
        if healthPercent <= 0.67 && scriptVars["currentPhase"] == 1 {
            // Transition to phase 2 when boss loses first third of health
            scriptVars["currentPhase"] = 2
            scriptVars["phase2FirstFrame"] = true
            
            // Start phase transition state
            scriptVars["inPhaseTransition"] = true
            scriptVars["phaseTransitionTimer"] = 0.0
            
            // Add invulnerability
            addAuraToEntity(myEntityId, "Sovereign Invulnerability", 0, myEntityId)
            
            // Clear all bullets to give players a clean slate for phase 2
            clearBulletsForEntity(myEntityId)
            
            // Optionally announce the phase change to players
            say(myEntityId, "You think you can defeat me? Now witness my true power!")
        } else if healthPercent <= 0.33 && scriptVars["currentPhase"] == 2 {
            // Transition to phase 3 when boss loses second third of health
            scriptVars["currentPhase"] = 3
            scriptVars["phase3FirstFrame"] = true
            
            // Start phase transition state
            scriptVars["inPhaseTransition"] = true
            scriptVars["phaseTransitionTimer"] = 0.0
            
            // Add invulnerability
            addAuraToEntity(myEntityId, "Sovereign Invulnerability", 0, myEntityId)
            
            // Clear all bullets again for phase 3
            clearBulletsForEntity(myEntityId)
            
            // Optionally announce the phase 3 transition
            say(myEntityId, "My final form shall be your doom!")
        }

        if scriptVars["currentPhase"] == 1 {
            // Phase 1 logic
            if scriptVars["fractureWaveTimer"] >= 6.0 {
                useAbilityAtPosition(myEntityId, "Fracture Wave", entityPosition(myEntityId))
                scriptVars["fractureWaveTimer"] = 0.0
                say(myEntityId, "Fracture Wave!")
            }
            
            if scriptVars["timeSinceSpawn"] >= 4.0 {
                
                // First row (10 pools)
                useAbilityAtPosition(myEntityId, "Room Catastrophe Circle Pool 1", positionInCurrentRoom(myEntityId, [10.0, 10.0, 0.0]))
                useAbilityAtPosition(myEntityId, "Room Catastrophe Circle Pool 1", positionInCurrentRoom(myEntityId, [19.0, 10.0, 0.0]))
                useAbilityAtPosition(myEntityId, "Room Catastrophe Circle Pool 1", positionInCurrentRoom(myEntityId, [28.0, 10.0, 0.0]))
                useAbilityAtPosition(myEntityId, "Room Catastrophe Circle Pool 1", positionInCurrentRoom(myEntityId, [37.0, 10.0, 0.0]))
                useAbilityAtPosition(myEntityId, "Room Catastrophe Circle Pool 1", positionInCurrentRoom(myEntityId, [46.0, 10.0, 0.0]))
                useAbilityAtPosition(myEntityId, "Room Catastrophe Circle Pool 1", positionInCurrentRoom(myEntityId, [55.0, 10.0, 0.0]))
                useAbilityAtPosition(myEntityId, "Room Catastrophe Circle Pool 1", positionInCurrentRoom(myEntityId, [64.0, 10.0, 0.0]))
                useAbilityAtPosition(myEntityId, "Room Catastrophe Circle Pool 1", positionInCurrentRoom(myEntityId, [73.0, 10.0, 0.0]))
                useAbilityAtPosition(myEntityId, "Room Catastrophe Circle Pool 1", positionInCurrentRoom(myEntityId, [82.0, 10.0, 0.0]))
                useAbilityAtPosition(myEntityId, "Room Catastrophe Circle Pool 1", positionInCurrentRoom(myEntityId, [91.0, 10.0, 0.0]))

                // Second row (10 pools)
                useAbilityAtPosition(myEntityId, "Room Catastrophe Circle Pool 1", positionInCurrentRoom(myEntityId, [10.0, 18.0, 0.0]))
                useAbilityAtPosition(myEntityId, "Room Catastrophe Circle Pool 1", positionInCurrentRoom(myEntityId, [19.0, 18.0, 0.0]))
