	wait 60
	vanish

---script_grantbombbuff_BulletHit---
// Apply the bomb buff to any player that touches this
if hitLayer == CollisionLayerPlayer {
    // Add the buff to the entity that was hit
    addAuraToEntity(myEntityId, "Bomb Attacker", abilityId, hitEntityId)
    
    // Show a visual effect
    showVfxAtPosition(hitEntityId, "PowerStrike", entityPosition(hitEntityId))
}

---aura_Bomb Attacker---
Type :: Buff
Duration :: 70.0
Icon :: statusicons_7
Max Stacks :: 1
Time Per Tick :: 1.0
Definitions :: [[Custom:BombAttackBuff]]

---ability_Random Bomb Buff---
Script :: RandomBombBuff

---script_RandomBombBuff_Cast---
if frameNum == 0 {
    
    // Get all nearby entities
    nearby := getNearbyEntities(myEntityId)
    
    playerEntities := []
    
    for i := 0; i < len(nearby); i++ {
        entityId := nearby[i].id
        // Method 1: Check if entity is friendly to us (not an enemy)
        if nearby[i].isEnemy {
            playerEntities = append(playerEntities, entityId)
        }
    }
    
    // If we have at least one player, randomly select up to two to apply the buff
    if len(playerEntities) > 0 {
        rand := import("rand")
        
        // Determine how many players to affect (either all players if fewer than 2, or just 2)
        numToAffect := 2
        if len(playerEntities) < numToAffect {
            numToAffect = len(playerEntities)
        }
        
        
        // Create a copy of the array that we can modify
        availablePlayers := playerEntities
        
        // Apply the buff to the selected number of players
        for i := 0; i < numToAffect; i++ {
            if len(availablePlayers) > 0 {
                // Select a random index
                randomIndex := rand.intn(len(availablePlayers))
                
                // Get the player at that index
                playerId := availablePlayers[randomIndex]
                
                // Apply the buff
                addAuraToEntity(myEntityId, "Bomb Attacker", abilityId, playerId)
                
                // Remove this player from the available list
                if randomIndex < len(availablePlayers)-1 {
                    availablePlayers = append(availablePlayers[:randomIndex], availablePlayers[randomIndex+1:]...)
                } else {
                    availablePlayers = availablePlayers[:randomIndex]
                }
            }
        }
    } else {
        log("Unable to find players to apply buff")
    }
}

