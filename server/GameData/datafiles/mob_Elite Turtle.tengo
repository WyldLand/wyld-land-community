---bulletdef_defensiveshield---
sprite BluePool 3
potency 0
fire 0 relative 0
	aoedot
	radius 3
	damageEvery 0
	wait 100
	vanish

---script_eliteturtle_Monster---
if is_undefined(scriptVars["timeInState"]) {
	scriptVars["timeInState"] = 2.0
	scriptVars["inShell"] = false
	scriptVars["timeSinceBasicAttack"] = 0.5
	scriptVars["timeSinceSpike"] = 0.0
	scriptVars["shellCycles"] = 0
}

if targetEntityId > 0 && !isDead {

	scriptVars["timeInState"] += delta
	scriptVars["timeSinceBasicAttack"] += delta
	scriptVars["timeSinceSpike"] += delta

	// Enhanced shell cycling
	if scriptVars["timeInState"] >= 5.0 {
		scriptVars["timeInState"] = 0.0
		scriptVars["inShell"] = !scriptVars["inShell"]
		
		if scriptVars["inShell"] {
			useAbilityAtPosition(myEntityId, "Shell Pulse Enhanced", entityPosition(myEntityId))
			addAuraToEntity(myEntityId, "Elite Defense", 0, myEntityId)
			scriptVars["shellCycles"] += 1
			
			
		} else {
			useAbilityAtPosition(myEntityId, "Shell Expire Enhanced", entityPosition(myEntityId))
			dispelAuraOnEntity(myEntityId, "Elite Defense")
		}
	}

	// Movement control - slower in shell, but not completely stopped
	if scriptVars["inShell"] {
		setSpeed(myEntityId, 0.0)
	} else {
		setSpeed(myEntityId, 1.0)
	}

	// Basic attack pattern
	if scriptVars["timeSinceBasicAttack"] >= 3.5 {
		useAbilityAtTarget(myEntityId, "Turtle Barrage", targetEntityId, 1.5)
		scriptVars["timeSinceBasicAttack"] = 0.0
	}

	// Spike eruption attack - targets player position
	if scriptVars["timeSinceSpike"] >= 4.0 {
		// Target where the player will likely be
		targetPos := entityPredictedPosition(targetEntityId)
		useAbilityAtPosition(myEntityId, "Spike Eruption", targetPos)
		scriptVars["timeSinceSpike"] = 0.0
	}

	// Every 3rd shell cycle, create multiple spike eruptions
	if scriptVars["shellCycles"] >= 3 && scriptVars["inShell"] && scriptVars["timeInState"] > 2.0 {
		for i := 0; i < 3; i++ {
			spikePos := randomPositionNearby(targetEntityId, 8.0)
			useAbilityAtPosition(myEntityId, "Spike Eruption", spikePos)
		}
		scriptVars["shellCycles"] = 0
	}
}

---aura_Elite Defense---
Type :: Buff
Duration :: -1
Icon :: statusicons_8
Max Stacks :: 1
Time Per Tick :: 1.0
Definitions :: [[Custom:EliteDefense]]

---script_EliteDefense_IncomingDamage---
additionalDamage = -1 * int(damage * 0.20)