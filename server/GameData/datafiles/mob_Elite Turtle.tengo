radial bullets:16 speed:8 angle:0 directionType:absolute
	wait 60
	vanish

---ability_Spike Eruption---
Bullet Definition :: [[spikeeruption]]
Max Range :: 100.0
VFX Cast :: trigger:Attack*

---bulletdef_spikeeruption---
sprite CirclePool 2
potency 150
fire 0 relative 0
	aoeexplosion
	radius 2
	timedFill 30
	damageEvery 30
	wait 30
	vfx SmallBombExplosion 3
	wait 1
	fire spikeburst
	vanish

---bulletdef_spikeburst---
sprite Custom12
potency 100
radial bullets:12 speed:5 angle:0 directionType:absolute
	wait 40
	vanish

---ability_Defensive Shield---
