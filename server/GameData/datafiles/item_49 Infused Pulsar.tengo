---aura_Infused Pulsar Pool---
Type :: Buff
Duration :: -1
Icon :: 
Max Stacks :: 1
Time Per Tick :: 1.0
Definitions :: [[Custom:InfusedPulsarPool]]


---script_InfusedPulsarPool_DamageDealt---
if abilityId == auraAbilityId {
	log("Damage Dealt")
	
	// Initialize pool tracking variables if they don't exist
	if is_undefined(scriptVars["activePools"]) {
		scriptVars["activePools"] = 0
	}
	if is_undefined(scriptVars["poolDecrementTimes"]) {
		scriptVars["poolDecrementTimes"] = []
	}
	
	// Check if we can spawn a new pool (max 3 pools)
	if scriptVars["activePools"] < 3 {
		targetPos := entityPosition(damageSenderId)
		useAbilityAtPosition(myEntityId, "Infused Pulsar Pool", targetPos)
		
		// Increment active pool count
		scriptVars["activePools"] = scriptVars["activePools"] + 1
		
		// Schedule this pool for decrement after 1 second (20 frames at 20fps)
		// Store the global tick when this pool should be decremented
		decrementTime := globalTick + 20
		scriptVars["poolDecrementTimes"] = append(scriptVars["poolDecrementTimes"], decrementTime)
	}
	
	// Process pool decrements - check if any pools have expired
	newDecrementTimes := []
	for i := 0; i < len(scriptVars["poolDecrementTimes"]); i++ {
		if globalTick >= scriptVars["poolDecrementTimes"][i] {
			// This pool has expired, decrement the count
			scriptVars["activePools"] = scriptVars["activePools"] - 1
			if scriptVars["activePools"] < 0 {
				scriptVars["activePools"] = 0
			}
		} else {
			// Pool hasn't expired yet, keep it in the list
			newDecrementTimes = append(newDecrementTimes, scriptVars["poolDecrementTimes"][i])
		}
	}
	scriptVars["poolDecrementTimes"] = newDecrementTimes
}

---ability_Infused Pulsar Pool---
