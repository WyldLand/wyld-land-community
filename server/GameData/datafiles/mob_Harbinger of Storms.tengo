---aura_Harbinger Max HP---
Type :: Buff
Duration :: -1
Max stacks :: 1 
Time Per Tick :: 1.0
Definitions :: [[auraaffectstat/harbingermaxhp]]

---auraaffectstat_harbingermaxhp---
Stat :: Vitality
Boost :: 75.0

---aura_Invulnerability---
Type :: Buff
Duration :: -1
Max Stacks :: 1 
Time Per Tick :: 1.0
Icon :: statusicons_36

---layout_layout2---

---script_stormharbinger_Monster---
//Main variables
resetMainVars := func() {
	scriptVars["phase"] = 1
	scriptVars["phaseTransition"] = true
	scriptVars["phaseTransitionTimer"] = 0.0
	scriptVars["phaseTransitionMaxTimer"] = 3.0
}
//General variables
resetVars := func() {
	scriptVars["phaseAttack"] = 1
	scriptVars["attackCount"] = 1
//Room Limiter variables
	scriptVars["roomLimiterMaxTimer"] = 3.0
	scriptVars["roomLimiterTimer"] = scriptVars["roomLimiterMaxTimer"]
	scriptVars["roomLimiterWarningTimer"] = 0.0
//Phase 1 variables
	scriptVars["thunderstormMaxTimer"] = 3.25
	scriptVars["thunderstormTimer"] = 0.0
	scriptVars["stormdashMaxTimer"] = 3.25
	scriptVars["stormdashTimer"] = 0.0
//Phase 3 variables
	//scriptVars["stormspark"] = 0
	scriptVars["stormsparkMaxTimer"] = 1.0
	scriptVars["stormsparkTimer"] = 0.0
	scriptVars["stormspiralMaxTimer"] = 3.0
	scriptVars["stormspiralTimer"] = 0.0
	scriptVars["stormroarMaxTimer"] = 20.0
	scriptVars["stormroarTimer"] = 0.0
//Phase 4 variables
	scriptVars["stormrageStart"] = 1
	scriptVars["stormrageMaxTimer"] = 2.0
	scriptVars["stormrageTimer"] = 0.0
	//scriptVars["thunderstormMaxTimer"] = 6.0
	//scriptVars["thunderstormTimer"] = 0.0
//Phase 5 variables
	scriptVars["stormslashMaxTimer"] = 2.0
	scriptVars["stormslashTimer"] = 0.0
	scriptVars["stormmightMaxTimer"] = 5.0
	scriptVars["stormmightTimer"] = 0.0
	scriptVars["stormfleeMaxTimer"] = 10.0
	scriptVars["stormfleeTimer"] = scriptVars["stormfleeMaxTimer"]
	scriptVars["direction"] = 1
	scriptVars["directionMaxTimer"] = 10.0
	scriptVars["directionTimer"] = scriptVars["directionMaxTimer"]
//Phase 6 variables
	//scriptVars["stormspiralMaxTimer"] = 3.0
	//scriptVars["stormspiralTimer"] = 0.0
	scriptVars["finalStormStart"] = false
	scriptVars["finalStormCounter"] = 5
	//scriptVars["thunderstormMaxTimer"] = 3.0
	//scriptVars["thunderstormTimer"] = 0.0
	scriptVars["survivalMaxTimer"] = 50.0
	scriptVars["survivalTimer"] = 0.0
//Misc variables
	scriptVars["boltTimer"] = 0.0
	scriptVars["boltMaxTimer"] = 3.0
	scriptVars["focusEntityId"] = 0
	scriptVars["dialogueTrigger"] = false
	scriptVars["randomTargetTimer"] = 0.0
	scriptVars["hurtBoss"] = false
	scriptVars["childEntityId"] = 0
}

//Visible and Invisible variables
resetInvisibleVars := func() {
	scriptVars["vanished"] = false
	scriptVars["vanishing"] = false
	scriptVars["invisibleTimer"] = 0.0
	scriptVars["invisibleMaxTimer"] = 0.5
	scriptVars["vanishTimer"] = 0.0
	scriptVars["vanishMaxTimer"] = 0.5
}

//Constantly launch bolts towards players
doBolts := func() {
	if scriptVars["phase"] < 5 {
		useAbilityAtPosition(myEntityId, "Harbinger Bolts I", randomPositionNearby(myEntityId, [5.0, 15.0, 0.0], 2.0))
	} else if scriptVars["phase"] == 5 {
		currentNearby := getNearbyEntities(myEntityId)
		for i := 0; i < len(currentNearby) && i <= 4; i++ {
			if isEnemyOfEntity(myEntityId, currentNearby[i].id) {
				if distToEntity(myEntityId, currentNearby[i].id) <= 9.0 {
					log("BOLT I")
					useAbilityAtPosition(myEntityId, "Harbinger Bolts I", randomPositionNearby(targetEntityId, [5.0, 10.0, 0.0], 2.0))
				} else if distToEntity(myEntityId, currentNearby[i].id) > 9.0 && distToEntity(myEntityId, currentNearby[i].id) <= 17.0 {
					log("BOLT II")
					useAbilityAtPosition(myEntityId, "Harbinger Bolts II", randomPositionNearby(targetEntityId, [5.0, 10.0, 0.0], 2.0))
				} else if distToEntity(myEntityId, currentNearby[i].id) > 17.0 {
					log("BOLT III")
					useAbilityAtPosition(myEntityId, "Harbinger Bolts III", randomPositionNearby(targetEntityId, [5.0, 10.0, 0.0], 2.0))
				}
			}
		}
	}
}
//Room Limiter Warning Spawner
doWallWarnings := func() {
	if scriptVars["phase"] == 1 {
		useAbilityAtPosition(myEntityId, "Harbinger Room Limiter I Vertical Warning", positionInCurrentRoom(myEntityId, [5.7,21.0,0.0]))
		useAbilityAtPosition(myEntityId, "Harbinger Room Limiter I Vertical Warning", positionInCurrentRoom(myEntityId, [36.3,21.0,0.0]))
		useAbilityAtPosition(myEntityId, "Harbinger Room Limiter I Horizontal Warning", positionInCurrentRoom(myEntityId, [21.0,5.7,0.0]))
		useAbilityAtPosition(myEntityId, "Harbinger Room Limiter I Horizontal Warning", positionInCurrentRoom(myEntityId, [21.0,36.3,0.0]))
	} else {
		useAbilityAtPosition(myEntityId, "Harbinger Room Limiter II Vertical Warning", positionInCurrentRoom(myEntityId, [5.7,21.0,0.0]))
		useAbilityAtPosition(myEntityId, "Harbinger Room Limiter II Vertical Warning", positionInCurrentRoom(myEntityId, [36.3,21.0,0.0]))
		useAbilityAtPosition(myEntityId, "Harbinger Room Limiter II Horizontal Warning", positionInCurrentRoom(myEntityId, [21.0,5.7,0.0]))
		useAbilityAtPosition(myEntityId, "Harbinger Room Limiter II Horizontal Warning", positionInCurrentRoom(myEntityId, [21.0,36.3,0.0]))
		if scriptVars["phase"] == 3 || scriptVars["phase"] == 4 || scriptVars["phase"] == 6 {
			useAbilityAtPosition(myEntityId, "Harbinger Room Limiter I Diamond Warning", positionInCurrentRoom(myEntityId, [8.7,8.7,0.0]))
			useAbilityAtPosition(myEntityId, "Harbinger Room Limiter I Diamond Warning", positionInCurrentRoom(myEntityId, [33.3,33.3,0.0]))
			useAbilityAtPosition(myEntityId, "Harbinger Room Limiter I Diamond Warning", positionInCurrentRoom(myEntityId, [33.3,8.7,0.0]))
			useAbilityAtPosition(myEntityId, "Harbinger Room Limiter I Diamond Warning", positionInCurrentRoom(myEntityId, [8.7,33.3,0.0]))
		} else if scriptVars["phase"] == 5 {
			useAbilityAtPosition(myEntityId, "Harbinger Room Limiter II Diamond Warning", positionInCurrentRoom(myEntityId, [21.0,21.0,0.0]))
			useAbilityAtPosition(myEntityId, "Harbinger Room Limiter I Separator Warning", positionInCurrentRoom(myEntityId, [10.7,21.0,0.0]))
			useAbilityAtPosition(myEntityId, "Harbinger Room Limiter I Separator Warning", positionInCurrentRoom(myEntityId, [31.3,21.0,0.0]))
			useAbilityAtPosition(myEntityId, "Harbinger Room Limiter I Separator Warning", positionInCurrentRoom(myEntityId, [21.0,10.7,0.0]))
			useAbilityAtPosition(myEntityId, "Harbinger Room Limiter I Separator Warning", positionInCurrentRoom(myEntityId, [21.0,31.3,0.0]))
		}
		scriptVars["roomLimiterMaxTimer"] = 1.5
	}
}
//Room Limiter Respawn Trigger
doWalls := func() {
	useAbilityAtPosition(myEntityId, "Harbinger Room Limiter I Vertical", positionInCurrentRoom(myEntityId, [5.7,21.0,0.0]))
	useAbilityAtPosition(myEntityId, "Harbinger Room Limiter I Vertical", positionInCurrentRoom(myEntityId, [36.3,21.0,0.0]))
	useAbilityAtPosition(myEntityId, "Harbinger Room Limiter I Horizontal", positionInCurrentRoom(myEntityId, [21.0,5.7,0.0]))
	useAbilityAtPosition(myEntityId, "Harbinger Room Limiter I Horizontal", positionInCurrentRoom(myEntityId, [21.0,36.3,0.0]))
	if scriptVars["phase"] == 3 || scriptVars["phase"] == 4 || scriptVars["phase"] == 6 {
		useAbilityAtPosition(myEntityId, "Harbinger Room Limiter I Diamond", positionInCurrentRoom(myEntityId, [8.7,8.7,0.0]))
		useAbilityAtPosition(myEntityId, "Harbinger Room Limiter I Diamond", positionInCurrentRoom(myEntityId, [33.3,33.3,0.0]))
		useAbilityAtPosition(myEntityId, "Harbinger Room Limiter I Diamond", positionInCurrentRoom(myEntityId, [33.3,8.7,0.0]))
		useAbilityAtPosition(myEntityId, "Harbinger Room Limiter I Diamond", positionInCurrentRoom(myEntityId, [8.7,33.3,0.0]))
	} else if scriptVars["phase"] == 5 {
		useAbilityAtPosition(myEntityId, "Harbinger Room Limiter II Vertical", positionInCurrentRoom(myEntityId, [5.7,21.0,0.0]))
		useAbilityAtPosition(myEntityId, "Harbinger Room Limiter II Vertical", positionInCurrentRoom(myEntityId, [36.3,21.0,0.0]))
		useAbilityAtPosition(myEntityId, "Harbinger Room Limiter II Horizontal", positionInCurrentRoom(myEntityId, [21.0,5.7,0.0]))
		useAbilityAtPosition(myEntityId, "Harbinger Room Limiter II Horizontal", positionInCurrentRoom(myEntityId, [21.0,36.3,0.0]))
		useAbilityAtPosition(myEntityId, "Harbinger Room Limiter II Diamond", positionInCurrentRoom(myEntityId, [21.0,21.0,0.0]))
	}
	scriptVars["roomLimiterTimer"] = 0.0
	if scriptVars["roomLimiterMaxTimer"] != 10.0 {
		scriptVars["roomLimiterMaxTimer"] = 10.0
	}
}
//Dialogue Handler
dialoguePrompt := func()  {
	if scriptVars["phase"] == 1 {
		say(myEntityId, "... The storm is coming.")
    } else if scriptVars["phase"] == 2 {
		say(myEntityId, "Feel the presence of its strongest shadow.")
    } else if scriptVars["phase"] == 3 {
		say(myEntityId, "Hear its roar, be consumed by its domain.")
    } else if scriptVars["phase"] == 4 {
		say(myEntityId, "Learn its rage. Or it shall tear through it all.")
	} else if scriptVars["phase"] == 5 {
		say(myEntityId, "Fleeing is futile. Fight it with your might or you shall meet your demise.")
	} else if scriptVars["phase"] == 6 {
		if !isDead {
			say(myEntityId, "Witness its eye and you shall see the sunlight.")
		} else {
			say(myEntityId, "The storm has come to an end. May it await for your presence once again.")
			clearBulletsForEntity(myEntityId)
		}
	}
}

//Main
if !isDead && targetEntityId != 0 {
	
	//Constants
	currentHealth := getPoints(myEntityId, "hp", "current")
	maxHealth := getPoints(myEntityId, "hp", "max")
	targetEntityPos := entityGroundTargetPosition(targetEntityId)
	roomCenter := positionInCurrentRoom(myEntityId, [21.0,21.0,0.0])
	diamondTop := positionInCurrentRoom(myEntityId, [21.0,5.7,0.0])
	diamondLeft := positionInCurrentRoom(myEntityId, [5.7,21.0,0.0])
	diamondRight := positionInCurrentRoom(myEntityId, [36.7,21.0,0.0])
	diamondBot := positionInCurrentRoom(myEntityId, [21.0,36.7,0.0])
	diamondTopLeft := positionInCurrentRoom(myEntityId, [15.2,16.7,0.0])
	diamondTopRight := positionInCurrentRoom(myEntityId, [26.8,16.7,0.0])
	diamondBotRight := positionInCurrentRoom(myEntityId, [26.8,28.2,0.0])
	diamondBotLeft := positionInCurrentRoom(myEntityId, [15.2,28.2,0.0])
	
	//Phase handler
	if is_undefined(scriptVars["phase"]) {
		log("INITIALIZE")
		resetMainVars()
		resetVars()
		resetInvisibleVars()
		doWallWarnings()
		addAuraToEntity(myEntityId, "Harbinger Max HP", 0, myEntityId)
		addHitPoints(myEntityId, 5000000000)
		log("health:" + currentHealth + "/" + maxHealth)
		scriptVars["dialogueTrigger"] = true
		triggerAnimation(myEntityId, "Appear")
	}
	if currentHealth < maxHealth * 0.8 && scriptVars["phase"] == 1 || currentHealth < maxHealth * 0.7 && scriptVars["phase"] == 2 || currentHealth < maxHealth * 0.5 && scriptVars["phase"] == 3 || currentHealth < maxHealth * 0.3 && scriptVars["phase"] == 4 || currentHealth < maxHealth * 0.1 && scriptVars["phase"] == 5 {
		resetVars()
		scriptVars["dialogueTrigger"] = true
		scriptVars["phase"] += 1
		scriptVars["phaseTransition"] = true
		log("health:" + currentHealth + "/" + maxHealth)
		triggerAnimation(myEntityId, "Appear")
	}
	
	//Check if entity is visible. If visible proceed to vanish after X time
	if scriptVars["vanishing"] ==  true {
		if scriptVars["vanishTimer"] < scriptVars["vanishMaxTimer"]{
			scriptVars["vanishTimer"] += delta
		} else {
			triggerAnimation(myEntityId, "Vanish")
			setCollisionLayer(myEntityId, CollisionLayerDynamic)
			//log("SUCCESFUL VANISH")
			scriptVars["vanishing"] = false
			scriptVars["vanishTimer"] = 0.0
			scriptVars["vanished"] = true
		}
	}
	//Check if entity is invisible. If invisible proceed to appear after X time
	if scriptVars["vanished"] == true && scriptVars["phase"] !=  2 {
		if scriptVars["invisibleTimer"] < scriptVars["invisibleMaxTimer"] {
			scriptVars["invisibleTimer"] += delta
		} else {
			triggerAnimation(myEntityId, "Appear")
			setCollisionLayer(myEntityId, CollisionLayerMonster)
			//log("SUCCESFUL APPEAR")
			scriptVars["vanished"] = false
			scriptVars["invisibleTimer"] = 0.0
		}
	}
	
	//Phase Transition Handler
	if scriptVars["phaseTransition"] == true {
		if scriptVars["phaseTransitionTimer"] < scriptVars["phaseTransitionMaxTimer"] {
			if scriptVars["phase"] != 1 {
				clearBulletsForEntity(myEntityId)
				scriptVars["roomLimiterTimer"] = 0.0
			} 
			if scriptVars["phase"] != 2 {
				clearBulletsForEntity(scriptVars["childEntityId"])
			}
			resetInvisibleVars()
			//triggerAnimation(myEntityId, "Idle")
			addAuraToEntity(myEntityId, "Invulnerability", 0, myEntityId)
			setCollisionLayer(myEntityId, CollisionLayerDynamic)
			scriptVars["phaseTransitionTimer"] += delta
			changeAttackBehaviour(myEntityId, "Ignore Targets")
			setTargetPosition(myEntityId, roomCenter)
			if scriptVars["phase"] > 2 {
				scriptVars["boltMaxTimer"] = 2.0
			}
			if scriptVars["phase"] == 4 {
				scriptVars["thunderstormMaxTimer"] = 6.0
			} else if scriptVars["phase"] == 6 {
				scriptVars["stormspiralMaxTimer"] = 3.0
				scriptVars["thunderstormMaxTimer"] = 3.0
			}
		} else {
			dispelAuraOnEntity(myEntityId, "Invulnerability")
			setCollisionLayer(myEntityId, CollisionLayerMonster)
			scriptVars["phaseTransitionTimer"] = 0.0
			if scriptVars["dialogueTrigger"] == true {
				dialoguePrompt()
				scriptVars["dialogueTrigger"] = false
			}
			
			if scriptVars["phase"] != 1 {
				doWallWarnings()
			}
			
			if scriptVars["phase"] == 1 {
				scriptVars["thunderstormTimer"] = scriptVars["thunderstormMaxTimer"]
			} else if scriptVars["phase"] == 2 {
				showVfxAtPosition(myEntityId, "SpawnEnemy", roomCenter)
				scriptVars["childEntityId"] = summonEntity("championshadowstorm", roomCenter, monsterLevel(myEntityId), true, {parentEntityId: myEntityId, parentMaxHealth: maxHealth})
				scriptVars["vanishMaxTimer"] = 0.25
				scriptVars["vanishing"] = true
			} else if scriptVars["phase"] == 3 {
				scriptVars["stormsparkTimer"] = scriptVars["stormsparkMaxTimer"]
			} else if scriptVars["phase"] == 4 {
				scriptVars["stormrageTimer"] = scriptVars["stormrageMaxTimer"] 
			} else if scriptVars["phase"] == 5 {
				changeAttackBehaviour(myEntityId, "Ignore Targets")
				setTargetPosition(myEntityId, diamondTopLeft)
				scriptVars["stormslashTimer"] = scriptVars["stormslashMaxTimer"]
			} else if scriptVars["phase"] == 6 {
				scriptVars["stormspiralTimer"] = scriptVars["stormspiralMaxTimer"] 
			}
			log("phase:" + scriptVars["phase"])
			scriptVars["phaseTransition"] = false
			
		}
	//Phase Attack Handler
	} else if scriptVars["phaseTransition"] == false {
		//Room Limiter Respawn
		scriptVars["roomLimiterTimer"] += delta
		if scriptVars["roomLimiterTimer"] >= scriptVars["roomLimiterMaxTimer"]{
			doWalls()
			scriptVars["roomLimiterTimer"] = 0.0
		}
		if scriptVars["boltTimer"] > scriptVars["boltMaxTimer"] {
			doBolts()
			scriptVars["boltTimer"] = 0.0
		}
		
		//Increase timers
		scriptVars["boltTimer"] += delta
		//Phase 1 timers
		scriptVars["thunderstormTimer"] += delta
		scriptVars["stormdashTimer"] += delta
		//Phase 3 timers
		scriptVars["stormsparkTimer"] += delta
		scriptVars["stormspiralTimer"] += delta
		scriptVars["stormroarTimer"] += delta
		//Phase 4 timers
		scriptVars["stormrageTimer"] += delta
		//scriptVars["thunderstormTimer"] += delta
		//Phase 5 timers
		scriptVars["stormmightTimer"] += delta
		scriptVars["stormslashTimer"] += delta
		scriptVars["stormfleeTimer"] += delta
		scriptVars["directionTimer"] += delta
		//Phase 6 timers
		//scriptVars["thunderstormTimer"] += delta
		//scriptVars["stormspiralTimer"] += delta
	
		if scriptVars["phase"] == 1 {
			//Thunderstorm Attack
			if scriptVars["thunderstormTimer"] > scriptVars["thunderstormMaxTimer"] && scriptVars["phaseAttack"] == 1 {
				//log("THUNDERSTORM")
				setPosition(myEntityId, roomCenter)
				changeAttackBehaviour(myEntityId, "Stationary")
				useAbilityAtTarget(myEntityId, "Harbinger Thunderstorm I", targetEntityId, 2.0)
				scriptVars["thunderstormTimer"] = 0.0
				scriptVars["vanishMaxTimer"] = 2.25
				scriptVars["vanishing"] = true
				scriptVars["phaseAttack"] = 2
			//Stormdash Attack
			} else if scriptVars["stormdashTimer"] > scriptVars["stormdashMaxTimer"] && scriptVars["phaseAttack"] == 2 {
				//log("STORMDASH")
				if scriptVars["attackCount"] <= 3 {
				//log("attackCount:" + scriptVars["attackCount"])
					if distToEntity(myEntityId, closestEnemyEntityId(myEntityId)) < 5.5 {
						setPosition(myEntityId, randomPositionInCurrentRoom(myEntityId, 12.0))
					} else {
						setPosition(myEntityId, targetEntityPos)
					}
					changeAttackBehaviour(myEntityId, "Stationary")
					useAbilityAtTarget(myEntityId, "Harbinger Stormdash I", targetEntityId, 2.0)
					scriptVars["stormdashMaxTimer"] = 1.5
					scriptVars["vanishMaxTimer"] = 1.0
					scriptVars["vanishing"] = true
					scriptVars["attackCount"] += 1
				} else {
				//log("phaseAttack:" + scriptVars["phaseAttack"])
					triggerAnimation(myEntityId, "Vanish")
					scriptVars["phaseAttack"] = 1
					scriptVars["attackCount"] = 1
					scriptVars["stormdashMaxTimer"] = 3.0
					scriptVars["vanishMaxTimer"] = 0.5
					scriptVars["vanished"] = true
				}
				scriptVars["stormdashTimer"] = 0.0
			}
		} else if scriptVars["phase"] == 2 {
			if isEntityDead(scriptVars["childEntityId"]) && scriptVars["hurtBoss"] == false {
				//log("SELF DAMAGE CHECK")
				attackEntity(myEntityId, myEntityId, maxHealth/10, 0)
				scriptVars["hurtBoss"] = true
			}
		} else if scriptVars["phase"] == 3 {
			//stormspark Attack
			if scriptVars["phaseAttack"] == 1 {
				if scriptVars["stormsparkTimer"] > scriptVars["stormsparkMaxTimer"] {
				//log("STORMSPARK")
				useAbilityAtTarget(myEntityId, "Harbinger Stormspark", targetEntityId, 2.0)
				scriptVars["stormsparkTimer"] = 0.0
				scriptVars["stormspiralTimer"] = 0.0
				scriptVars["phaseAttack"] = 2
				}
			//stormspiral Attack
			} else {
				if scriptVars["stormspiralTimer"] > scriptVars["stormspiralMaxTimer"] {
					//log("STORMSPIRAL")
					useAbilityAtTarget(myEntityId, "Harbinger Stormspiral I", targetEntityId, 1.0)
					scriptVars["stormspiralTimer"] = 0.0
					scriptVars["stormspiralMaxTimer"] = 6.0
				}
				if scriptVars["stormroarTimer"] > scriptVars["stormroarMaxTimer"] {
					//log("STORMROAR")
					useAbilityAtTarget(myEntityId, "Harbinger Stormroar I", targetEntityId, 1.0)
					scriptVars["stormroarTimer"] = 0.0
					scriptVars["stormroarMaxTimer"] = 5.0
				}
			}
		} else if scriptVars["phase"] == 4 {
			//stormrage Attack
			if scriptVars["stormrageTimer"] >= scriptVars["stormrageMaxTimer"] && scriptVars["phaseAttack"] == 1 {
				//log("STORMRAGE")
				//Top Spot
				if scriptVars["stormrageStart"] == 1 && scriptVars["attackCount"] == 1 || scriptVars["stormrageStart"] == 2 && scriptVars["attackCount"] == 4 || scriptVars["stormrageStart"] == 3 && scriptVars["attackCount"] == 3 || scriptVars["stormrageStart"] == 4 && scriptVars["attackCount"] == 2 {
					//log("TOP")
					setPosition(myEntityId, diamondTop) 
					useAbilityAtTarget(myEntityId, "Harbinger Stormrage Top", targetEntityId, 2.0)
				//Left
				} else if scriptVars["stormrageStart"] == 2 && scriptVars["attackCount"] == 1 || scriptVars["stormrageStart"] == 3 && scriptVars["attackCount"] == 4 || scriptVars["stormrageStart"] == 4 && scriptVars["attackCount"] == 3 || scriptVars["stormrageStart"] == 1 && scriptVars["attackCount"] == 2 {
					//log("LEFT")
					setPosition(myEntityId, diamondLeft) 
					useAbilityAtTarget(myEntityId, "Harbinger Stormrage Left", targetEntityId, 2.0)
				//Right
				} else if scriptVars["stormrageStart"] == 3 && scriptVars["attackCount"] == 1 || scriptVars["stormrageStart"] == 4 && scriptVars["attackCount"] == 4 || scriptVars["stormrageStart"] == 1 && scriptVars["attackCount"] == 3 || scriptVars["stormrageStart"] == 2 && scriptVars["attackCount"] == 2 {
					//log("RIGHT")
					setPosition(myEntityId, diamondRight) 
					useAbilityAtTarget(myEntityId, "Harbinger Stormrage Right", targetEntityId, 2.0)
				//Bot
				} else if scriptVars["stormrageStart"] == 4 && scriptVars["attackCount"] == 1 || scriptVars["stormrageStart"] == 1 && scriptVars["attackCount"] == 4 || scriptVars["stormrageStart"] == 2 && scriptVars["attackCount"] == 3 || scriptVars["stormrageStart"] == 3 && scriptVars["attackCount"] == 2 {
					//log("BOT")
					setPosition(myEntityId, diamondBot) 
					useAbilityAtTarget(myEntityId, "Harbinger Stormrage Bot", targetEntityId, 2.0)
				}
				if scriptVars["attackCount"] <= 4 {
					//log("STORMRAGE +1")
					changeAttackBehaviour(myEntityId, "Stationary")
					scriptVars["stormrageMaxTimer"] = 1.5
					scriptVars["vanishMaxTimer"] = 1.0
					scriptVars["invisibleMaxTimer"] = 0.5
					scriptVars["vanished"] = true
					scriptVars["vanishing"] = true
					scriptVars["attackCount"] += 1
					scriptVars["stormrageTimer"] = 0.0
				} else {
					//log("STORMRAGE END")
					scriptVars["phaseAttack"] = 2
					scriptVars["attackCount"] = 1
					scriptVars["stormrageMaxTimer"] = 4.0
					scriptVars["vanishMaxTimer"] = 0.5
					scriptVars["vanished"] = true
					scriptVars["stormrageTimer"] = 0.0
					if scriptVars["stormrageStart"] < 4 {
						scriptVars["stormrageStart"] += 1
					} else {
						scriptVars["stormrageStart"] = 1
					}
				}
			} else {
				if scriptVars["thunderstormTimer"] >= scriptVars["thunderstormMaxTimer"] && scriptVars["phaseAttack"] == 2 {
					//log("THUNDERSTORM")
					setPosition(myEntityId, roomCenter)
					changeAttackBehaviour(myEntityId, "Stationary")
					useAbilityAtTarget(myEntityId, "Harbinger Thunderstorm II", targetEntityId, 2.0)
					scriptVars["thunderstormTimer"] = 0.0
					scriptVars["vanishMaxTimer"] = 4.5
					scriptVars["vanishing"] = true
					scriptVars["phaseAttack"] = 1
				}
			}
		} else if scriptVars["phase"] == 5 {
			currentNearby := getNearbyEntities(myEntityId)
			for i := 0; i < len(currentNearby) && i <= 4; i++ {
				if scriptVars["boltTimer"] > 3.0 && distToEntity(myEntityId, currentNearby[i].id) <= 9.0 || scriptVars["boltTimer"] > 2.0 && distToEntity(myEntityId, currentNearby[i].id) > 9.0 && distToEntity(myEntityId, currentNearby[i].id) <= 17.0 || scriptVars["boltTimer"] > 1.0 && distToEntity(myEntityId, currentNearby[i].id) > 17.0  {
					doBolts()
					scriptVars["boltTimer"] = 0.0
				}
			}
			//Pathing Handler
			if scriptVars["directionTimer"] >= scriptVars["directionMaxTimer"] {
				//log("CHANGE POS")
				
				//TopLeft Spot
				if scriptVars["direction"] == 1 {
					//log("TOPLEFT")
					setTargetPosition(myEntityId, diamondTopLeft)
					useAbilityAtPosition(myEntityId, "Harbinger Stormflee", positionInCurrentRoom(myEntityId, [27.14,14.85,0.0]))
					
				//TopRight
				} else if scriptVars["direction"] == 2 {
					//log("TOPRIGHT")
					setTargetPosition(myEntityId, diamondTopRight)
					useAbilityAtPosition(myEntityId, "Harbinger Stormflee", positionInCurrentRoom(myEntityId, [27.14,27.14,0.0]))
					
				//BotRight
				} else if scriptVars["direction"] == 3 {
					//log("BOTRIGHT")
					setTargetPosition(myEntityId, diamondBotRight)
					useAbilityAtPosition(myEntityId, "Harbinger Stormflee", positionInCurrentRoom(myEntityId, [14.85,27.14,0.0]))
					
				//BotLeft
				} else if scriptVars["direction"] == 4 {
					//log("BOTLEFT")
					setTargetPosition(myEntityId, diamondBotLeft)
					useAbilityAtPosition(myEntityId, "Harbinger Stormflee", positionInCurrentRoom(myEntityId, [14.85,14.85,0.0]))
				}
				if scriptVars["direction"] < 4 {
					scriptVars["direction"] += 1
				} else {
					scriptVars["direction"] = 1
				}
				scriptVars["directionTimer"] = 0.0
				scriptVars["stormmightTimer"] = 0.0
				scriptVars["stormslashTimer"] = 0.0
			}
			//stormslash Attack
			if distToPoint(myEntityId, diamondTopLeft) < 1.0 || distToPoint(myEntityId, diamondTopRight) < 1.0 || distToPoint(myEntityId, diamondBotRight) < 1.0 || distToPoint(myEntityId, diamondBotLeft) < 1.0 {
				dispelAuraOnEntity(myEntityId, "Invulnerability")
				setCollisionLayer(myEntityId, CollisionLayerMonster)
				if scriptVars["stormslashTimer"] >= scriptVars["stormslashMaxTimer"] {
					//log("STORMSLASH")
					useAbilityAtTarget(myEntityId, "Harbinger Stormslash", targetEntityId, 1.0)
					scriptVars["stormslashTimer"] = 0.0
				}
				
				if scriptVars["stormmightTimer"] >= scriptVars["stormmightMaxTimer"] {
					//log("STORMMIGHT")
					//TopLeft Spot
					if scriptVars["direction"] == 2 {
						useAbilityAtTarget(myEntityId, "Harbinger Stormmight Top Left", targetEntityId, 2.0)
					//TopRight
					} else if scriptVars["direction"] == 3 {
						useAbilityAtTarget(myEntityId, "Harbinger Stormmight Top Right", targetEntityId, 2.0)
					//BotRight
					} else if scriptVars["direction"] == 4 {
						useAbilityAtTarget(myEntityId, "Harbinger Stormmight Bottom Right", targetEntityId, 2.0)
					//BotLeft
					} else if scriptVars["direction"] == 1 {
						useAbilityAtTarget(myEntityId, "Harbinger Stormmight Bottom Left", targetEntityId, 2.0)
					}
					scriptVars["stormmightTimer"] = 0.0
				}
			} else {
				addAuraToEntity(myEntityId, "Invulnerability", 0, myEntityId)
				setCollisionLayer(myEntityId, CollisionLayerDynamic)
			}
		} else if scriptVars["phase"] == 6 {
			if scriptVars["survivalTimer"] < scriptVars["survivalMaxTimer"] {
				scriptVars["survivalTimer"] += delta
				addAuraToEntity(myEntityId, "Invulnerability", 0, myEntityId)
				setCollisionLayer(myEntityId, CollisionLayerDynamic)
			} else {
				dispelAuraOnEntity(myEntityId, "Invulnerability")
				setCollisionLayer(myEntityId, CollisionLayerMonster)
				scriptVars["dialogueTrigger"] == true
			}
			/*if scriptVars["boltTimer"] > 2.0 {
				doBolts()
				scriptVars["boltTimer"] = 0.0
			}*/
			//thunderstorm Attack
			if scriptVars["finalStormStart"] == false && scriptVars["thunderstormTimer"] > scriptVars["thunderstormMaxTimer"] {
				log("FINALSTORM")
				useAbilityAtTarget(myEntityId, "Harbinger Thunderstorm III", targetEntityId, 1.0)
				scriptVars["finalStormStart"] = true
			}
			//stormspiral Attack
			if scriptVars["finalStormCounter"] > 1 && scriptVars["stormspiralTimer"] > scriptVars["stormspiralMaxTimer"] {
				log("STORMSPIRAL")
				//log("" + scriptVars["finalStormCounter"])
				useAbilityAtTarget(myEntityId, "Harbinger Stormspiral II", targetEntityId, 1.0)
				useAbilityAtTarget(myEntityId, "Harbinger Stormspiral II Double", targetEntityId, 1.0)
				scriptVars["stormspiralTimer"] = 0.0
				scriptVars["stormspiralMaxTimer"] = 11.7
				scriptVars["finalStormCounter"] -= 1
			}
		}
	}
} else if isDead && scriptVars["dialogueTrigger"] == true {
	dialoguePrompt()
	scriptVars["dialogueTrigger"] = false
}

