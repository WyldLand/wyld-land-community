---aura_Champion Storm Max HP---
Type :: Buff
Duration :: -1
Max stacks :: 1 
Time Per Tick :: 1.0
Definitions :: [[auraaffectstat/championstormmaxhp]]

---auraaffectstat_championstormmaxhp---
Stat :: Vitality
Boost :: 150.0

---script_championshadowstorm_Monster---
resetVars := func() {
	scriptVars["superSpin"] = false
	scriptVars["phaseAttack"] = 1
	scriptVars["didDie"] = false
	scriptVars["spinTimer"] = 0.0
	scriptVars["lightningTimer"] = 0.0
	scriptVars["abilityID"] = 0.0
}
if !isDead && targetEntityId != 0 {
	//Apply miniboss health boost
	if is_undefined(scriptVars["superSpin"]) {
		//log(scriptVars["parentEntityId"])
		//log("SPAWN SUCCESSFUL")
		//log("test"+ myEntityId)
		resetVars()
		addAuraToEntity(myEntityId, "Champion Storm Max HP", 0, myEntityId)
		addHitPoints(myEntityId, 500000000)
		say(myEntityId, "...")
		scriptVars["spinTimer"] = 2.0
	}
	scriptVars["spinTimer"] += delta
	scriptVars["lightningTimer"] += delta
	
	//Attack Handler
	//Spin Attack
	if scriptVars["spinTimer"] > 2.5 && scriptVars["phaseAttack"] == 1 {
		//Do Super Spin at the start
		if scriptVars["superSpin"] == false {
			//log("SUPER SPIN")
			useAbilityAtTarget(myEntityId, "Champion Storm Super Spin", targetEntityId, 2.0)
			scriptVars["superSpin"] = true
		} else {
			//log("SPIN")
			useAbilityAtTarget(myEntityId, "Champion Storm Spin", targetEntityId, 2.0)
		}
		scriptVars["phaseAttack"] = 2
		scriptVars["lightningTimer"] = 0.0
	} else if scriptVars["lightningTimer"] > 2.5 && scriptVars["phaseAttack"] == 2 {
		useAbilityAtTarget(myEntityId, "Champion Storm Lightning", targetEntityId, 2.0)
		scriptVars["phaseAttack"] = 1
		scriptVars["spinTimer"] = 0.0
	}
} else if isDead && scriptVars["didDie"] == false {
	clearBulletsForEntity(myEntityId)
	scriptVars["didDie"] = true
}