---ability_Spawn Power Circle Enemy---
Script :: SpawnPowerCircleEnemy

---script_SpawnPowerCircleEnemy_Cast---
if frameNum == 0 {
    rand := import("rand")
    
    // Define possible spawn positions
    spawnPositions := [
        positionInCurrentRoom(myEntityId, [7.0, 7.0, 0.0]),
        positionInCurrentRoom(myEntityId, [21.0, 7.0, 0.0]),
        positionInCurrentRoom(myEntityId, [34.0, 7.0, 0.0]),
        positionInCurrentRoom(myEntityId, [7.0, 14.0, 0.0]),
        positionInCurrentRoom(myEntityId, [34.0, 14.0, 0.0]),
        positionInCurrentRoom(myEntityId, [7.0, 21.0, 0.0]),
        positionInCurrentRoom(myEntityId, [34.0, 21.0, 0.0]),
        positionInCurrentRoom(myEntityId, [7.0, 28.0, 0.0]),
        positionInCurrentRoom(myEntityId, [34.0, 28.0, 0.0]),
        positionInCurrentRoom(myEntityId, [7.0, 34.0, 0.0]),
        positionInCurrentRoom(myEntityId, [21.0, 34.0, 0.0]),
        positionInCurrentRoom(myEntityId, [34.0, 34.0, 0.0])
    ]
    
    // Create array to track used positions
    usedPositions := []
    
    // Spawn 6 enemies at different positions
    for i := 0; i < 6; i++ {
        // Keep trying until we find an unused position
        selectedIndex := -1
        for selectedIndex == -1 {
            randomIndex := rand.intn(len(spawnPositions))
            
            // Check if this position has already been used
            alreadyUsed := false
            for j := 0; j < len(usedPositions); j++ {
                if usedPositions[j] == randomIndex {
                    alreadyUsed = true
                    break
                }
            }
            
            // If position hasn't been used, select it
            if !alreadyUsed {
                selectedIndex = randomIndex
            }
        }
        
        // Add the selected index to used positions
        usedPositions = append(usedPositions, selectedIndex)
        
        // Spawn the enemy at the selected position
        selectedPosition := spawnPositions[selectedIndex]
        log("Spawn Power Circle Enemy " + string(i + 1) + " at position " + string(selectedIndex))
        newEntityId := summonEntity("powercircleenemy", selectedPosition, monsterLevel(myEntityId))
        killEntityIfEntityDies(newEntityId, myEntityId)
    }
}

---ability_Spawn Healing Tower Two---
Script :: SpawnHealingTowerTwo

---script_SpawnHealingTowerTwo_Cast---
if frameNum == 0 {
    rand := import("rand")
    
    // Define possible spawn positions
    spawnPositions := [
        positionInCurrentRoom(myEntityId, [25.0, 11.0, 0.0]),
        positionInCurrentRoom(myEntityId, [20.0, 31.0, 0.0])
    ]
    
    // Create array to track used positions
    usedPositions := []
    
    // Spawn 6 enemies at different positions
    for i := 0; i < 2; i++ {
        // Keep trying until we find an unused position
        selectedIndex := -1
        for selectedIndex == -1 {
            randomIndex := rand.intn(len(spawnPositions))
            
            // Check if this position has already been used
            alreadyUsed := false
            for j := 0; j < len(usedPositions); j++ {
                if usedPositions[j] == randomIndex {
                    alreadyUsed = true
                    break
                }
            }
            
            // If position hasn't been used, select it
            if !alreadyUsed {
                selectedIndex = randomIndex
            }
        }
        
        // Add the selected index to used positions
        usedPositions = append(usedPositions, selectedIndex)
        
        // Spawn the enemy at the selected position
        selectedPosition := spawnPositions[selectedIndex]
        log("Spawn Power Circle Enemy " + string(i + 1) + " at position " + string(selectedIndex))
        newEntityId := summonEntity("raid3healingtower", selectedPosition, monsterLevel(myEntityId))
        killEntityIfEntityDies(newEntityId, myEntityId)
    }
}



---aura_Raid3 Immunity---
Type :: Buff
Duration :: -1
Max Stacks :: 1
Time Per Tick :: 1.0
Definitions :: [[Custom:Raid3Immunity]]

---script_Raid3Immunity_IncomingDamage---
// Check if the damage sender has the Raid3 Attacker
hasRaid3Buff := false
senderAuras := getAurasOnEntity(damageSenderId)

for i := 0; i < len(senderAuras); i++ {
    if senderAuras[i]["name"] == "Raid3 Attacker" {
        hasRaid3Buff = true
        break
    }
}

// If the player doesn't have the raid3 buff, make the entity invulnerable
if !hasRaid3Buff {
    additionalDamage = -1 * damage
}

---ability_Rect Throw Right---
Bullet Definition :: [[rectthrowright]]
Max Range :: 100.0

---bulletdef_rectthrowright---
sprite RectPool 0.5 2.5
potency 75
fire 1.5 absolute 90
	aoedot
	radius 0.5 2.5
	damageEvery 1
	timedFill 1
	wait 500
	vanish

---script_testboss_Monster---
resetVarsStart := func() {
		scriptVars["phase"] = 2
		addAuraToEntity(myEntityId, "Raid3 Immunity", 0, myEntityId)
	}

	if is_undefined(scriptVars["phase"]) {
		resetVarsStart()
	}

if !isDead {
	currentHealth := float(getPoints(myEntityId, "hp", "current"))
	maxHealth := float(getPoints(myEntityId, "hp", "max"))

	// Phase transitions
	if currentHealth < maxHealth * 0.66 && scriptVars["phase"] == 1 {
		clearBulletsForEntity(myEntityId)
		scriptVars["phase"] = 2
		say(myEntityId, "I'm in phase 2.")
	} else if currentHealth < maxHealth * 0.33 && scriptVars["phase"] == 2 {
		say(myEntityId, "Im in Phase 3.")
		clearBulletsForEntity(myEntityId)
		scriptVars["phase"] = 3
	}

	if scriptVars["phase"] == 1 { 

		resetVarsOne := func() {
			scriptVars["rectAndLineTime"] = 0.0
			scriptVars["crossWeaveTime"] = 4.0
			scriptVars["powerCircleEnemySpawnTimer"] = 19.0
			scriptVars["targetAllPlayersTimer"] = 4.0

			scriptVars["timeSinceTeleport"] = 0.0
			scriptVars["teleportIndex"] = 0
			scriptVars["hasTeleported"] = false


			scriptVars["teleportLocations"] = [
				[12.0, 31.0, 0.0],
				[24.0, 31.0, 0.0],
				[10.0, 8.0, 0.0],
				[31.0, 8.0, 0.0]
			]
		}

		if is_undefined(scriptVars["rectAndLineTime"]) {
    		resetVarsOne()
		}

		scriptVars["rectAndLineTime"] += delta
		scriptVars["timeSinceTeleport"] += delta
		scriptVars["targetAllPlayersTimer"] += delta
		scriptVars["powerCircleEnemySpawnTimer"] += delta
		scriptVars["crossWeaveTime"] += delta

		// Check if it's time to teleport 
		if scriptVars["timeSinceTeleport"] >= 12.0 && !scriptVars["hasTeleported"] {
			// Move to the next location in the predefined list
			scriptVars["teleportIndex"] = (scriptVars["teleportIndex"] + 1) % len(scriptVars["teleportLocations"])
			
			// Get the new position
			newPosition := positionInCurrentRoom(myEntityId, scriptVars["teleportLocations"][scriptVars["teleportIndex"]])

			scriptVars["hasTeleported"] = true

			scriptVars["timeSinceTeleport"] = 0.0
			
			// Teleport the entity to the new position
			setPosition(myEntityId, newPosition)
			
		}


		if scriptVars["targetAllPlayersTimer"] >= 5.75 && scriptVars["sendTargetAllPlayersBullet"] {
			useAbilityAtPosition(myEntityId, "Target All Players Tracking Bullet", entityPosition(myEntityId))
			scriptVars["sendTargetAllPlayersBullet"] = false
			log("Tracking Bullet")
		}

		if scriptVars["targetAllPlayersTimer"] >= 10.75 {
			useAbilityAtPosition(myEntityId, "Target All Players Ground Blast", entityPosition(myEntityId))
			log("Ground Blast")
			scriptVars["sendTargetAllPlayersBullet"] = true
			scriptVars["targetAllPlayersTimer"] = 0.0
		}

		
		if targetEntityId > 0 {
		scriptVars["powerCircleEnemySpawnTimer"] += delta
		

		if scriptVars["powerCircleEnemySpawnTimer"] >= 20.0 {
					useAbilityAtPosition(myEntityId, "Spawn Power Circle Enemy", entityPosition(myEntityId))
					scriptVars["powerCircleEnemySpawnTimer"] = 0.0
					log("Spawned Power Circle")
			}
		}

		if scriptVars["crossWeaveTime"] >= 8.0 {
			useAbilityAtPosition(myEntityId, "Cross Weave", positionInCurrentRoom(myEntityId, [21.0, 20.0, 0.0]))
			scriptVars["crossWeaveTime"] = 0
		}
		


		if scriptVars["rectAndLineTime"] >= 3.0 {
			
			useAbilityAtPosition(myEntityId, "Rect Throw Down", positionInCurrentRoom(myEntityId, [22.0, 3.0, 0.0]))
			useAbilityAtPosition(myEntityId, "Rect Throw Up", positionInCurrentRoom(myEntityId, [37.0, 38.0, 0.0]))
			useAbilityAtPosition(myEntityId, "Rect Throw Up", positionInCurrentRoom(myEntityId, [5.0, 38.0, 0.0]))
			useAbilityAtPosition(myEntityId, "Top Line", positionInCurrentRoom(myEntityId, [12.0, 3.0, 0.0]))
			useAbilityAtPosition(myEntityId, "Bottom Line", positionInCurrentRoom(myEntityId, [11.0, 39.0, 0.0]))

			useAbilityAtPosition(myEntityId, "Top Line", positionInCurrentRoom(myEntityId, [32.0, 3.0, 0.0]))
			useAbilityAtPosition(myEntityId, "Bottom Line", positionInCurrentRoom(myEntityId, [31.0, 39.0, 0.0]))
			scriptVars["rectAndLineTime"] = 0.0
		}

	}
	

	if scriptVars["phase"] == 2 { 

		resetVarsTwo := func() {
			scriptVars["rectExplodeTime"] = 0.0
			scriptVars["lineBulletTime"] = 1.0
			scriptVars["basicWeaveTime"] = 10.0
			scriptVars["firstRectExplode"] = false
			scriptVars["secondRectExplode"] = false
			scriptVars["thirdRectExplode"] = false
			scriptVars["fourthRectExplode"] = false
			scriptVars["fifthRectExplode"] = false
			scriptVars["sixthRectExplode"] = false
			scriptVars["seventhRectExplode"] = false
			scriptVars["eigthRectExplode"] = false
			scriptVars["ninthRectExplode"] = false
			scriptVars["tenthRectExplode"] = false
			scriptVars["eleventhRectExplode"] = false
			scriptVars["twelthRectExplode"] = false
			scriptVars["thirteenthRectExplode"] = false
			scriptVars["fourteenthRectExplode"] = false
			scriptVars["fifteenthRectExplode"] = false
			scriptVars["sixteenthRectExplode"] = false
			scriptVars["seventeenthRectExplode"] = false
			scriptVars["eighteenthRectExplode"] = false
			scriptVars["targetAllPlayersTimer"] = 0.0
			scriptVars["powerCircleEnemySpawnTimer"] = 19.0

			scriptVars["healingTowerSpawnTimer"] = 59.0
			
			scriptVars["timeSinceTeleport"] = 0.0
			scriptVars["teleportIndex"] = 0
			scriptVars["hasTeleported"] = false
			scriptVars["teleportLocations"] = [
				[12.0, 31.0, 0.0],
				[24.0, 31.0, 0.0],
				[10.0, 8.0, 0.0],
				[31.0, 8.0, 0.0]
			]
		}

		if is_undefined(scriptVars["rectExplodeTime"]) {
    		resetVarsTwo()
		}

		scriptVars["rectExplodeTime"] += delta
		scriptVars["lineBulletTime"] += delta 
		scriptVars["basicWeaveTime"] += delta
		scriptVars["targetAllPlayersTimer"] += delta
		scriptVars["timeSinceTeleport"] += delta
		scriptVars["healingTowerSpawnTimer"] += delta

		if scriptVars["healingTowerSpawnTimer"] >= 60.0 {
			useAbilityAtPosition(myEntityId, "Spawn Healing Tower Two", entityPosition(myEntityId))
			scriptVars["healingTowerSpawnTimer"] = 0
		}


		// Check if it's time to teleport 
		//if scriptVars["timeSinceTeleport"] >= 12.0 && !scriptVars["hasTeleported"] {
			// Move to the next location in the predefined list
		//	scriptVars["teleportIndex"] = (scriptVars["teleportIndex"] + 1) % len(scriptVars["teleportLocations"])
			
			// Get the new position
		//	newPosition := positionInCurrentRoom(myEntityId, scriptVars["teleportLocations"][scriptVars["teleportIndex"]])

		//	scriptVars["hasTeleported"] = true
			
			// Teleport the entity to the new position
		//	setPosition(myEntityId, newPosition)
			
		// }

		if scriptVars["timeSinceTeleport"] >= 12.3 {
			// Reset the timer
			scriptVars["timeSinceTeleport"] = 0.0
			
			useAbilityAtPosition(myEntityId, "Expand Attack", entityPosition(myEntityId))
			scriptVars["hasTeleported"] = false
		}

		if scriptVars["targetAllPlayersTimer"] >= 2.0 && scriptVars["sendTargetAllPlayersBullet"] {
			useAbilityAtPosition(myEntityId, "Target All Players Tracking Bullet", entityPosition(myEntityId))
			scriptVars["sendTargetAllPlayersBullet"] = false
			log("Tracking Bullet")
		}

		if scriptVars["targetAllPlayersTimer"] >= 5.0 {
			useAbilityAtPosition(myEntityId, "Target All Players Hoarder Beam", entityPosition(myEntityId))
			log("Hoarder Beam")
			scriptVars["sendTargetAllPlayersBullet"] = true
			scriptVars["targetAllPlayersTimer"] = 0.0
		}

		
		if targetEntityId > 0 {
		scriptVars["powerCircleEnemySpawnTimer"] += delta
		

		if scriptVars["powerCircleEnemySpawnTimer"] >= 20.0 {
				useAbilityAtPosition(myEntityId, "Spawn Power Circle Enemy", entityPosition(myEntityId))
				scriptVars["powerCircleEnemySpawnTimer"] = 0.0
				log("Spawned Power Circle")
			}
		}

		if scriptVars["basicWeaveTime"] >= 12.0 {
			useAbilityAtPosition(myEntityId, "Basic Weave", positionInCurrentRoom(myEntityId, [21.0, 20.0, 0.0]))
			scriptVars["basicWeaveTime"] = 0.0
		}

		if scriptVars["lineBulletTime"] >= 2.0 {
			useAbilityAtPosition(myEntityId, "Left Line", positionInCurrentRoom(myEntityId, [40.0, 38.0, 0.0]))
			useAbilityAtPosition(myEntityId, "Right Line", positionInCurrentRoom(myEntityId, [2.0, 36.0, 0.0]))
			useAbilityAtPosition(myEntityId, "Left Line", positionInCurrentRoom(myEntityId, [40.0, 34.0, 0.0]))
			useAbilityAtPosition(myEntityId, "Right Line", positionInCurrentRoom(myEntityId, [2.0, 32.0, 0.0]))
			useAbilityAtPosition(myEntityId, "Left Line", positionInCurrentRoom(myEntityId, [40.0, 30.0, 0.0]))
			useAbilityAtPosition(myEntityId, "Right Line", positionInCurrentRoom(myEntityId, [2.0, 28.0, 0.0]))
			useAbilityAtPosition(myEntityId, "Left Line", positionInCurrentRoom(myEntityId, [40.0, 26.0, 0.0]))
			useAbilityAtPosition(myEntityId, "Right Line", positionInCurrentRoom(myEntityId, [2.0, 24.0, 0.0]))
			useAbilityAtPosition(myEntityId, "Left Line", positionInCurrentRoom(myEntityId, [40.0, 22.0, 0.0]))
			useAbilityAtPosition(myEntityId, "Right Line", positionInCurrentRoom(myEntityId, [2.0, 20.0, 0.0]))
			useAbilityAtPosition(myEntityId, "Left Line", positionInCurrentRoom(myEntityId, [40.0, 18.0, 0.0]))
			useAbilityAtPosition(myEntityId, "Right Line", positionInCurrentRoom(myEntityId, [2.0, 16.0, 0.0]))
			useAbilityAtPosition(myEntityId, "Left Line", positionInCurrentRoom(myEntityId, [40.0, 14.0, 0.0]))
			useAbilityAtPosition(myEntityId, "Right Line", positionInCurrentRoom(myEntityId, [2.0, 12.0, 0.0]))
			useAbilityAtPosition(myEntityId, "Left Line", positionInCurrentRoom(myEntityId, [40.0, 10.0, 0.0]))
			useAbilityAtPosition(myEntityId, "Right Line", positionInCurrentRoom(myEntityId, [2.0, 8.0, 0.0]))
			useAbilityAtPosition(myEntityId, "Left Line", positionInCurrentRoom(myEntityId, [40.0, 6.0, 0.0]))
			useAbilityAtPosition(myEntityId, "Right Line", positionInCurrentRoom(myEntityId, [2.0, 4.0, 0.0]))
			scriptVars["lineBulletTime"] = 0.0 
			log("Bullet Spawned")
		}

		if scriptVars["rectExplodeTime"] >= 0.5 && !scriptVars["firstRectExplode"] {
			useAbilityAtPosition(myEntityId, "Rect Explode", positionInCurrentRoom(myEntityId, [3.0, 21.0, 0.0]))
			scriptVars["firstRectExplode"] = true
			log("Rect Explode 1")
		}
		
		

		if scriptVars["rectExplodeTime"] >= 1.0 && !scriptVars["secondRectExplode"]{
			useAbilityAtPosition(myEntityId, "Rect Explode", positionInCurrentRoom(myEntityId, [5.0, 21.0, 0.0]))
			scriptVars["secondRectExplode"] = true
			log("Rect Explode 2")
		}

		if scriptVars["rectExplodeTime"] >= 1.5 && !scriptVars["thirdRectExplode"]{
			useAbilityAtPosition(myEntityId, "Rect Explode", positionInCurrentRoom(myEntityId, [7.0, 21.0, 0.0]))
			scriptVars["thirdRectExplode"] = true
			log("Rect Explode 3")
		}

		if scriptVars["rectExplodeTime"] >= 2.0 && !scriptVars["fourthRectExplode"]{
			useAbilityAtPosition(myEntityId, "Rect Explode", positionInCurrentRoom(myEntityId, [9.0, 21.0, 0.0]))
			scriptVars["fourthRectExplode"] = true
			log("Rect Explode 4")
		}

		if scriptVars["rectExplodeTime"] >= 2.5 && !scriptVars["fifthRectExplode"]{
			useAbilityAtPosition(myEntityId, "Rect Explode", positionInCurrentRoom(myEntityId, [11.0, 21.0, 0.0]))
			scriptVars["fifthRectExplode"] = true
