		if scriptVars["rectExplodeTime"] >= 3.5 && !scriptVars["seventhRectExplode"]{
			useAbilityAtPosition(myEntityId, "Rect Explode", positionInCurrentRoom(myEntityId, [15.0, 21.0, 0.0]))
			scriptVars["seventhRectExplode"] = true
			log("Rect Explode 7")
		}

		if scriptVars["rectExplodeTime"] >= 4.0 && !scriptVars["eigthRectExplode"]{
			useAbilityAtPosition(myEntityId, "Rect Explode", positionInCurrentRoom(myEntityId, [17.0, 21.0, 0.0]))
			scriptVars["eigthRectExplode"] = true
			log("Rect Explode 8")
		}

		if scriptVars["rectExplodeTime"] >= 4.5 && !scriptVars["ninthRectExplode"]{
			useAbilityAtPosition(myEntityId, "Rect Explode", positionInCurrentRoom(myEntityId, [19.0, 21.0, 0.0]))
			scriptVars["ninthRectExplode"] = true
			log("Rect Explode 9")
		}

		if scriptVars["rectExplodeTime"] >= 5.0 && !scriptVars["tenthRectExplode"]{
			useAbilityAtPosition(myEntityId, "Rect Explode", positionInCurrentRoom(myEntityId, [21.0, 21.0, 0.0]))
			scriptVars["tenthRectExplode"] = true
			log("Rect Explode 10")
		}

		if scriptVars["rectExplodeTime"] >= 5.5 && !scriptVars["eleventhRectExplode"]{
			useAbilityAtPosition(myEntityId, "Rect Explode", positionInCurrentRoom(myEntityId, [23.0, 21.0, 0.0]))
			scriptVars["eleventhRectExplode"] = true
			log("Rect Explode 11")
		}

		if scriptVars["rectExplodeTime"] >= 6.0 && !scriptVars["twelthRectExplode"]{
			useAbilityAtPosition(myEntityId, "Rect Explode", positionInCurrentRoom(myEntityId, [25.0, 21.0, 0.0]))
			scriptVars["twelthRectExplode"] = true
			log("Rect Explode 12")
		}

		if scriptVars["rectExplodeTime"] >= 6.5 && !scriptVars["thirteenthRectExplode"]{
			useAbilityAtPosition(myEntityId, "Rect Explode", positionInCurrentRoom(myEntityId, [27.0, 21.0, 0.0]))
			scriptVars["thirteenthRectExplode"] = true
			log("Rect Explode 13")
		}

		if scriptVars["rectExplodeTime"] >= 7.0 && !scriptVars["fourteenthRectExplode"]{
			useAbilityAtPosition(myEntityId, "Rect Explode", positionInCurrentRoom(myEntityId, [29.0, 21.0, 0.0]))
			scriptVars["fourteenthRectExplode"] = true
			log("Rect Explode 14")
		}

		if scriptVars["rectExplodeTime"] >= 7.5 && !scriptVars["fifteenthRectExplode"]{
			useAbilityAtPosition(myEntityId, "Rect Explode", positionInCurrentRoom(myEntityId, [31.0, 21.0, 0.0]))
			scriptVars["fifteenthRectExplode"] = true
			log("Rect Explode 15")
		}

		if scriptVars["rectExplodeTime"] >= 8.0 && !scriptVars["sixteenthRectExplode"] {
			useAbilityAtPosition(myEntityId, "Rect Explode", positionInCurrentRoom(myEntityId, [33.0, 21.0, 0.0]))
			scriptVars["sixteenthRectExplode"] = true
			log("Rect Explode 16")
		}

		if scriptVars["rectExplodeTime"] >= 8.5 && !scriptVars["seventeenthRectExplode"] {
			useAbilityAtPosition(myEntityId, "Rect Explode", positionInCurrentRoom(myEntityId, [35.0, 21.0, 0.0]))
			scriptVars["seventeenthRectExplode"] = true
			log("Rect Explode 17")
		}

		if scriptVars["rectExplodeTime"] >= 9.0 && !scriptVars["eighteenthRectExplode"] {
			useAbilityAtPosition(myEntityId, "Rect Explode", positionInCurrentRoom(myEntityId, [37.0, 21.0, 0.0]))
			scriptVars["eighteenthRectExplode"] = true
			log("Rect Explode 18")
		}

		if scriptVars["rectExplodeTime"] >= 9.5 {
			useAbilityAtPosition(myEntityId, "Rect Explode", positionInCurrentRoom(myEntityId, [39.0, 21.0, 0.0]))
			scriptVars["rectExplodeTime"] = 0.0
			scriptVars["firstRectExplode"] = false
			scriptVars["secondRectExplode"] = false
			scriptVars["thirdRectExplode"] = false
			scriptVars["fourthRectExplode"] = false
			scriptVars["fifthRectExplode"] = false
			scriptVars["sixthRectExplode"] = false
			scriptVars["seventhRectExplode"] = false
			scriptVars["eigthRectExplode"] = false
			scriptVars["ninthRectExplode"] = false
			scriptVars["tenthRectExplode"] = false
			scriptVars["eleventhRectExplode"] = false
			scriptVars["twelthRectExplode"] = false
			scriptVars["thirteenthRectExplode"] = false
			scriptVars["fourteenthRectExplode"] = false
			scriptVars["fifteenthRectExplode"] = false
			scriptVars["sixteenthRectExplode"] = false
			scriptVars["seventeenthRectExplode"] = false
			scriptVars["eighteenthRectExplode"] = false
			log("Rect Explode 19")
		}

	}

	if scriptVars["phase"] == 3 {

		resetVarsThree := func() {
			scriptVars["powerCircleEnemySpawnTimer"] = 19.0
			scriptVars["expandRetractTime"] = 2.7
			scriptVars["rectThrowTime"] = 2.7
			scriptVars["targetAllPlayersTimer"] = 1.0
			scriptVars["sendTargetAllPlayersBullet"] = true

			scriptVars["hasTeleported"] = false
			scriptVars["timeSinceTeleport"] = 0.0
			scriptVars["teleportIndex"] = 0
			scriptVars["teleportLocations"] = [
				[12.0, 31.0, 0.0],
				[24.0, 31.0, 0.0],
				[10.0, 8.0, 0.0],
				[31.0, 8.0, 0.0]
			]
		}

		if is_undefined(scriptVars["powerCircleEnemySpawnTimer"]) {
			resetVarsThree()
		}
			// Only start spawning enemies if there's a target (player detected)
		if targetEntityId > 0 {
			scriptVars["powerCircleEnemySpawnTimer"] += delta
			

			if scriptVars["powerCircleEnemySpawnTimer"] >= 20.0 {
						useAbilityAtPosition(myEntityId, "Spawn Power Circle Enemy", entityPosition(myEntityId))
						scriptVars["powerCircleEnemySpawnTimer"] = 0.0
						log("Spawned Power Circle")
			}
		}

		scriptVars["expandRetractTime"] += delta
		scriptVars["targetAllPlayersTimer"] += delta
		scriptVars["rectThrowTime"] += delta
		scriptVars["timeSinceTeleport"] += delta

		// Check if it's time to teleport 
		if scriptVars["timeSinceTeleport"] >= 12.0 && !scriptVars["hasTeleported"] {
			// Move to the next location in the predefined list
			scriptVars["teleportIndex"] = (scriptVars["teleportIndex"] + 1) % len(scriptVars["teleportLocations"])
			
			// Get the new position
			newPosition := positionInCurrentRoom(myEntityId, scriptVars["teleportLocations"][scriptVars["teleportIndex"]])

			scriptVars["hasTeleported"] = true
			
			// Teleport the entity to the new position
			setPosition(myEntityId, newPosition)
			
		}

		if scriptVars["timeSinceTeleport"] >= 12.3 {
			// Reset the timer
			scriptVars["timeSinceTeleport"] = 0.0
			
			useAbilityAtPosition(myEntityId, "Expand And Retract Attack", entityPosition(myEntityId))
			scriptVars["hasTeleported"] = false
		}

		if scriptVars["rectThrowTime"] >= 3.75 {
				useAbilityAtPosition(myEntityId, "Rect Throw Right", positionInCurrentRoom(myEntityId, [2.0, 6.0, 0.0]))
				useAbilityAtPosition(myEntityId, "Rect Throw Right", positionInCurrentRoom(myEntityId, [2.0, 12.0, 0.0]))
				useAbilityAtPosition(myEntityId, "Rect Throw Right", positionInCurrentRoom(myEntityId, [2.0, 18.0, 0.0]))
				useAbilityAtPosition(myEntityId, "Rect Throw Right", positionInCurrentRoom(myEntityId, [2.0, 24.0, 0.0]))
				useAbilityAtPosition(myEntityId, "Rect Throw Right", positionInCurrentRoom(myEntityId, [2.0, 30.0, 0.0]))
				useAbilityAtPosition(myEntityId, "Rect Throw Right", positionInCurrentRoom(myEntityId, [2.0, 36.0, 0.0]))

				useAbilityAtPosition(myEntityId, "Bottom Line", positionInCurrentRoom(myEntityId, [37.0, 39.0, 0.0]))
				useAbilityAtPosition(myEntityId, "Bottom Line", positionInCurrentRoom(myEntityId, [34.0, 39.0, 0.0]))
				useAbilityAtPosition(myEntityId, "Bottom Line", positionInCurrentRoom(myEntityId, [31.0, 39.0, 0.0]))
				useAbilityAtPosition(myEntityId, "Bottom Line", positionInCurrentRoom(myEntityId, [28.0, 39.0, 0.0]))
				useAbilityAtPosition(myEntityId, "Bottom Line", positionInCurrentRoom(myEntityId, [25.0, 39.0, 0.0]))
				useAbilityAtPosition(myEntityId, "Bottom Line", positionInCurrentRoom(myEntityId, [22.0, 39.0, 0.0]))
				useAbilityAtPosition(myEntityId, "Bottom Line", positionInCurrentRoom(myEntityId, [19.0, 39.0, 0.0]))
				useAbilityAtPosition(myEntityId, "Bottom Line", positionInCurrentRoom(myEntityId, [16.0, 39.0, 0.0]))
				useAbilityAtPosition(myEntityId, "Bottom Line", positionInCurrentRoom(myEntityId, [13.0, 39.0, 0.0]))
				useAbilityAtPosition(myEntityId, "Bottom Line", positionInCurrentRoom(myEntityId, [10.0, 39.0, 0.0]))
				useAbilityAtPosition(myEntityId, "Bottom Line", positionInCurrentRoom(myEntityId, [7.0, 39.0, 0.0]))
				useAbilityAtPosition(myEntityId, "Bottom Line", positionInCurrentRoom(myEntityId, [4.0, 39.0, 0.0]))

				scriptVars["rectThrowTime"] = 0.0
		}





		if scriptVars["targetAllPlayersTimer"] >= 5.75 && scriptVars["sendTargetAllPlayersBullet"] {
			useAbilityAtPosition(myEntityId, "Target All Players Hoarder Beam", entityPosition(myEntityId))
			scriptVars["sendTargetAllPlayersBullet"] = false
			log("Tracking Bullet")
		}

		if scriptVars["targetAllPlayersTimer"] >= 10.75 {
			useAbilityAtPosition(myEntityId, "Target All Players Ground Blast", entityPosition(myEntityId))
			log("Tracking Bullet")
			scriptVars["sendTargetAllPlayersBullet"] = true
			scriptVars["targetAllPlayersTimer"] = 0.0
		}

		if scriptVars["expandRetractTime"] >= 2.75 {
				useAbilityAtPosition(myEntityId, "Expand And Retract", positionInCurrentRoom(myEntityId, [21.0, 20.0, 0.0]))
				scriptVars["expandRetractTime"] = 0.0
			}

	}
	
}

---mob_Power Circle Enemy---
ID :: powercircleenemy
Prefab :: obstacle
Type :: Normal
Range Behavior :: Stationary

---ability_Raid3 Immunity Pool---
Bullet Definition :: [[raid3immunitypool]]
Max Range :: 100.0

---bulletdef_raid3immunitypool---
sprite GreenPool 0.65
potency 0
fire 0 relative 0
	aoedot
	nododge
	radius 0.65
	damageEvery 10
	wait 400
	vanish

---aura_Raid3 Attacker---
Type :: Buff
Duration :: 1.0
Icon :: statusicons_7
Max Stacks :: 1
Time Per Tick :: 1.0

---script_powercircleenemy_Monster---
resetVars := func() {
	scriptVars["poolsCreated"] = false
	scriptVars["timeUntilPools"] = 0.0
	scriptVars["timeSinceCheck"] = 0.0
}

if !isDead {
	if is_undefined(scriptVars["poolsCreated"]) {
		resetVars()
	}

	scriptVars["timeUntilPools"] += delta

	if !scriptVars["poolsCreated"] && scriptVars["timeUntilPools"] >= 0.5 {
				useAbilityAtPosition(myEntityId, "Raid3 Immunity Pool", 
					entityPosition(myEntityId))
					scriptVars["poolsCreated"] = true
	}

	scriptVars["timeSinceCheck"] += delta

	if scriptVars["timeSinceCheck"] > 0.5 {

		scriptVars["timeSinceCheck"] = 0.0

		// Set the minimum distance between players for the buff to apply
		minimumDistance := 2.0

		// Get all nearby entities
		nearby := getNearbyEntities(myEntityId)

		// Count how many players are within the minimum distance
		playersWithinDistance := []

		for i := 0; i < len(nearby); i++ {
			// Since the Power Circle Enemy is now "Friendly", we use isEnemyOfEntity 
			// to identify players (from a friendly entity's perspective, players are "enemies" in faction terms)
			if isEnemyOfEntity(myEntityId, nearby[i]["id"]) && nearby[i]["id"] != myEntityId {
				// Calculate distance to this player
				dist := distToEntity(myEntityId, nearby[i]["id"])
				
				// If this player is within the minimum distance, count them
				if dist < minimumDistance {
					playersWithinDistance = append(playersWithinDistance, nearby[i]["id"])
				}
			}
		}

		// If there are 2 or more players within the minimum distance, remove the buff
		if len(playersWithinDistance) == 1 {
			addAuraToEntity(myEntityId, "Raid3 Attacker", 0, playersWithinDistance[0])
		}

	}
}

---mobdefinition_Raid 3 Healing Tower---
ID :: raid3healingtower
Prefab :: healingtower
Range Behavior :: Stationary
Type :: Normal
Speed :: 0

---prefab_healingtower---
Components :: [[HealingTowerSprite]] [[HealingTowerCollider]] [[Monster]] [[Nameplate]]

---prefabcomponent_HealingTowerCollider---
Component :: Collider
{
    "layer": "Enemy",
    "position": [0.0, 1.0],
    "size": [1.5, 2.0]
}

---prefabcomponent_HealingTowerSprite---
Component :: Sprite
{
    "pivotX": 0.5,
    "pivotY": 1.0,
    "sprite": "echodeathvictor/echodeathtowertwo",
    "animations": [
        {
            "name": "idle"
        }
    ]
}

---ability_Boss Heal Pulse---
Script :: BossHealPulse
Max Range :: 100
VFX Cast :: trigger:Heal*

---script_BossHealPulse_Cast---
if frameNum >= 0 {
	// Find all nearby entities
	nearby := getNearbyEntities(myEntityId)
	
	for i := 0; i < len(nearby); i++ {
		// Check if this entity has the Raid3 Immunity aura (which the boss has)
		auras := getAurasOnEntity(nearby[i]["id"])
		
		for j := 0; j < len(auras); j++ {
			if auras[j]["name"] == "Raid3 Immunity" && nearby[i]["id"] != myEntityId {
				// This is the boss! Heal it
				dealPotencyToEntity(myEntityId, nearby[i]["id"], -500, 0)
				log("Healing Tower healed boss (entity " + string(nearby[i]["id"]) + ") for 500 HP")
				
				// Optional: Add a visual effect at the boss location
				showVfxAtPosition(myEntityId, "HealEffect", entityPosition(nearby[i]["id"]))
			}
		}
	}
	
	// Alternative method: If the boss entity ID is stored somewhere
	// or if we know the boss is always the entity that summoned the towers
	// we could use that information instead
}

---script_raid3healingtower_Monster---
resetVars := func() {
	scriptVars["healPulseTimer"] = 19.0
	scriptVars["visualCreated"] = false
	scriptVars["timeSinceSpawn"] = 0.0
}

if !isDead {
	if is_undefined(scriptVars["healPulseTimer"]) {
		resetVars()
	}

	scriptVars["healPulseTimer"] += delta
	scriptVars["timeSinceSpawn"] += delta

	// Start healing after 2 seconds to give players time to react
	if scriptVars["timeSinceSpawn"] > 2.0 && scriptVars["healPulseTimer"] >= 20.0 {
		// Use the healing ability
		useAbilityAtPosition(myEntityId, "Boss Heal Pulse", entityPosition(myEntityId))
		scriptVars["healPulseTimer"] = 0.0
	}
}


