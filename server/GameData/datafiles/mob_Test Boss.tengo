---ability_Target All Players Ground Blast---
Script :: TargetAllPlayersGroundBlast
VFX Cast :: trigger:Attack*
Lock Time :: 1.0

---script_TargetAllPlayersGroundBlast_Cast---
// Get all nearby entities
nearby := getNearbyEntities(myEntityId)

// Loop through all entities and target players
for i := 0; i < len(nearby); i++ {
	entityId := nearby[i].id
	
	// Check if this entity is an enemy of the caster (i.e., a player)
	if isEnemyOfEntity(myEntityId, entityId) {
		// Get the player's current position
		playerPos := entityPosition(entityId)
		
		// Spawn a delayed explosion at the player's current location
		useAbilityAtPosition(myEntityId, "Delayed Ground Explosion", playerPos)
	}
}

