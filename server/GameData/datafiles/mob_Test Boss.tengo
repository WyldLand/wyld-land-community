		if scriptVars["rectExplodeTime"] >= 3.0 && !scriptVars["sixthRectExplode"] {
			useAbilityAtPosition(myEntityId, "Rect Explode", positionInCurrentRoom(myEntityId, [13.0, 21.0, 0.0]))
			scriptVars["sixthRectExplode"] = true
			log("Rect Explode 6")
