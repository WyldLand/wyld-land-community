---aura_Guardian Shield---
Type :: Buff
Duration :: -1
Icon :: statusicons_8
Max Stacks :: 1
Time Per Tick :: 1.0
Definitions :: [[Custom:GuardianShield]]

---script_GuardianShield_IncomingDamage---
// Negate all damage while shield is active
additionalDamage = -1 * damage

---script_servitor_Monster---
resetVars := func() {
	scriptVars["phase"] = 1
	scriptVars["vulnerableTimer"] = 10.0
	scriptVars["currentAttackPattern"] = 0
	scriptVars["timeSinceLastAttack"] = 0.0
	scriptVars["shieldPhaseTimer"] = 0.0
	scriptVars["timeSinceTeleport"] = 0.0
}

if !isDead {
	if is_undefined(scriptVars["phase"]) {
		resetVars()
	}

	if targetEntityId > 0 {
		// Check for Red Ball deaths
		nearby := getNearbyEntities(myEntityId)
		redBallCount := 0
		for i := 0; i < len(nearby); i++ {
			if nearby[i].prefab == "redball" && !isEntityDead(nearby[i].id) {
				redBallCount++
			}
		}

		// Update timers
		scriptVars["timeSinceLastAttack"] += delta
		scriptVars["timeSinceTeleport"] += delta
		scriptVars["shieldPhaseTimer"] += delta
		
		if redBallCount == 0 {
			// Vulnerable phase
			if hasAura := getAurasOnEntity(myEntityId); len(hasAura) > 0 {
				// Remove shield when all orbs are dead
				for i := 0; i < len(hasAura); i++ {
					if hasAura[i]["name"] == "Guardian Shield" {
						dispelAuraOnEntity(myEntityId, "Guardian Shield")
					}
				}
			}
			
			scriptVars["vulnerableTimer"] += delta
			
			if scriptVars["vulnerableTimer"] >= 26.0 {
				// Reset for next shield phase
				scriptVars["vulnerableTimer"] = 0.0
				useAbilityAtPosition(myEntityId, "Summon Shield Orbs", entityPosition(myEntityId))
			} else if castingAction == 0 {
				// Vulnerable phase attacks
				if scriptVars["timeSinceTeleport"] > 5.0 {
					useAbilityAtTarget(myEntityId, "Void Blast", targetEntityId, 1.0)
					useAbilityAtTarget(myEntityId, "Servitor Phase Shift", targetEntityId, 0.5)
					scriptVars["timeSinceTeleport"] = 0.0
				} else if scriptVars["timeSinceLastAttack"] > 3.0 {
					useAbilityAtPosition(myEntityId, "Ring of Fire", entityPosition(myEntityId))
					useAbilityAtPosition(myEntityId, "Vulnerability Blast", entityPosition(myEntityId))
					scriptVars["timeSinceLastAttack"] = 0.0
				}
			}
		} else {
			// Shielded phase
			
			if castingAction == 0 {
				if scriptVars["currentAttackPattern"] == 0 {
					// Pattern 1: Energy + Cross
					if scriptVars["timeSinceLastAttack"] > 2.0 {
						useAbilityAtTarget(myEntityId, "Energy Barrage", targetEntityId, 1.0)
						useAbilityAtPosition(myEntityId, "Cross Blast", entityPosition(myEntityId))
						scriptVars["timeSinceLastAttack"] = 0.0
					}
				} else if scriptVars["currentAttackPattern"] == 1 {
					// Pattern 2: Beam + Ring
					if scriptVars["timeSinceLastAttack"] > 2.5 {
						useAbilityAtTarget(myEntityId, "Beam Array", targetEntityId, 1.0)
						useAbilityAtPosition(myEntityId, "Ring of Fire", entityPosition(myEntityId))
						scriptVars["timeSinceLastAttack"] = 0.0
					}
				} else {
					// Pattern 3: Spiral + Void
					if scriptVars["timeSinceLastAttack"] > 3.0 {
						useAbilityAtPosition(myEntityId, "Spiral Storm", entityPosition(myEntityId))
						useAbilityAtTarget(myEntityId, "Void Blast", targetEntityId, 1.0)
						scriptVars["timeSinceLastAttack"] = 0.0
					}
				}
				
				// Change attack pattern every 10 seconds
				if scriptVars["shieldPhaseTimer"] >= 10.0 {
					scriptVars["currentAttackPattern"] = (scriptVars["currentAttackPattern"] + 1) % 3
					scriptVars["shieldPhaseTimer"] = 0.0
				}
			}
		}
	}
}
