---ability_Summon Shield Orbs---
VFX Charging :: trigger:Attack2*
Cast Time :: 1.0
Script :: SummonShieldOrbs

---script_SummonShieldOrbs_Cast---
if frameNum == 5 {
	// Spawn Red Balls in a pentagon formation around the room
	positions := [
		[8.0, 8.0],   // Top left
		[24.0, 8.0],  // Top right
		[8.0, 24.0],  // Bottom left
		[24.0, 24.0]  // Bottom right
	]
	
	for i := 0; i < len(positions); i++ {
		newId := summonEntity("redball", positionInCurrentRoom(myEntityId, [positions[i][0], positions[i][1], 0.0]), monsterLevel(myEntityId))
		aggroMyTargets(myEntityId, newId)
		killEntityIfEntityDies(newId, myEntityId)
	}
}

if frameNum == 19 {    
	// Add shield aura
	addAuraToEntity(myEntityId, "Guardian Shield", 0, myEntityId)
}

