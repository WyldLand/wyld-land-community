---ability_Servitor Phase Shift---
VFX Charging :: trigger:Attack4*
Cast Time :: 1.0
Lock Time :: 1.0
Script :: ServitorPhaseShift

---script_ServitorPhaseShift_Cast---
setSpeed(myEntityId, 0.0)

if frameNum == 5 {
	setCollisionLayer(myEntityId, CollisionLayerDynamic)
}

if frameNum == 15 {
	targetPos := randomPositionInCurrentRoom(myEntityId, 6.0)
	setPosition(myEntityId, targetPos)
	setCollisionLayer(myEntityId, CollisionLayerMonster)
}

