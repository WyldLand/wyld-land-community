---spike_Stationary Damage---
Auras :: [[Stationary Damage]]

Creates a targeting zone with first bullet of every magazine. Shots fired while standing in your zone deal significantly more damage.

---aura_Stationary Damage---
Type :: Buff
Duration :: -1
Icon :: 
Max Stacks :: 1
Time Per Tick :: 1.0
Definitions :: [[Custom:StationaryDamage]]

---script_StationaryDamage_Equipped---
// Initialize variables when gun is first equipped
scriptVars["initialized"] = true
scriptVars["zonePosition"] = [0, 0, 0]
scriptVars["hasZone"] = false

---script_StationaryDamage_FireWeapon---
// When the weapon is fired
if abilityId == auraAbilityId {
    // Check if this is the first bullet of the clip
    if gunState["BulletsFired"] == 0 {
        // Create a zone at the player's position
        playerPosition := entityPosition(myEntityId)
        useAbilityAtPosition(myEntityId, "Stationary Zone", playerPosition)
        scriptVars["zonePosition"] = playerPosition
        scriptVars["hasZone"] = true
        showVfxAtPosition(myEntityId, "EnergyBurst", playerPosition)
    }
    
    // Mark the gun as active whenever it's fired
    scriptVars["isActive"] = true
    scriptVars["lastActivationTime"] = globalTick
}

---script_StationaryDamage_ReloadWeapon---
// When reloading, mark the gun as active
if abilityId == auraAbilityId {
    scriptVars["isActive"] = true
    scriptVars["lastActivationTime"] = globalTick
}

---script_StationaryDamage_DamageDealt---
// This script runs when damage is dealt, which gives us access to the target entity
if abilityId == auraAbilityId {
    // Check if player is inside the zone
    if !is_undefined(scriptVars["zonePosition"]) {
        playerPos := entityPosition(myEntityId)
        distToZoneCenter := distToPoint(myEntityId, scriptVars["zonePosition"])
        
        // If player is within 4 units of zone center (the zone radius)
        if distToZoneCenter <= 5.0 {
            // Calculate extra damage
            extraDamage := damage 
            
            // Apply extra damage directly to ensure it works
            attackEntity(myEntityId, damageSenderId, extraDamage, -99)
            
            // Show visual effect at target
            showVfxAtPosition(damageSenderId, "MediumHit", damagePosition)
        }
    }
}