---script_Chronoshift_DamageDealt---
if abilityId == auraAbilityId {
    if is_undefined(scriptVars["bonusBullets"]) {
        scriptVars["bonusBullets"] = 0
    }
    scriptVars["bonusBullets"] += 1
}

---script_Chronoshift_BulletHit---
if abilityId == auraAbilityId && hitLayer == CollisionLayerStatic {
	if is_undefined(scriptVars["bonusBullets"]) {
        scriptVars["bonusBullets"] = 0
    }
    scriptVars["bonusBullets"] -= 1
}

---script_Chronoshift_FireWeapon---
if abilityId == auraAbilityId {
    if gunState["BulletsFired"] == gunState["BulletsInChamber"] - 1 {  // Last bullet
        if !is_undefined(scriptVars["bonusBullets"]) && scriptVars["bonusBullets"] > 0 {
            if scriptVars["bonusBullets"] >= 1 {
                useAbilityAtPosition(myEntityId, "Chronoshift Bonus Shot", [0.0,0.0,0.0], positionAddDegreesDistance(entityPosition(myEntityId, true), aimingAngle, 2.0)) //using at [0,0,0] means use at my current position
            }
			if scriptVars["bonusBullets"] >= 2 {
                useAbilityAtPosition(myEntityId, "Chronoshift Bonus ShotTwo", [0.0,0.0,0.0], positionAddDegreesDistance(entityPosition(myEntityId, true), aimingAngle, 2.0)) //using at [0,0,0] means use at my current position
            }
			if scriptVars["bonusBullets"] >= 3 {
                useAbilityAtPosition(myEntityId, "Chronoshift Bonus ShotThree", [0.0,0.0,0.0], positionAddDegreesDistance(entityPosition(myEntityId, true), aimingAngle, 2.0)) //using at [0,0,0] means use at my current position
            }
			if scriptVars["bonusBullets"] >= 4 {
                useAbilityAtPosition(myEntityId, "Chronoshift Bonus ShotFour", [0.0,0.0,0.0], positionAddDegreesDistance(entityPosition(myEntityId, true), aimingAngle, 2.0)) //using at [0,0,0] means use at my current position
            }
            scriptVars["bonusBullets"] = 0
        }
    }
}

---script_Chronoshift_ReloadWeapon---

if abilityId == auraAbilityId {
    scriptVars["bonusBullets"] = 0
}