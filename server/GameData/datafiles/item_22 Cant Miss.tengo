---spike_Cant Miss---
Auras :: [[Cant Miss]]

---aura_Cant Miss---
Type :: Buff
Duration :: -1
Icon :: 
Max Stacks :: 10
Time Per Tick :: 1.0
Definitions :: [[Custom:CantMiss]]

---script_CantMiss_DamageDealt---
if abilityId == auraAbilityId {
	if is_undefined(scriptVars["hitCounter"]) {
		scriptVars["hitCounter"] = 0
	}
	
	// Refund bullet on hit
	addAmmoToClip(myEntityId, abilityId, 1)
	
	scriptVars["hitCounter"] += 1
	
	if scriptVars["hitCounter"] >= 4 {
		// Create explosion at the target's position
		targetPos := entityPosition(damageSenderId)
		addAuraToEntity(myEntityId, "Cant Miss Plus Damage", auraAbilityId, myEntityId)
		scriptVars["hitCounter"] = 0
		showVfxAtPosition(myEntityId, "PowerSpike", targetPos)
	}
}

---script_CantMiss_FireWeapon---
// Apply slow debuff to player when firing
if abilityId == auraAbilityId {
	addAuraToEntity(myEntityId, "Cant Miss Slow", auraAbilityId, myEntityId)
}

---script_CantMiss_BulletHit---
// Check if the bullet missed (hit static collision like walls, not enemies)
if auraAbilityId == abilityId && hitLayer == CollisionLayerStatic {
	// Reset hit counter on miss
	if !is_undefined(scriptVars["hitCounter"]) {
		scriptVars["hitCounter"] = 0
	}

	scriptVars["hitCounter"] = 0
	

	dispelAuraOnEntity(myEntityId, "Cant Miss Plus Damage")
	dispelAuraOnEntity(myEntityId, "Cant Miss Plus Damage")
	dispelAuraOnEntity(myEntityId, "Cant Miss Plus Damage")
	dispelAuraOnEntity(myEntityId, "Cant Miss Plus Damage")
	dispelAuraOnEntity(myEntityId, "Cant Miss Plus Damage")
}

