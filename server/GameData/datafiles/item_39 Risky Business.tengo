---aura_Risky Business Active---
Type :: Buff
Duration :: -1
Icon :: statusicons_8
Max Stacks :: 1
Existing :: Replace
Time Per Tick :: 1.0
Definitions :: [[Custom:RiskyBusinessActive]]

---script_RiskyBusiness_FireWeapon---


if auraAbilityId == abilityId {
	addAuraToEntity(myEntityId, "Risky Business Active", auraAbilityId, myEntityId)
}

---script_RiskyBusinessActive_BulletHit---
if abilityId < 4 && ticksElapsed >= 6 { //was a bullet hit with our gun
    dispelAuraOnEntity(myEntityId, "Risky Business Active")
}

---script_RiskyBusinessActive_IncomingDamage---
if is_undefined(scriptVars["riskyBusinessDamageAbsorbed"]) {
    scriptVars["riskyBusinessDamageAbsorbed"] = 0
}

if ticksElapsed < 6 {
    scriptVars["riskyBusinessDamageAbsorbed"] = scriptVars["riskyBusinessDamageAbsorbed"] + int(0.8 * float(damage))
    additionalDamage = int(0.5 * float(damage)) * -1   
}

---script_RiskyBusinessActive_OutgoingDamage---
if is_undefined(scriptVars["riskyBusinessDamageAbsorbed"]) {
    scriptVars["riskyBusinessDamageAbsorbed"] = 0
}

if ticksElapsed >= 6 && abilityId < 4 {
    additionalDamage = scriptVars["riskyBusinessDamageAbsorbed"]
    scriptVars["riskyBusinessDamageAbsorbed"] = 0
}

---script_RiskyBusinessActive_Tick---
if ticksElapsed >= 6 && is_undefined(scriptVars["riskyBusinessShowVfx"]) {
    showVfxAtPosition(myEntityId, "RiskyBusiness", entityPosition(myEntityId))
    scriptVars["riskyBusinessShowVfx"] = true
}